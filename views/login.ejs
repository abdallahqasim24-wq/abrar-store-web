<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>تسجيل الدخول</title>
  <link rel="stylesheet" href="<%= faLink %>">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#fff0f6; --card:#fff; --border:#f0cfe1; --danger:#e53935; --brand:#ff7aa5; --brand2:#ffb58a;
    }
    *{ box-sizing:border-box } body{ margin:0; font-family:"Tajawal",system-ui; background:var(--bg) }

    .topbar{ padding:14px 16px; background:linear-gradient(90deg, var(--brand) 0%, var(--brand2) 100%); }
    .wrap{ max-width:420px; margin:50px auto; background:var(--card); border:1px solid var(--border); border-radius:18px; box-shadow:0 12px 28px rgba(255,0,130,.08); padding:22px }
    h1{ margin:0 0 18px 0; text-align:center; font-weight:800 }

    .form-group{ margin-bottom:14px }
    label{ display:block; margin-bottom:6px; font-weight:700 }
    input[type="text"], input[type="password"]{ width:100%; padding:11px 12px; border:1px solid var(--border); border-radius:12px; background:#fff }
    .btn{ width:100%; border:none; border-radius:12px; padding:11px 14px; font-weight:800; color:#fff; background:#1976d2; cursor:pointer }
    .btn i{ margin-left:6px }
    .error{ color:var(--danger); margin-bottom:10px; text-align:center; font-weight:700 }
    .note{ text-align:center; color:#666; margin-top:10px; font-size:.92rem }
  </style>
</head>
<body>
  <div class="topbar"></div>

  <div class="wrap">
    <h1>تسجيل الدخول</h1>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="post" action="/login" class="login-form">
      <div class="form-group">
        <label>اسم المستخدم</label>
        <input type="text" name="username" value="<%= usernamePrefill %>" required>
      </div>

      <div class="form-group">
        <label>كلمة المرور</label>
        <input type="password" name="password" required>
      </div>

      <input type="hidden" name="next" value="<%= next %>">

      <button type="submit" class="btn">
        <i class="fa fa-right-to-bracket"></i> دخول
      </button>

      <div class="note">أدخل بياناتك ثم اضغط دخول</div>
    </form>
  </div>
</body>
</html>
