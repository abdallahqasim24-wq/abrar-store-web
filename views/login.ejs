<div class="card" style="max-width:520px;margin:40px auto">
  <h3><i class="fa fa-right-to-bracket"></i> تسجيل الدخول</h3>
  <% if (error) { %>
    <div class="card" style="background:#fff3f3;border-color:#fca5a5;margin-bottom:10px;color:#991b1b">
      <%= error %>
    </div>
  <% } %>
  <form method="post" action="/login" class="form-grid">
    <input type="hidden" name="next" value="<%= next %>"/>
    <div>
      <label>اسم المستخدم</label>
      <input name="username" value="<%= usernamePrefill %>" required />
    </div>
    <div>
      <label>كلمة المرور</label>
      <input type="password" name="password" required />
    </div>
    <div class="right"></div>
    <div class="row right"><button class="btn save"><i class="fa fa-check"></i> دخول</button></div>
  </form>
</div>
