<link rel="stylesheet" href="<%= faLink %>">

<style>
  .form-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:14px;
  }
  .form-grid label{font-weight:700;font-size:.9rem;color:#374151;margin-bottom:4px;display:block}
  .items-table{width:100%;border-collapse:collapse;margin-top:18px}
  .items-table th,.items-table td{padding:10px;border:1px solid #f1f5f9;text-align:center}
  .items-table th{background:#feeef5}
  .btn.add-row{background:#2563eb;color:#fff;border:none;padding:8px 14px;border-radius:10px;font-weight:700}
  .btn.save{background:#16a34a;color:#fff;padding:10px 16px;border:none;border-radius:12px;font-weight:700}
  .remove-btn{background:#ef4444;color:#fff;border:none;border-radius:50%;width:32px;height:32px;cursor:pointer}
</style>

<h2><i class="fa fa-cart-plus"></i> إضافة عملية بيع (عدة منتجات)</h2>

<form method="post" action="/orders">
  <div class="form-grid">
    <div>
      <label>رقم الطلب</label>
      <input type="number" name="order_id" placeholder="أدخل رقم الطلب">
    </div>
    <div>
      <label>اسم الزبون</label>
      <input type="text" name="customer_name">
    </div>
    <div>
      <label>الهاتف</label>
      <input type="text" name="customer_phone">
    </div>
    <div>
      <label>المدينة</label>
      <input type="text" name="customer_city">
    </div>
    <div style="grid-column:1/-1">
      <label>ملاحظة عامة</label>
      <input type="text" name="note">
    </div>
  </div>

  <table class="items-table" id="itemsTable">
    <thead>
      <tr>
        <th>المنتج</th>
        <th>كمية</th>
        <th>سعر بيع (₪)</th>
        <th>سعر أصلي (₪)</th>
        <th>شحن (₪)</th>
        <th>ملاحظة</th>
        <th>حذف</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          <select name="product_id" required>
            <option value="">— اختر —</option>
            <% products.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.name %> (مخزون: <%= p.stock %>)</option>
            <% }) %>
          </select>
        </td>
        <td><input type="number" name="quantity" value="1" min="1"></td>
        <td><input type="number" step="0.01" name="sale_price"></td>
        <td><input type="number" step="0.01" name="cost_price"></td>
        <td><input type="number" step="0.01" name="shipping_cost"></td>
        <td><input type="text" name="item_note"></td>
        <td><button type="button" class="remove-btn">&times;</button></td>
      </tr>
    </tbody>
  </table>

  <div style="margin-top:12px">
    <button type="button" class="btn add-row"><i class="fa fa-plus"></i> إضافة صف</button>
  </div>

  <div style="margin-top:16px">
    <button type="submit" class="btn save"><i class="fa fa-save"></i> حفظ الطلب</button>
  </div>
</form>

<script>
  // تكرار الصفوف
  const table = document.getElementById("itemsTable").querySelector("tbody");
  document.querySelector(".add-row").addEventListener("click",()=>{
    const clone = table.rows[0].cloneNode(true);
    clone.querySelectorAll("input").forEach(i=>i.value="");
    clone.querySelector("select").selectedIndex=0;
    table.appendChild(clone);
  });

  // حذف الصف
  table.addEventListener("click",e=>{
    if(e.target.classList.contains("remove-btn")){
      if(table.rows.length>1) e.target.closest("tr").remove();
    }
  });
</script>
