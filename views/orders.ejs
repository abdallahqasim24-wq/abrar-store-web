<!-- views/orders.ejs — صفحة "كل الطلبات" (نسخة مرتّبة ونهائية) -->
<link rel="stylesheet" href="<%= faLink %>">

<%
  // حماية إذا filters ما وصل من السيرفر
  const _filters = (typeof filters !== 'undefined' && filters) ? filters : {};
  const st = _filters.status || 'all';
  const so = _filters.sort   || 'newest';

  function statusLabel(s){
    switch(String(s||'').toLowerCase()){
      case 'pending':    return 'قيد الإدخال';
      case 'processing': return 'قيد المعالجة';
      case 'shipping':   return 'قيد التوصيل';
      case 'delivered':  return 'تم التسليم';
      case 'failed':     return 'فشل/لم يتم';
      default:           return s || '—';
    }
  }
%>

<div class="container page">

  <!-- العنوان + الفلاتر -->
  <div class="row" style="justify-content:space-between;align-items:center;gap:10px">
    <h2 style="margin:0"><i class="fa fa-list"></i> كل الطلبات
      <span class="muted">(<%= (orders||[]).length %>)</span></h2>

    <form method="get" action="/orders" class="row" style="gap:8px">
      <select name="status" onchange="this.form.submit()">
        <option value="all"        <%= st==='all'?'selected':'' %>       >كل الحالات</option>
        <option value="pending"    <%= st==='pending'?'selected':'' %>    >قيد الإدخال</option>
        <option value="processing" <%= st==='processing'?'selected':'' %> >قيد المعالجة</option>
        <option value="shipping"   <%= st==='shipping'?'selected':'' %>   >قيد التوصيل</option>
        <option value="delivered"  <%= st==='delivered'?'selected':'' %>  >تم التسليم</option>
        <option value="failed"     <%= st==='failed'?'selected':'' %>     >فشل/لم يتم</option>
      </select>

      <select name="sort" onchange="this.form.submit()">
        <option value="newest" <%= so==='newest'?'selected':'' %> >الأحدث أولاً</option>
        <option value="oldest" <%= so==='oldest'?'selected':'' %> >الأقدم أولاً</option>
      </select>
      <noscript><button class="btn info">تطبيق</button></noscript>
    </form>
  </div>

  <!-- شريط الأوامر الجماعية -->
  <form id="bulkForm" method="post">
    <input type="hidden" name="ids" id="bulkIds">

    <div class="bulk-bar" style="margin:12px 0">
      <label class="row" style="gap:8px;align-items:center;cursor:pointer">
        <input id="selectAll" type="checkbox">
        <span class="bulk-title">تحديد الكل</span>
      </label>

      <span class="muted">على <span id="selCount" class="bulk-count">0</span> طلب</span>

      <div class="bulk-actions" style="display:flex;gap:8px;flex-wrap:wrap">
        <input type="hidden" name="apply_to_items" value="on">
        <button data-bulk class="btn warn"     formaction="/orders/bulk-status" name="status" value="pending"    type="submit"><i class="fa fa-hourglass-start"></i> إلى قيد الإدخال</button>
        <button data-bulk class="btn info"     formaction="/orders/bulk-status" name="status" value="processing" type="submit"><i class="fa fa-gears"></i> إلى قيد المعالجة</button>
        <button data-bulk class="btn gray"     formaction="/orders/bulk-status" name="status" value="shipping"   type="submit"><i class="fa fa-truck"></i> إلى قيد التوصيل</button>
        <button data-bulk class="btn success"  formaction="/orders/bulk-status" name="status" value="delivered"  type="submit"><i class="fa fa-check"></i> تم التسليم</button>
        <button data-bulk class="btn danger"   formaction="/orders/bulk-status" name="status" value="failed"     type="submit"><i class="fa fa-xmark"></i> فشل التسليم</button>
      </div>

      <span class="right"></span>

      <button data-bulk class="btn danger" formaction="/orders/bulk-delete" type="submit"
              onclick="return confirm('حذف الطلبات المحددة نهائيًا؟')">
        <i class="fa fa-trash"></i> حذف المحدّد
      </button>
    </div>

    <!-- بطاقات الطلبات -->
    <div class="cards">
      <% (orders||[]).forEach(o => {
        const its   = (itemsByOrder && itemsByOrder[o.id]) || [];
        const shown = its.slice(0, 4);
        const more  = Math.max(0, its.length - shown.length);

        const allDelivered = its.length && its.every(x=>x.delivery_status==='delivered');
        const allFailed    = its.length && its.every(x=>x.delivery_status==='failed');
        const effStatus    = allFailed ? 'failed' : (allDelivered ? 'delivered' : (o.status || 'pending'));

        const totalQty = its.reduce((a,x)=>a + Number(x.quantity||0), 0);
        const revenue  = its.reduce((a,x)=>a + Number(x.sale_price||0) * Number(x.quantity||0), 0);
        const profit   = its.reduce((a,x)=> a + (Number(x.sale_price)*Number(x.quantity) - Number(x.cost_price)*Number(x.quantity)), 0);
      %>

      <div class="card order-card" data-oid="<%= o.id %>">
        <!-- رأس البطاقة -->
        <div class="row" style="justify-content:space-between;align-items:center;gap:10px">
          <label class="row" style="gap:10px;align-items:center;cursor:pointer">
            <input class="sel" type="checkbox" data-oid="<%= o.id %>">
            <span class="status-chip status-<%= effStatus %>">
              <i class="fa fa-hashtag"></i> #<%= o.id %> — <%= statusLabel(effStatus) %>
            </span>
          </label>

          <div class="order-kpis">
            <span><i class="fa fa-box"></i> <strong><%= totalQty %></strong> بنود</span>
            <span><i class="fa fa-coins"></i> الإيراد: <strong><%= revenue.toFixed(2) %></strong></span>
            <span><i class="fa fa-sack-dollar"></i> الربح: <strong><%= profit.toFixed(2) %></strong></span>
          </div>
        </div>

        <!-- معلومات العميل -->
        <div class="row" style="gap:14px;align-items:center;margin-top:6px">
          <span class="muted-sm"><i class="fa fa-clock"></i>
            <%= dayjs(o.created_at).tz(TZ_NAME||'Asia/Hebron').format('YYYY-MM-DD HH:mm') %></span>
          <span class="muted-sm"><i class="fa fa-user"></i> <%= o.customer_name || '—' %></span>
          <span class="muted-sm"><i class="fa fa-phone"></i> <%= o.customer_phone || '—' %></span>
          <span class="muted-sm"><i class="fa fa-location-dot"></i> <%= o.customer_city || '—' %></span>
        </div>

        <!-- معاينة البنود -->
        <div style="margin-top:12px">
          <% if (!its.length) { %>
            <div class="muted">لا يوجد بنود بعد.</div>
          <% } else { %>
            <div class="row" style="gap:10px;flex-wrap:wrap">
              <% shown.forEach(x => { %>
                <div class="badge">
                  <i class="fa fa-cube"></i>
                  <span><%= x.product_name %></span>
                  <span class="muted-sm">× <%= x.quantity %></span>
                </div>
              <% }) %>
              <% if (more>0) { %>
                <div class="badge muted">+<%= more %> أخرى</div>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- أزرار سريعة -->
        <div class="row order-quick" style="gap:8px;align-items:center;margin-top:14px">
          <form method="post" action="/orders/<%= o.id %>/status">
            <input type="hidden" name="apply_to_items" value="on">
            <input type="hidden" name="status" value="pending">
            <button class="btn warn" type="submit" title="إلى قيد الإدخال"><i class="fa fa-hourglass-start"></i></button>
          </form>

          <form method="post" action="/orders/<%= o.id %>/status">
            <input type="hidden" name="apply_to_items" value="on">
            <input type="hidden" name="status" value="processing">
            <button class="btn info" type="submit" title="إلى قيد المعالجة"><i class="fa fa-gears"></i></button>
          </form>

          <form method="post" action="/orders/<%= o.id %>/status">
            <input type="hidden" name="apply_to_items" value="on">
            <input type="hidden" name="status" value="shipping">
            <button class="btn gray" type="submit" title="إلى قيد التوصيل"><i class="fa fa-truck"></i></button>
          </form>

          <form method="post" action="/orders/<%= o.id %>/status">
            <input type="hidden" name="apply_to_items" value="on">
            <input type="hidden" name="status" value="delivered">
            <button class="btn success" type="submit" title="تم التسليم"><i class="fa fa-check"></i></button>
          </form>

          <form method="post" action="/orders/<%= o.id %>/status">
            <input type="hidden" name="apply_to_items" value="on">
            <input type="hidden" name="status" value="failed">
            <button class="btn danger" type="submit" title="فشل التسليم"><i class="fa fa-xmark"></i></button>
          </form>

          <a class="btn manage" href="/orders/<%= o.id %>"><i class="fa fa-pen-to-square"></i> إدارة</a>
        </div>
      </div>

      <% }) %>
    </div>
  </form>
</div>

<!-- سكريبت بسيط لإدارة التحديد الجماعي -->
<script>
  (function(){
    const $$ = (s,ctx=document)=>Array.from(ctx.querySelectorAll(s));
    const selected = new Set();
    const selCount = document.getElementById('selCount');
    const bulkIds  = document.getElementById('bulkIds');
    const selectAll = document.getElementById('selectAll');

    function sync(){
      selCount.textContent = selected.size;
      bulkIds.value = Array.from(selected).join(',');
      // مزامنة حالة selectAll
      const boxes = $$('.sel');
      selectAll.checked = (boxes.length>0 && boxes.every(b=>b.checked));
    }

    $$('.sel').forEach(cb=>{
      cb.addEventListener('change', ()=>{
        const id = cb.getAttribute('data-oid');
        cb.checked ? selected.add(id) : selected.delete(id);
        sync();
      });
    });

    if (selectAll){
      selectAll.addEventListener('change', ()=>{
        const on = selectAll.checked;
        $$('.sel').forEach(cb=>{
          cb.checked = on;
          const id = cb.getAttribute('data-oid');
          on ? selected.add(id) : selected.delete(id);
        });
        sync();
      });
    }

    // عند الضغط على أي زر جماعي، امنع الإرسال إذا لا يوجد محدد
    document.getElementById('bulkForm')?.addEventListener('click', (e)=>{
      const btn = e.target.closest('[data-bulk]');
      if (!btn) return;
      if (selected.size===0){
        e.preventDefault();
        alert('اختر طلبًا واحدًا على الأقل.');
      }
    });

    sync();
  })();
</script>
