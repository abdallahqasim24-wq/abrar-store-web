<!-- views/orders.ejs — واجهة طلبات مُحسّنة مع تحديد الكل وأوامر جماعية -->

<link rel="stylesheet" href="<%= faLink %>">

<div class="container page">
  <div class="row" style="justify-content:space-between;align-items:center;gap:10px">
    <h2 style="margin:0"><i class="fa fa-list"></i> كل الطلبات <span class="muted">(<%= (orders||[]).length %>)</span></h2>

    <!-- فلاتر -->
    <form method="get" action="/orders" class="row" style="gap:8px">
      <select name="status" onchange="this.form.submit()">
        <% const st = (filters&&filters.status)||'all' %>
        <option value="all"       <%= st==='all'?'selected':'' %> >كل الحالات</option>
        <option value="pending"   <%= st==='pending'?'selected':'' %> >قيد الإدخال</option>
        <option value="processing"<%= st==='processing'?'selected':'' %> >قيد المعالجة</option>
        <option value="shipping"  <%= st==='shipping'?'selected':'' %> >قيد التوصيل</option>
        <option value="delivered" <%= st==='delivered'?'selected':'' %> >تم التسليم</option>
        <option value="failed"    <%= st==='failed'?'selected':'' %> >فشل/لم يتم</option>
      </select>

      <select name="sort" onchange="this.form.submit()">
        <% const so = (filters&&filters.sort)||'newest' %>
        <option value="newest" <%= so==='newest'?'selected':'' %> >الأحدث أولاً</option>
        <option value="oldest" <%= so==='oldest'?'selected':'' %> >الأقدم أولاً</option>
      </select>
      <noscript><button class="btn">تطبيق</button></noscript>
    </form>
  </div>

  <!-- شريط أوامر جماعية -->
  <form id="bulkForm" method="post">
    <div class="card" style="margin:10px 0">
      <div class="row" style="gap:8px;align-items:center;flex-wrap:wrap">
        <label class="row" style="gap:6px;align-items:center">
          <input id="selectAll" type="checkbox">
          <b>تحديد الكل</b>
        </label>

        <span class="muted">على <span id="selCount">0</span> طلب</span>

        <button class="btn"      formaction="/orders/bulk-status" name="status" value="pending"   type="submit"><i class="fa fa-hourglass-start"></i> إلى قيد الإدخال</button>
        <button class="btn"      formaction="/orders/bulk-status" name="status" value="processing"type="submit"><i class="fa fa-gears"></i> إلى قيد المعالجة</button>
        <button class="btn"      formaction="/orders/bulk-status" name="status" value="shipping"  type="submit"><i class="fa fa-truck"></i> إلى قيد التوصيل</button>
        <button class="btn save" formaction="/orders/bulk-status" name="status" value="delivered" type="submit"><i class="fa fa-check"></i> تعليم كمسلّمة</button>
        <button class="btn danger" formaction="/orders/bulk-status" name="status" value="failed" type="submit"><i class="fa fa-xmark"></i> تعليم كفاشلة</button>

        <span class="right"></span>

        <button class="btn danger" formaction="/orders/bulk-delete" type="submit" onclick="return confirm('حذف الطلبات المحددة نهائيًا؟')">
          <i class="fa fa-trash"></i> حذف المحدّد
        </button>
      </div>
    </div>

    <!-- الكروت -->
    <div class="cards">
      <% (orders||[]).forEach(o => {
           const its = (itemsByOrder && itemsByOrder[o.id]) || [];
           const shown = its.slice(0, 4);
           const more = Math.max(0, its.length - shown.length);

           const isDelivered = its.length && its.every(x=>x.delivery_status==='delivered');
           const isFailed    = its.length && its.every(x=>x.delivery_status==='failed');

           const totalQty = its.reduce((a,x)=>a + Number(x.quantity||0), 0);
           const revenue  = its.reduce((a,x)=>a + Number(x.sale_price||0) * Number(x.quantity||0), 0);
          const profit   = its.reduce((a,x)=> 
  a + ( (Number(x.sale_price) * Number(x.quantity)) - (Number(x.cost_price) * Number(x.quantity)) )
, 0);

      %>
        <div class="card">
          <!-- صف علوي: تحديد + حالة + رقم + وقت -->
          <div class="row" style="justify-content:space-between;align-items:center;gap:10px">
            <div class="row" style="gap:10px;align-items:center">
              <input class="rowCheck" type="checkbox" name="ids" value="<%= o.id %>">
              <span class="tag" style="background:<%= isFailed ? '#fee2e2' : (isDelivered ? '#dcfce7' : '#f1f5f9') %>">
                <% if (isFailed) { %> فشل/لم يتم <i class="fa fa-xmark"></i>
                <% } else if (isDelivered) { %> تم التسليم <i class="fa fa-check"></i>
                <% } else { %> <%= o.status || 'قيد التنفيذ' %> <% } %>
              </span>
              <b>#<%= o.id %></b>
            </div>

            <div class="muted-sm">
              <i class="fa fa-clock"></i>
              <%= dayjs(o.created_at).tz(TZ_NAME).format('YYYY-MM-DD HH:mm') %>
            </div>
          </div>

          <!-- معلومات زبون مختصرة -->
          <div class="row muted-sm" style="gap:12px; margin-top:6px; flex-wrap:wrap">
            <span><i class="fa fa-user"></i> <%= o.customer_name || 'بدون اسم' %></span>
            <span><i class="fa fa-phone"></i> <%= o.customer_phone || '—' %></span>
            <span><i class="fa fa-location-dot"></i> <%= o.customer_city || '—' %></span>
          </div>

          <!-- ملخص المنتجات -->
          <div class="row" style="gap:10px; margin:10px 0; align-items:center; flex-wrap:wrap">
            <% if (!its.length) { %>
              <div class="muted">لا يوجد بنود بعد.</div>
            <% } %>

            <% shown.forEach(it => { %>
              <div class="row" title="<%- it.product_name %>" style="gap:8px; padding:6px 8px; border:1px solid var(--border); border-radius:12px; background:#fff">
                <img src="<%= it.product_image || 'https://via.placeholder.com/80?text=No+Img' %>"
                     style="width:44px;height:44px;object-fit:cover;border-radius:10px;border:1px solid var(--border)"
                     onerror="this.onerror=null;this.src='https://via.placeholder.com/80?text=No+Img';">
                <div class="right" style="max-width:180px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">
                  <div style="font-weight:700"><%- it.product_name %></div>
                  <div class="muted-sm">× <%= it.quantity %></div>
                </div>
              </div>
            <% }) %>

            <% if (more > 0) { %>
              <span class="tag">+<%= more %> أخرى</span>
            <% } %>
          </div>

          <!-- أزرار الحالة المختصرة + فتح الطلب + إحصائيات -->
          <div class="row" style="justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
            <div class="row" style="gap:6px">
              <form method="post" action="/orders/bulk-status" class="row" style="gap:6px">
                <input type="hidden" name="ids" value="<%= o.id %>">
                <button class="btn" name="status" value="pending"   title="قيد الإدخال"><i class="fa fa-hourglass-start"></i></button>
                <button class="btn" name="status" value="processing" title="قيد المعالجة"><i class="fa fa-gears"></i></button>
                <button class="btn" name="status" value="shipping"   title="قيد التوصيل"><i class="fa fa-truck"></i></button>
                <button class="btn save" name="status" value="delivered" title="تم التسليم"><i class="fa fa-check"></i></button>
                <button class="btn danger" name="status" value="failed" title="فشل/لم يتم"><i class="fa fa-xmark"></i></button>
              </form>
              <form method="post" action="/orders/bulk-delete" onsubmit="return confirm('حذف الطلب؟')" class="row">
                <input type="hidden" name="ids" value="<%= o.id %>">
                <button class="btn danger" title="حذف"><i class="fa fa-trash"></i></button>
              </form>
            </div>

            <a class="btn secondary" href="/orders/<%= o.id %>"><i class="fa fa-folder-open"></i> فتح الطلب</a>

            <div class="row muted-sm" style="gap:12px">
              <span>بنود: <b><%= totalQty %></b></span>
              <span>الإيراد: <b>₪<%= revenue.toFixed(2) %></b></span>
              <span>الربح: <b>₪<%= profit.toFixed(2) %></b></span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </form>

  <% if (!(orders||[]).length) { %>
    <div class="card"><div class="muted">لا يوجد طلبات.</div></div>
  <% } %>
</div>

<script>
  // تحديد الكل + عدّاد
  (function(){
    const all = document.getElementById('selectAll');
    const rows = [...document.querySelectorAll('.rowCheck')];
    const cnt  = document.getElementById('selCount');
    function refresh(){ cnt.textContent = rows.filter(r=>r.checked).length; }
    if (all) all.addEventListener('change', ()=>{ rows.forEach(r=>r.checked=all.checked); refresh(); });
    rows.forEach(r=> r.addEventListener('change', refresh));
    refresh();
  })();
</script>
