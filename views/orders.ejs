<!-- views/orders-view.ejs -->
<link rel="stylesheet" href="<%= faLink %>">

<div class="container page">

  <!-- رأس الطلب + أزرار سريعة للحالة -->
  <div class="card">
    <div class="row" style="justify-content:space-between;align-items:center">
      <div class="row">
        <h2 style="margin:0"><i class="fa fa-receipt"></i> طلب #<%= order.id %></h2>
        <div class="muted-sm">
          <i class="fa fa-clock"></i>
          <%= dayjs(order.created_at).tz('Asia/Hebron').format('YYYY-MM-DD HH:mm') %>
        </div>
      </div>
      <a class="btn secondary" href="/orders"><i class="fa fa-list"></i> كل الطلبات</a>
    </div>

    <div class="row" style="margin-top:10px;gap:16px">
      <div><b>الزبون:</b> <%= order.customer_name||'—' %></div>
      <div><b>الهاتف:</b> <%= order.customer_phone||'—' %></div>
      <div><b>المدينة:</b> <%= order.customer_city||'—' %></div>
    </div>

    <div style="margin-top:10px">
      <span class="status-chip status-<%= order.status %>">
        <% if(order.status==='pending'){ %><i class="fa fa-hourglass-half"></i> قيد المعالجة
        <% } else if(order.status==='processing'){ %><i class="fa fa-spinner"></i> معالجة
        <% } else if(order.status==='shipping'){ %><i class="fa fa-truck"></i> قيد التوصيل
        <% } else if(order.status==='delivered'){ %><i class="fa fa-check"></i> تم التسليم
        <% } else { %><i class="fa fa-xmark"></i> لم يتم / فشل <% } %>
      </span>
    </div>

    <!-- شريط أزرار الحالة أسفل العنوان مباشرة -->
    <form class="row" method="post" action="/orders/<%= order.id %>/status" style="margin-top:10px">
      <input type="hidden" name="apply_to_items" value="on">
      <input type="hidden" name="status" value="">
      <div class="row">
        <button type="button" class="btn edit status-action" data-val="pending"   title="قيد المعالجة">⏳</button>
        <button type="button" class="btn add  status-action" data-val="shipping"  title="قيد التوصيل">🚚</button>
        <button type="button" class="btn save status-action" data-val="delivered" title="تم التسليم">✔</button>
        <button type="button" class="btn danger status-action" data-val="failed"    title="لم يتم / فشل">✖</button>
        <button type="submit" class="btn secondary" onclick="this.form.status.value=this.form.status.value||'<%= order.status %>'">
          <i class="fa fa-rotate"></i> تحديث الحالة
        </button>
      </div>
    </form>

    <% if (order.note) { %>
      <div class="muted-sm" style="margin-top:8px"><b>ملاحظة:</b> <%= order.note %></div>
    <% } %>

    <div class="row" style="margin-top:8px">
      <b>الإيراد:</b> ₪<%= Number(revenue||0).toFixed(2) %>
      <b style="margin-inline-start:16px">الربح:</b> ₪<%= Number(profit||0).toFixed(2) %>
    </div>
  </div>

  <!-- البنود -->
  <div class="card">
    <div class="row" style="justify-content:space-between;align-items:center">
      <h3 style="margin:0"><i class="fa fa-list-check"></i> بنود الطلب</h3>
      <button class="btn add" type="button" id="addRow"><i class="fa fa-plus"></i> إضافة بند</button>
    </div>

    <form method="post" action="/orders/<%= order.id %>/items/bulk-update" style="margin-top:10px">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>المنتج</th>
              <th>كمية</th>
              <th>سعر بيع (₪)</th>
              <th>سعر أصلي (₪)</th>
              <th>شحن (₪)</th>
              <th>ملاحظة</th>
              <th>حالة البند</th>
              <th>حذف</th>
            </tr>
          </thead>
          <tbody id="itemsBody">
          <% items.forEach(it=>{ %>
            <tr>
              <td style="text-align:right">
                <div class="row">
                  <img class="thumb" style="width:60px;height:60px" src="<%= it.product_image||'' %>">
                  <select name="product_id">
                    <% products.forEach(p=>{ %>
                      <option value="<%= p.id %>" <%= p.id===it.product_id?'selected':'' %>><%= p.name %></option>
                    <% }) %>
                  </select>
                  <input type="hidden" name="item_id" value="<%= it.id %>">
                </div>
              </td>
              <td><input type="number" name="quantity" value="<%= it.quantity %>" min="1" step="1" required></td>
              <td><input type="number" name="sale_price" value="<%= it.sale_price %>" step="0.01" required></td>
              <td><input type="number" name="cost_price" value="<%= it.cost_price %>" step="0.01" required></td>
              <td><input type="number" name="shipping_cost" value="<%= it.shipping_cost||0 %>" step="0.01"></td>
              <td><input type="text" name="item_note" value="<%= it.note||'' %>"></td>
              <td>
                <span class="status-chip status-<%= it.delivery_status %>">
                  <% if(it.delivery_status==='pending'){ %><i class="fa fa-hourglass-half"></i> قيد المعالجة
                  <% } else if(it.delivery_status==='shipping'){ %><i class="fa fa-truck"></i> قيد التوصيل
                  <% } else if(it.delivery_status==='delivered'){ %><i class="fa fa-check"></i> تم التسليم
                  <% } else { %><i class="fa fa-xmark"></i> لم يتم / فشل <% } %>
                </span>
              </td>
              <td><input type="checkbox" name="delete_flag"></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>

      <div class="row" style="margin-top:10px;justify-content:flex-end">
        <button class="btn save" type="submit"><i class="fa fa-floppy-disk"></i> حفظ التعديلات</button>
      </div>
    </form>
  </div>
</div>

<script>
  // إضافة صف جديد
  (function(){
    const products = <%- JSON.stringify(products||[]) %>;
    const body = document.getElementById('itemsBody');
    const add  = document.getElementById('addRow');

    function makeRow(){
      const opts = products.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
      return `
        <tr>
          <td style="text-align:right">
            <div class="row">
              <img class="thumb" style="width:60px;height:60px" src="">
              <select name="product_id">${opts}</select>
              <input type="hidden" name="item_id" value="">
            </div>
          </td>
          <td><input type="number" name="quantity" value="1" min="1" step="1" required></td>
          <td><input type="number" name="sale_price" step="0.01" required></td>
          <td><input type="number" name="cost_price" step="0.01" required></td>
          <td><input type="number" name="shipping_cost" value="0" step="0.01"></td>
          <td><input type="text" name="item_note"></td>
          <td>
            <span class="status-chip status-pending"><i class="fa fa-hourglass-half"></i> قيد المعالجة</span>
          </td>
          <td><input type="checkbox" name="delete_flag"></td>
        </tr>
      `;
    }
    add.addEventListener('click', ()=> body.insertAdjacentHTML('beforeend', makeRow()));
  })();

  // أزرار تغيير حالة الطلب السريعة
  document.querySelectorAll('.status-action').forEach(b=>{
    b.addEventListener('click', ()=>{
      const form = b.closest('form');
      form.querySelector('[name="status"]').value = b.dataset.val;
    });
  });
</script>
