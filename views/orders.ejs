<link rel="stylesheet" href="<%= faLink %>">

<div class="row" style="gap:8px;margin-bottom:10px">
  <a class="btn add" href="/orders/new"><i class="fa fa-plus"></i> طلب جديد</a>
  <a class="btn save" href="/sales"><i class="fa fa-cart-shopping"></i> المبيعات</a>
</div>

<div class="card">
  <h3><i class="fa fa-list-check"></i> الطلبات</h3>

  <table>
    <thead>
      <tr>
        <th>#</th><th>الزبون</th><th>الهاتف</th><th>المدينة</th><th>عدد الأصناف</th>
        <th>الإيراد (₪)</th><th>الربح (₪)</th><th>الحالة</th><th>التاريخ</th><th>عرض</th>
      </tr>
    </thead>
    <tbody>
      <% (orders||[]).forEach(o=>{ %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.customer_name || '—' %></td>
          <td><%= o.customer_phone || '—' %></td>
          <td><%= o.customer_city || '—' %></td>
          <td><%= o.items_count %></td>
          <td>₪<%= Number(o.revenue||0).toFixed(2) %></td>
          <td>₪<%= Number(o.profit||0).toFixed(2) %></td>
          <td><%= o.status==='pending'?'قيد المعالجة':o.status==='shipping'?'قيد التوصيل':o.status==='delivered'?'تم التسليم':'فشل/لم يتم' %></td>
          <td>
            <%= (dayjs && dayjs.tz) ? dayjs(o.created_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A')
                                     : (new Date(o.created_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %>
          </td>
          <td><a class="btn secondary" href="/orders/<%= o.id %>"><i class="fa fa-eye"></i> عرض</a></td>
        </tr>
      <% }) %>
      <% if (!(orders||[]).length){ %><tr><td colspan="10" class="muted">لا توجد طلبات.</td></tr><% } %>
    </tbody>
  </table>
</div>
