<%-
/**
 * orders.ejs — قائمة الطلبات
 * يعتمد على متغيرات:
 *  - orders: [{id, customer_name, customer_phone, customer_city, status, created_at, items_count, revenue, profit}]
 *  - dayjs
 *  - faLink متوفر من السيرفر
 */
-%>
<link rel="stylesheet" href="<%= faLink %>">

<style>
  .card{background:#fff;border:1px solid #eef2f7;border-radius:14px;padding:16px;margin:14px 0}
  .orders-table{width:100%;border:1px solid #eef2f7;border-radius:12px;overflow:hidden}
  .orders-table th{background:#feeef5;padding:10px;text-align:center}
  .orders-table td{border-top:1px solid #f1f5f9;padding:10px;text-align:center;vertical-align:middle}
  .status{display:inline-flex;gap:6px;align-items:center;border:1px solid #ebedf0;border-radius:999px;padding:6px 10px;font-weight:700}
  .status.pending{background:#fff7fb}
  .status.shipping{background:#eef7ff}
  .status.delivered{background:#efffed}
  .status.failed{background:#fff0f0}
  .btn{display:inline-flex;gap:6px;align-items:center;border:0;border-radius:10px;padding:8px 12px;cursor:pointer}
  .btn.add{background:#2563eb;color:#fff}
  .btn.secondary{background:#f1f5f9;color:#111}
  .btn.danger{background:#ef4444;color:#fff}
  .row{display:flex;gap:8px;align-items:center}
  .right{margin-inline-start:auto}
  .muted{color:#7a8da1}
</style>

<div class="row" style="justify-content:space-between;align-items:center">
  <h2 style="margin:0"><i class="fa fa-basket-shopping"></i> الطلبات</h2>
  <div class="row">
    <a class="btn add" href="/orders/new"><i class="fa fa-plus"></i> طلب جديد</a>
  </div>
</div>

<div class="card">
  <table class="orders-table">
    <thead>
      <tr>
        <th>#</th>
        <th>الزبون</th>
        <th>الهاتف</th>
        <th>المدينة</th>
        <th>الحالة</th>
        <th>عدد الأصناف</th>
        <th>الإيراد (₪)</th>
        <th>الربح (₪)</th>
        <th>التاريخ</th>
        <th>إجراء</th>
      </tr>
    </thead>
    <tbody>
      <% if (!orders.length){ %>
        <tr><td colspan="10" class="muted">لا توجد طلبات بعد.</td></tr>
      <% } %>
      <% orders.forEach(o=>{ %>
        <tr>
          <td>#<%= o.id %></td>
          <td style="text-align:right"><%= o.customer_name||'—' %></td>
          <td><%= o.customer_phone||'—' %></td>
          <td><%= o.customer_city||'—' %></td>
          <td>
            <span class="status <%= o.status %>">
              <i class="fa <%= o.status==='pending'?'fa-hourglass-half':o.status==='shipping'?'fa-truck':o.status==='delivered'?'fa-check':'fa-xmark' %>"></i>
              <%= o.status==='pending'?'قيد المعالجة':o.status==='shipping'?'قيد التوصيل':o.status==='delivered'?'تم التسليم':'فشل/لم يتم' %>
            </span>
          </td>
          <td><%= o.items_count||0 %></td>
          <td>₪<%= Number(o.revenue||0).toFixed(2) %></td>
          <td>₪<%= Number(o.profit||0).toFixed(2) %></td>
          <td>
            <%= (dayjs && dayjs.tz)
                ? dayjs(o.created_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A')
                : (new Date(o.created_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %>
          </td>
          <td>
            <a class="btn secondary" href="/orders/<%= o.id %>"><i class="fa fa-eye"></i> عرض</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>