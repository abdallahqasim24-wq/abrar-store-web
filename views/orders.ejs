<link rel="stylesheet" href="<%= faLink %>">

<style>
  .orders-wrap{display:grid;grid-template-columns:1fr;gap:14px}
  .ocard{background:#fff;border:1px solid #f7cfe1;border-radius:16px;padding:14px;box-shadow:0 12px 30px rgba(255,126,179,.08)}
  .head{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .id{font-weight:900}
  .muted{color:#6b7280}
  .right{margin-inline-start:auto}

  /* حالة */
  .chip{display:inline-flex;align-items:center;gap:6px;border:1px solid #f7cfe1;border-radius:999px;padding:6px 10px;font-weight:800}
  .pending{background:#fff7e6}
  .shipping{background:#eef7ff}
  .delivered{background:#e6ffed}
  .failed{background:#ffe6e6}

  /* أزرار الحالة السريعة */
  .quick{display:flex;gap:10px;align-items:center;margin-top:10px}
  .qbtn{
    display:inline-flex;align-items:center;justify-content:center;
    width:44px;height:44px;border-radius:14px;border:0;cursor:pointer;
    box-shadow:0 2px 0 rgba(0,0,0,.06)
  }
  .q-pending   {background:#f59e0b;color:#111}
  .q-shipping  {background:#2563eb;color:#fff}
  .q-delivered {background:#16a34a;color:#fff}
  .q-failed    {background:#ef4444;color:#fff}
  .q-reset     {background:#ef4444;color:#fff}

  .nums{display:flex;gap:18px;flex-wrap:wrap}
  .nums b{font-size:16px}
  .open{background:#475569;color:#fff;border:0;border-radius:12px;padding:8px 12px;display:inline-flex;align-items:center;gap:8px}
</style>

<div class="head" style="margin-bottom:10px">
  <h2 style="margin:0"><i class="fa fa-list"></i> كل الطلبات</h2>
  <span class="muted">(<%= (orders||[]).length %>)</span>
</div>

<div class="orders-wrap">
  <% if (!orders || !orders.length) { %>
    <div class="muted">لا توجد طلبات بعد.</div>
  <% } else { orders.forEach(o => { %>
    <div class="ocard">
      <div class="head">
        <div class="id">#<%= o.id %></div>
        <div class="muted">
          <i class="fa fa-clock"></i>
          <%= dayjs(o.created_at).tz('Asia/Hebron').format('YYYY-MM-DD HH:mm') %>
        </div>

        <div class="right chip <%= o.status %>">
          <% if (o.status==='pending'){ %><i class="fa fa-hourglass-half"></i><span>قيد المعالجة</span><% } %>
          <% if (o.status==='shipping'){ %><i class="fa fa-truck"></i><span>قيد التوصيل</span><% } %>
          <% if (o.status==='delivered'){ %><i class="fa fa-check"></i><span>تم التسليم</span><% } %>
          <% if (o.status==='failed'){ %><i class="fa fa-xmark"></i><span>فشل/لم يتم</span><% } %>
        </div>
      </div>

      <div class="nums" style="margin-top:8px">
        <div><b><i class="fa fa-user"></i></b> <%= o.customer_name || 'بدون اسم' %></div>
        <div class="muted"><b><i class="fa fa-phone"></i></b> <%= o.customer_phone || '—' %></div>
        <div class="muted"><b><i class="fa fa-location-dot"></i></b> <%= o.customer_city || '—' %></div>
        <div class="muted"><b><i class="fa fa-boxes-stacked"></i></b> <%= o.items_count %> بند</div>
        <div class="muted"><b>الإيراد:</b> ₪<%= Number(o.revenue||0).toFixed(2) %></div>
        <div class="muted"><b>الربح:</b> ₪<%= Number(o.profit||0).toFixed(2) %></div>
        <a class="open" href="/orders/<%= o.id %>"><i class="fa fa-folder-open"></i> فتح الطلب</a>
      </div>

      <!-- أزرار الحالة السريعة -->
      <div class="quick">
        <form method="post" action="/orders/<%= o.id %>/status">
          <input type="hidden" name="status" value="pending">
          <button class="qbtn q-pending" title="قيد المعالجة"><i class="fa fa-hourglass-half"></i></button>
        </form>
        <form method="post" action="/orders/<%= o.id %>/status">
          <input type="hidden" name="status" value="shipping">
          <button class="qbtn q-shipping" title="قيد التوصيل"><i class="fa fa-truck"></i></button>
        </form>
        <form method="post" action="/orders/<%= o.id %>/status">
          <input type="hidden" name="status" value="delivered">
          <button class="qbtn q-delivered" title="تم التسليم"><i class="fa fa-check"></i></button>
        </form>
        <form method="post" action="/orders/<%= o.id %>/status">
          <input type="hidden" name="status" value="failed">
          <button class="qbtn q-failed" title="فشل/لم يتم"><i class="fa fa-xmark"></i></button>
        </form>
      </div>
    </div>
  <% }) } %>
</div>
