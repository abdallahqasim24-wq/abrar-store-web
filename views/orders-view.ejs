<!-- views/orders-view.ejs (FINAL)
     - تعديل بيانات الطلب (الاسم/الهاتف/العنوان/رقم الطلب/الملاحظات)
     - تغيير رقم الطلب ينقل البنود تلقائياً (إن لم يكن الرقم مستخدماً)
     - حذف البنود يعمل بصندوق اختيار delete_ids[]
     - إرجاع البنود المحددة (يرسِل إلى /orders/:id/items/bulk-return)
     - إضافة بند عبر شبكة المنتجات + تعبئة سعر البيع/الكلفة تلقائياً
-->
<%
  const o   = typeof order === 'object' && order ? order : {};
  const its = Array.isArray(items) ? items : [];
  const tz  = (typeof TZ_NAME!=='undefined' && TZ_NAME) ? TZ_NAME : 'Asia/Hebron';

  function statusLabel(s){
    switch(String(s||'').toLowerCase()){
      case 'pending':    return 'قيد الإدخال';
      case 'processing': return 'قيد المعالجة';
      case 'shipping':   return 'قيد التوصيل';
      case 'delivered':  return 'تم التسليم';
      case 'failed':     return 'فشل/لم يتم';
      default:           return 'غير محدد';
    }
  }
%>

<div class="container page" style="max-width:1200px">
  <!-- شريط علوي -->
  <div class="row" style="justify-content:space-between;align-items:flex-end;margin-bottom:10px">
    <div class="row" style="gap:10px;align-items:center">
      <h2 style="margin:0">
        <i class="fa fa-receipt"></i>
        الطلب <span class="muted">#<%= o.id %></span>
      </h2>
      <span class="status-chip status-<%= o.status %>">
        <i class="fa fa-circle"></i> <%= statusLabel(o.status) %>
      </span>
      <span class="badge">
        <i class="fa fa-clock"></i>
        <%= dayjs(o.created_at).tz(tz).format('YYYY-MM-DD HH:mm') %>
      </span>
    </div>

    <div class="row">
      <a class="btn gray" href="/orders"><i class="fa fa-arrow-right"></i> رجوع</a>
      <form method="post" action="/orders/<%= o.id %>/delete" onsubmit="return confirm('حذف الطلب وبنوده؟')">
        <button class="btn danger" type="submit"><i class="fa fa-trash"></i> حذف الطلب</button>
      </form>
    </div>
  </div>

  <!-- تعديل بيانات الطلب -->
  <div class="card" style="margin-bottom:14px">
    <h3 style="margin-top:0"><i class="fa fa-user-pen"></i> تعديل بيانات الطلب</h3>
    <form class="form-grid" method="post" action="/orders/<%= o.id %>/update">
      <div>
        <label>رقم الطلب</label>
        <input name="order_id" type="number" min="1" value="<%= o.id %>">
        <div class="muted-sm">تغيير الرقم سينقل كل البنود للرقم الجديد.</div>
      </div>
      <div>
        <label>اسم الزبون</label>
        <input name="customer_name" value="<%- o.customer_name||'' %>">
      </div>
      <div>
        <label>الهاتف</label>
        <input name="customer_phone" value="<%- o.customer_phone||'' %>">
      </div>
      <div>
        <label>المدينة / العنوان</label>
        <input name="customer_city" value="<%- o.customer_city||'' %>">
      </div>
      <div style="grid-column:1 / -1">
        <label>ملاحظات</label>
        <input name="note" value="<%- o.note||'' %>">
      </div>
      <div class="right" style="align-self:end">
        <button class="btn success" type="submit"><i class="fa fa-floppy-disk"></i> حفظ بيانات الطلب</button>
      </div>
    </form>
    <div id="orderIdErr" class="muted-sm" style="display:none;color:#b91c1c;margin-top:8px">
      رقم الطلب المطلوب موجود مسبقًا. اختر رقمًا آخر.
    </div>
  </div>

  <!-- تغيـير حالة الطلب (تطبق على البنود أيضاً) -->
  <div class="card" style="margin-bottom:14px">
    <form class="row" method="post" action="/orders/<%= o.id %>/status" style="gap:8px;align-items:center">
      <input type="hidden" name="apply_to_items" value="on">
      <span class="muted">تغيير الحالة:</span>
      <button name="status" value="pending"    class="btn warn"    type="submit"><i class="fa fa-hourglass-start"></i> إلى قيد الإدخال</button>
      <button name="status" value="processing" class="btn info"    type="submit"><i class="fa fa-gears"></i> إلى قيد المعالجة</button>
      <button name="status" value="shipping"   class="btn gray"    type="submit"><i class="fa fa-truck"></i> إلى قيد التوصيل</button>
      <button name="status" value="delivered"  class="btn success" type="submit"><i class="fa fa-check"></i> تم التسليم</button>
      <button name="status" value="failed"     class="btn danger"  type="submit"><i class="fa fa-xmark"></i> فشل التسليم</button>
      <span class="right muted-sm">* سيتم تطبيق الحالة على البنود أيضاً</span>
    </form>
  </div>

  <!-- ملخص -->
  <%
    const totalQty = its.reduce((a,x)=>a + Number(x.quantity||0), 0);
    const revenue  = its.reduce((a,x)=>a + Number(x.sale_price||0) * Number(x.quantity||0), 0);
    const profit   = its.reduce((a,x)=>a + (Number(x.sale_price||0)*Number(x.quantity||0) - Number(x.cost_price||0)*Number(x.quantity||0)), 0);
  %>
  <div class="card" style="margin-bottom:14px">
    <div class="order-kpis">
      <span><i class="fa fa-box"></i> <strong><%= totalQty %></strong> عناصر</span>
      <span><i class="fa fa-coins"></i> <strong><%= revenue.toFixed(2) %></strong></span>
      <span><i class="fa fa-sack-dollar"></i> <strong><%= profit.toFixed(2) %></strong></span>
    </div>
  </div>

  <!-- البنود (تحديث + حذف + إرجاع) -->
  <div class="card" style="margin-bottom:14px">
    <h3>بنود الطلب</h3>

    <!-- ملاحظة صغيرة: نفس مربعات الاختيار تُستخدم للحذف أو الإرجاع -->
    <div class="muted-sm" style="margin:6px 0">اختر البنود ثم اضغط <strong>إرجاع البنود المحددة</strong> أو <strong>حفظ التعديلات / حذف المحدد</strong>.</div>

    <form id="editItemsForm" method="post" action="/orders/<%= o.id %>/items/bulk-update">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>المنتج</th>
              <th>الكمية</th>
              <th>سعر البيع</th>
              <th>سعر الكلفة</th>
              <th>شحن</th>
              <th>ملاحظة</th>
              <th>حالة التوصيل</th>
              <th>تحديد</th>
            </tr>
          </thead>
          <tbody>
            <% its.forEach((s)=>{ %>
              <tr>
                <td>
                  <%= s.id %>
                  <input type="hidden" name="item_id[]" value="<%= s.id %>">
                </td>
                <td>
                  <select name="product_id[]" required>
                    <% products.forEach(p=>{ %>
                      <option value="<%= p.id %>" data-sale="<%= Number(p.sale_price||0).toFixed(2) %>" data-cost="<%= Number(p.cost_price||0).toFixed(2) %>" <%= p.id===s.product_id?'selected':'' %>><%= p.name %></option>
                    <% }) %>
                  </select>
                </td>
                <td><input type="number" name="quantity[]" step="1" min="1" value="<%= s.quantity %>"></td>
                <td><input type="number" name="sale_price[]" step="0.01" value="<%= Number(s.sale_price||0).toFixed(2) %>"></td>
                <td><input type="number" name="cost_price[]" step="0.01" value="<%= Number(s.cost_price||0).toFixed(2) %>"></td>
                <td><input type="number" name="shipping_cost[]" step="0.01" value="<%= Number(s.shipping_cost||0).toFixed(2) %>"></td>
                <td><input type="text" name="item_note[]" value="<%- s.note||'' %>"></td>
                <td>
                  <span class="status-chip status-<%= s.delivery_status %>"><%= statusLabel(s.delivery_status) %></span>
                </td>
                <td style="text-align:center">
                  <input type="checkbox" name="delete_ids[]" value="<%= s.id %>">
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="row" style="margin-top:10px; gap:8px">
        <button class="btn info" type="submit"
                formaction="/orders/<%= o.id %>/items/bulk-return"
                formmethod="post"
                onclick="return confirm('إرجاع البنود المحددة إلى قائمة المرتجعات؟ سيتم حذفها من الطلب.');">
          <i class="fa fa-rotate-left"></i> إرجاع البنود المحددة
        </button>

        <button class="btn success" type="submit"><i class="fa fa-floppy-disk"></i> حفظ التعديلات / حذف المحدد</button>
      </div>
    </form>
  </div>

  <!-- إضافة بند -->
  <div class="card">
    <h3>إضافة بند</h3>
    <form id="addForm" class="form-grid" method="post" action="/orders/<%= o.id %>/items">
      <div>
        <label>المنتج</label>
        <div class="row" style="gap:8px">
          <select id="addProduct" name="product_id" required style="min-width:220px">
            <% products.forEach(p=>{ %>
              <option value="<%= p.id %>"
                      data-sale="<%= Number(p.sale_price||0).toFixed(2) %>"
                      data-cost="<%= Number(p.cost_price||0).toFixed(2) %>"><%= p.name %></option>
            <% }) %>
          </select>
          <button id="openPicker" class="btn info" type="button"><i class="fa fa-grid-2"></i> اختر من الشبكة</button>
        </div>
      </div>

      <div>
        <label>الكمية</label>
        <input id="addQty" type="number" name="quantity" min="1" step="1" value="1">
      </div>
      <div>
        <label>سعر البيع</label>
        <input id="addSale" type="number" name="sale_price" step="0.01">
      </div>
      <div>
        <label>سعر الكلفة</label>
        <input id="addCost" type="number" name="cost_price" step="0.01">
      </div>
      <div>
        <label>كلفة الشحن</label>
        <input id="addShip" type="number" name="shipping_cost" step="0.01" value="0">
      </div>
      <div>
        <label>ملاحظة</label>
        <input id="addNote" type="text" name="note">
      </div>
      <div class="right" style="align-self:end">
        <button class="btn add" type="submit"><i class="fa fa-plus"></i> إضافة</button>
      </div>
    </form>
  </div>
</div>

<!-- مودال شبكة المنتجات -->
<div id="pickModal" class="modal">
  <div class="modal-bg" id="pickClose"></div>
  <div class="modal-card">
    <button id="pickX" class="mclose" type="button"><i class="fa fa-xmark"></i></button>
    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <strong>اختر منتجًا</strong>
      <input id="pickSearch" type="search" placeholder="بحث اسم/ماركة/صنف…" class="right" style="max-width:360px">
    </div>
    <div id="pickGrid" class="mgrid">
      <% products.forEach(p=>{ %>
        <button class="pcard" type="button"
                data-id="<%= p.id %>"
                data-name="<%- (p.name||'').toLowerCase() %>"
                data-sale="<%= Number(p.sale_price||0).toFixed(2) %>"
                data-cost="<%= Number(p.cost_price||0).toFixed(2) %>">
          <img src="<%= p.image_path || '/public/placeholder.png' %>" alt="">
          <div class="name"><%= p.name %></div>
          <div style="text-align:center" class="muted-sm">
            بيع: <strong><%= Number(p.sale_price||0).toFixed(2) %></strong> •
            كلفة: <strong><%= Number(p.cost_price||0).toFixed(2) %></strong>
          </div>
        </button>
      <% }) %>
    </div>
  </div>
</div>

<script>
(function(){
  // عرض خطأ عند محاولة تغيير رقم الطلب لرقم موجود
  (function(){
    const params=new URLSearchParams(location.search||'');
    if(params.get('err')==='exists'){
      const el=document.getElementById('orderIdErr'); if(el) el.style.display='block';
    }
  })();

  // ===== تعبئة تلقائية لأسعار الإضافة =====
  const addProduct = document.getElementById('addProduct');
  const addSale = document.getElementById('addSale');
  const addCost = document.getElementById('addCost');

  function fillAddPricesFromSelect(){
    const opt = addProduct.options[addProduct.selectedIndex];
    if(!opt) return;
    addSale.value = opt.dataset.sale || '';
    addCost.value = opt.dataset.cost || '';
  }
  addProduct.addEventListener('change', fillAddPricesFromSelect);
  fillAddPricesFromSelect();

  // ===== مودال شبكة المنتجات =====
  const modal = document.getElementById('pickModal');
  const pickSearch = document.getElementById('pickSearch');
  const pickGrid = document.getElementById('pickGrid');
  const openBtn = document.getElementById('openPicker');
  const closeEls = [document.getElementById('pickClose'), document.getElementById('pickX')];

  function openModal(){ modal.style.display='block'; pickSearch.focus(); }
  function closeModal(){ modal.style.display='none'; }
  openBtn.addEventListener('click', openModal);
  closeEls.forEach(el=>el.addEventListener('click', closeModal));
  window.addEventListener('keydown',e=>{ if(e.key==='Escape') closeModal(); });

  // اختيار بطاقة منتج
  pickGrid.addEventListener('click', (e)=>{
    const card = e.target.closest('.pcard'); if(!card) return;
    const id = card.dataset.id;
    addProduct.value = id;
    fillAddPricesFromSelect();
    closeModal();
  });

  // بحث داخل الشبكة
  pickSearch.addEventListener('input', ()=>{
    const q=(pickSearch.value||'').trim().toLowerCase();
    Array.from(pickGrid.children).forEach(btn=>{
      const ok = !q || (btn.dataset.name||'').includes(q);
      btn.style.display = ok ? '' : 'none';
    });
  });
})();
</script>
