<link rel="stylesheet" href="<%= faLink %>">

<div class="card">
  <h3><i class="fa fa-bag-shopping"></i> طلب #<%= order.id %></h3>

  <form method="post" action="/orders/<%= order.id %>/status" class="row" style="gap:8px">
    <select name="status">
      <option value="pending"  <%= order.status==='pending'?'selected':'' %> >قيد المعالجة</option>
      <option value="shipping" <%= order.status==='shipping'?'selected':'' %> >قيد التوصيل</option>
      <option value="delivered"<%= order.status==='delivered'?'selected':''%> >تم التسليم</option>
      <option value="failed"   <%= order.status==='failed'?'selected':''   %> >فشل/لم يتم</option>
    </select>
    <label class="row" style="gap:6px"><input type="checkbox" name="apply_to_items"> تطبيق على كل البنود</label>
    <button class="btn save" type="submit">تحديث الحالة</button>
    <div class="right" style="flex:1"><a class="btn secondary" href="/orders"><i class="fa fa-list-check"></i> جميع الطلبات</a></div>
  </form>

  <div class="row" style="gap:16px;margin-top:12px">
    <div class="tag">الزبون: <b><%= order.customer_name||'—' %></b></div>
    <div class="tag">الهاتف: <b><%= order.customer_phone||'—' %></b></div>
    <div class="tag">المدينة: <b><%= order.customer_city||'—' %></b></div>
    <div class="tag">الإيراد: <b>₪<%= Number(revenue||0).toFixed(2) %></b></div>
    <div class="tag">الربح: <b>₪<%= Number(profit||0).toFixed(2) %></b></div>
  </div>
</div>

<div class="card">
  <h3><i class="fa fa-clipboard-list"></i> بنود الطلب</h3>

  <form method="post" action="/orders/<%= order.id %>/items/bulk-update">
    <table class="items-grid">
      <thead><tr><th>#</th><th>المنتج</th><th>كمية</th><th>سعر بيع</th><th>سعر أصلي</th><th>شحن</th><th>ملاحظة</th><th>حذف</th></tr></thead>
      <tbody>
        <% items.forEach(s=>{ %>
          <tr>
            <td><input type="hidden" name="item_id" value="<%= s.id %>">#<%= s.id %></td>
            <td style="text-align:right">
              <select name="product_id">
                <% items.length; %>
                <% /* بإمكانك تمرير قائمة products إن رغبت لاحقًا */ %>
                <option value="<%= s.product_id %>" selected><%= s.product_name %></option>
              </select>
            </td>
            <td><input type="number" name="quantity" step="1" min="1" value="<%= s.quantity %>"></td>
            <td><input type="number" name="sale_price" step="0.01" value="<%= s.sale_price %>"></td>
            <td><input type="number" name="cost_price" step="0.01" value="<%= s.cost_price %>"></td>
            <td><input type="number" name="shipping_cost" step="0.01" value="<%= s.shipping_cost||0 %>"></td>
            <td><input type="text" name="item_note" value="<%= s.note||'' %>"></td>
            <td style="text-align:center"><input type="checkbox" name="delete_flag"></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="right" style="margin-top:10px">
      <button class="btn save" type="submit"><i class="fa fa-floppy-disk"></i> حفظ التعديلات</button>
    </div>
  </form>

  <form method="post" action="/orders/<%= order.id %>/items" style="margin-top:16px">
    <h4>إضافة بند جديد</h4>
    <div class="row" style="gap:8px;align-items:center">
      <input type="number" name="product_id" placeholder="ID المنتج" required style="width:140px">
      <input type="number" name="quantity" step="1" min="1" value="1">
      <input type="number" name="sale_price" step="0.01" placeholder="سعر بيع">
      <input type="number" name="cost_price" step="0.01" placeholder="سعر أصلي">
      <input type="number" name="shipping_cost" step="0.01" value="0">
      <input type="text" name="note" placeholder="ملاحظة">
      <button class="btn add" type="submit"><i class="fa fa-plus"></i> إضافة</button>
    </div>
  </form>
</div>
