<%-
/**
 * orders-view.ejs — صفحة تفاصيل طلب
 * يعتمد على:
 *  - order: {id, customer_name, customer_phone, customer_city, note, status, created_at}
 *  - items: [{id,product_id,product_name,product_image,quantity,sale_price,cost_price,shipping_cost,note}]
 *  - products: [{id,name,stock,sale_price,cost_price,image_path}]
 *  - revenue, profit, dayjs
 */
-%>
<link rel="stylesheet" href="<%= faLink %>">

<style>
  .wrap{padding:14px}
  .card{background:#fff;border:1px solid #eef2f7;border-radius:14px;padding:16px;margin:14px 0}
  .row{display:flex;gap:10px;align-items:center}
  .grow{flex:1}
  .muted{color:#6b7280}
  .nowrap{white-space:nowrap}

  .pill{
    display:inline-flex;align-items:center;gap:8px;
    border:0;border-radius:16px;padding:10px 14px;font-weight:700;color:#fff;cursor:pointer
  }
  .pill.red{background:#ef4444}
  .pill.green{background:#16a34a}
  .pill.blue{background:#2563eb}
  .pill.orange{background:#f59e0b;color:#111}
  .pill.gray{background:#64748b}
  .pill:disabled{opacity:.6;cursor:not-allowed}

  .status{display:inline-flex;gap:6px;align-items:center;border:1px solid #ebedf0;border-radius:999px;padding:6px 10px;font-weight:700}
  .status.pending,.status.processing{background:#fff7eb}
  .status.shipping{background:#eef6ff}
  .status.delivered{background:#edfee8}
  .status.failed{background:#fff1f2}

  .items-grid{width:100%;border:1px solid #eef2f7;border-radius:12px;overflow:hidden}
  .items-grid th{background:#f9fafb;text-align:center;padding:10px}
  .items-grid td{padding:8px;border-top:1px solid #f1f5f9;text-align:center;vertical-align:middle}
  input,select{width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:10px}
  .thumb{width:48px;height:48px;border-radius:10px;border:1px solid #ebedf0;object-fit:cover;background:#fff}
  a.link{color:#2563eb;text-decoration:none}
  a.link:hover{text-decoration:underline}
</style>

<div class="wrap">

  <!-- ===== الهيدر مع كبسات الحالة ===== -->
  <div class="card">
    <div class="row" style="align-items:flex-start">
      <div class="grow">
        <div class="row" style="justify-content:space-between;align-items:center">
          <div class="row">
            <h2 style="margin:0">#<%= order.id %></h2>
            <span class="muted">
              <i class="fa fa-clock"></i>
              <%= (dayjs && dayjs.tz)
                    ? dayjs(order.created_at).tz('Asia/Hebron').format('YYYY-MM-DD HH:mm')
                    : new Date(order.created_at).toLocaleString('en-CA',{hour12:false}) %>
            </span>
            <span class="row muted"><i class="fa fa-user"></i> <%= order.customer_name || 'بدون اسم' %></span>
          </div>

          <span class="status <%= order.status %>">
            <i class="fa <%= order.status==='delivered'?'fa-check':order.status==='shipping'?'fa-truck':order.status==='failed'?'fa-xmark':(order.status==='processing'?'fa-spinner':'fa-hourglass-half') %>"></i>
            <%= order.status==='delivered'?'تم التسليم':order.status==='shipping'?'قيد التوصيل':order.status==='failed'?'فشل/لم يتم':order.status==='processing'?'قيد المعالجة':'pending' %>
          </span>
        </div>

        <div class="row muted" style="margin-top:6px;flex-wrap:wrap">
          <div><b>الهاتف:</b> <%= order.customer_phone || '—' %></div>
          <div><b>المدينة:</b> <%= order.customer_city || '—' %></div>
          <div><b>الإيراد:</b> ₪<%= Number(revenue||0).toFixed(2) %></div>
          <div><b>الربح:</b> ₪<%= Number(profit||0).toFixed(2) %></div>
        </div>

        <% if (order.note) { %>
          <div class="muted" style="margin-top:6px"><b>ملاحظة:</b> <%= order.note %></div>
        <% } %>
      </div>

      <!-- كبسات الحالة في الهيدر -->
      <div class="row" style="flex-wrap:wrap;justify-content:flex-end;min-width:340px">
        <!-- إرجاع كل البنود -->
        <form id="fReturnAll" action="/sales/bulk-return" method="post">
          <input type="hidden" id="idsReturnAll" name="ids">
          <button type="submit" class="pill red" title="إرجاع كل البنود للراجع"><i class="fa fa-rotate-left"></i></button>
        </form>

        <!-- فشل -->
        <form class="fStatus" action="/orders/<%= order.id %>/status" method="post">
          <input type="hidden" name="status" value="failed">
          <input type="hidden" name="apply_to_items" value="on">
          <button class="pill red" title="فشل/لم يتم"><i class="fa fa-xmark"></i></button>
        </form>

        <!-- تم التسليم -->
        <form class="fStatus" action="/orders/<%= order.id %>/status" method="post">
          <input type="hidden" name="status" value="delivered">
          <input type="hidden" name="apply_to_items" value="on">
          <button class="pill green" title="تم التسليم"><i class="fa fa-check"></i></button>
        </form>

        <!-- قيد التوصيل -->
        <form class="fStatus" action="/orders/<%= order.id %>/status" method="post">
          <input type="hidden" name="status" value="shipping">
          <input type="hidden" name="apply_to_items" value="on">
          <button class="pill blue" title="قيد التوصيل"><i class="fa fa-truck"></i></button>
        </form>

        <!-- قيد المعالجة / pending -->
        <form class="fStatus" action="/orders/<%= order.id %>/status" method="post">
          <input type="hidden" name="status" value="processing">
          <input type="hidden" name="apply_to_items" value="on">
          <button class="pill orange" title="قيد المعالجة"><i class="fa fa-spinner"></i></button>
        </form>
      </div>
    </div>

    <!-- سويتش تطبيق الحالة على البنود -->
    <div class="row muted" style="margin-top:10px">
      <label class="row">
        <input type="checkbox" id="applyToItems" checked>
        <span>تطبيق الحالة على كل البنود داخل الطلب</span>
      </label>
      <span class="grow"></span>
      <a class="link" href="/orders"><i class="fa fa-list"></i> كل الطلبات</a>
    </div>
  </div>

  <!-- ===== جدول البنود ===== -->
  <div class="card">
    <form method="post" action="/orders/<%= order.id %>/items/bulk-update">
      <div class="row" style="justify-content:space-between;align-items:center;margin-bottom:8px">
        <h3 style="margin:0"><i class="fa fa-list-check"></i> البنود</h3>
        <button type="button" id="addRow" class="pill gray"><i class="fa fa-plus"></i> إضافة بند</button>
      </div>

      <table class="items-grid">
        <thead>
          <tr>
            <th style="text-align:right">المنتج</th>
            <th>كمية</th>
            <th>سعر بيع (₪)</th>
            <th>سعر أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>حذف</th>
          </tr>
        </thead>
        <tbody id="itemsBody">
          <% items.forEach(it=>{ %>
            <tr>
              <td style="text-align:right">
                <div class="row" style="justify-content:flex-start">
                  <img class="thumb" src="<%= it.product_image||'/public/no-image.png' %>">
                  <select name="product_id">
                    <% products.forEach(p=>{ %>
                      <option value="<%= p.id %>" <%= p.id===it.product_id?'selected':'' %>><%= p.name %></option>
                    <% }) %>
                  </select>
                  <input type="hidden" name="item_id" value="<%= it.id %>">
                </div>
              </td>
              <td><input type="number" name="quantity" value="<%= it.quantity %>" min="1" step="1" required></td>
              <td><input type="number" name="sale_price" value="<%= it.sale_price %>" step="0.01" required></td>
              <td><input type="number" name="cost_price" value="<%= it.cost_price %>" step="0.01" required></td>
              <td><input type="number" name="shipping_cost" value="<%= it.shipping_cost||0 %>" step="0.01"></td>
              <td><input type="text" name="item_note" value="<%= it.note||'' %>"></td>
              <td><input type="checkbox" name="delete_flag"></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="row" style="justify-content:flex-end;margin-top:10px">
        <button class="pill blue" type="submit"><i class="fa fa-floppy-disk"></i> حفظ التعديلات</button>
      </div>
    </form>
  </div>
</div>

<script>
  // توليد صف جديد
  (function(){
    const products = <%- JSON.stringify(products||[]) %>;
    const body = document.getElementById('itemsBody');
    const add  = document.getElementById('addRow');

    function makeRow(){
      const opts = products.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
      return `
        <tr>
          <td style="text-align:right">
            <div class="row" style="justify-content:flex-start">
              <img class="thumb" src="/public/no-image.png">
              <select name="product_id">${opts}</select>
              <input type="hidden" name="item_id" value="">
            </div>
          </td>
          <td><input type="number" name="quantity" value="1" min="1" step="1" required></td>
          <td><input type="number" name="sale_price" step="0.01" required></td>
          <td><input type="number" name="cost_price" step="0.01" required></td>
          <td><input type="number" name="shipping_cost" value="0" step="0.01"></td>
          <td><input type="text" name="item_note"></td>
          <td><input type="checkbox" name="delete_flag"></td>
        </tr>
      `;
    }
    add.addEventListener('click', ()=> body.insertAdjacentHTML('beforeend', makeRow()));
  })();

  // تزامن خيار "تطبيق على البنود" مع جميع فورمات الحالة في الهيدر
  (function syncApply(){
    const apply = document.getElementById('applyToItems');
    const forms = Array.from(document.querySelectorAll('.fStatus'));
    function setVal(){
      forms.forEach(f=>{
        const i = f.querySelector('input[name="apply_to_items"]');
        if(i) i.value = apply.checked ? 'on' : 'off';
      });
    }
    apply.addEventListener('change', setVal);
    setVal();
  })();

  // زر إرجاع كل البنود (يجمع كل IDs البنود ويرسلها إلى /sales/bulk-return)
  (function returnAll(){
    const form = document.getElementById('fReturnAll');
    const input = document.getElementById('idsReturnAll');
    form.addEventListener('submit', (e)=>{
      const ids = Array.from(document.querySelectorAll('input[name="item_id"]'))
                  .map(i=>Number(i.value)).filter(Boolean);
      if(!ids.length || !confirm('إرجاع كل بنود هذا الطلب إلى الراجع؟')) {
        e.preventDefault();
        return;
      }
      input.value = ids.join(',');
    });
  })();
</script>
