<link rel="stylesheet" href="<%= faLink %>">

<style>
  /* شبكة اختيار + عناصر عامة (من نفس ستايل المشروع) */
  .thumb{width:48px;height:48px;border-radius:10px;border:1px solid var(--border);object-fit:cover;background:#fff}
  .mini-tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:999px;background:#fff7fb;font-size:.8rem}
  .items-grid{width:100%;border:1px solid var(--border);border-radius:12px;overflow:hidden}
  .items-grid thead th{background:#feeef5;text-align:center;padding:10px}
  .items-grid td{padding:8px;border-top:1px solid #f1f5f9;text-align:center;vertical-align:middle}

  .modal{position:fixed;inset:0;display:none;z-index:90}
  .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.45)}
  .modal-card{position:absolute;inset:4% 3%;background:#fff;border-radius:16px;border:1px solid var(--border);display:flex;flex-direction:column}
  .mclose{position:absolute;inset-block-start:10px;inset-inline-start:10px;width:38px;height:38px;border:0;border-radius:999px;background:#ef4444;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.15);z-index:5}
  .mhead{display:flex;gap:10px;align-items:center;padding:12px 12px 12px 56px;border-bottom:1px solid #f1f5f9}
  .mgrid{padding:14px;overflow:auto;display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
  @media(max-width:1200px){.mgrid{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:900px){.mgrid{grid-template-columns:repeat(2,1fr)}}
  .pcard{border:1px solid var(--border);border-radius:14px;padding:10px;display:flex;flex-direction:column;gap:8px}
  .pcard img{width:100%;aspect-ratio:1/1;object-fit:cover;border:1px solid var(--border);border-radius:12px}
  .pcard .name{font-weight:800;text-align:center;min-height:48px}
  .tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:999px;font-size:.8rem;background:#fff7fb;margin-inline:2px}
  .status-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-weight:700;border:1px solid var(--border)}
</style>

<!-- شريط تنقل بسيط -->
<div class="row" style="gap:8px; margin-bottom:12px">
  <a class="btn add" href="/orders"><i class="fa fa-basket-shopping"></i> الطلبات</a>
  <a class="btn save" href="/sales"><i class="fa fa-receipt"></i> المبيعات</a>
</div>

<!-- ===== 1) إضافة طلب (عدة منتجات لنفس الزبون) ===== -->
<div class="card">
  <div class="row">
    <h3><i class="fa fa-plus"></i> إضافة طلب (عدة منتجات)</h3>
  </div>

  <form id="orderForm" method="post" action="/orders" class="form-grid" style="grid-template-columns: 1fr 1fr; gap:14px">
    <div><label>اسم الزبون</label><input name="customer_name" required></div>
    <div><label>الهاتف</label><input name="customer_phone"></div>
    <div><label>المدينة</label><input name="customer_city"></div>
    <div style="grid-column: span 2;">
      <label>ملاحظات للطلب</label>
      <textarea name="note" rows="2"></textarea>
    </div>

    <div style="grid-column: span 2">
      <div class="row" style="justify-content:space-between;align-items:center">
        <h4 style="margin:0">المنتجات</h4>
        <button type="button" id="addRow" class="btn add"><i class="fa fa-plus"></i> إضافة صف</button>
      </div>

      <table class="items-grid" style="margin-top:8px">
        <thead>
          <tr>
            <th style="text-align:right">المنتج</th>
            <th>كمية</th>
            <th>بيع (₪)</th>
            <th>أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>حذف</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </div>

    <div class="right" style="grid-column: span 2;">
      <button class="btn save"><i class="fa fa-floppy-disk"></i> حفظ الطلب</button>
    </div>
  </form>
</div>

<!-- مودال اختيار منتج (شبكة) -->
<div class="modal" id="pickerModal" aria-hidden="true">
  <div class="modal-bg"></div>
  <div class="modal-card">
    <button type="button" id="pickerClose" class="mclose" aria-label="إغلاق">
      <i class="fa fa-xmark"></i>
    </button>

    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <div style="font-weight:800">اختيار منتج من الشبكة</div>
      <input id="searchBox" placeholder="ابحث بالاسم..." class="right" style="max-width:320px">
    </div>

    <div class="mgrid" id="gridWrap">
      <% products.forEach(p=>{ %>
        <div class="pcard" data-id="<%= p.id %>"
             data-name="<%- p.name %>"
             data-img="<%= p.image_path||'' %>"
             data-sale="<%= Number(p.sale_price||0) %>"
             data-cost="<%= Number(p.cost_price||0) %>"
             data-stock="<%= Number(p.stock||0) %>">
          <img src="<%= fixImg(p.image_path||'') %>" alt="">
          <div class="name"><%= p.name %></div>
          <div style="text-align:center">
            <span class="tag">بيع: ₪<%= Number(p.sale_price||0).toFixed(2) %></span>
            <span class="tag">أصلي: ₪<%= Number(p.cost_price||0).toFixed(2) %></span>
            <span class="tag">مخزون: <%= Number(p.stock||0) %></span>
          </div>
          <button class="btn add pickBtn" type="button"><i class="fa fa-check"></i> اختيار</button>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- ===== 2) قائمة الطلبات (أعلى المبيعات) ===== -->
<div class="card" style="margin-top:16px">
  <div class="row" style="justify-content:space-between;align-items:center">
    <h3 style="margin:0"><i class="fa fa-basket-shopping"></i> الطلبات</h3>
    <a class="btn add" href="/orders"><i class="fa fa-list"></i> صفحة الطلبات</a>
  </div>

  <table style="margin-top:8px">
    <thead>
      <tr>
        <th>#</th>
        <th>الزبون</th>
        <th>الهاتف</th>
        <th>المدينة</th>
        <th>عدد الأصناف</th>
        <th>(₪) الإيراد</th>
        <th>(₪) الربح</th>
        <th>الحالة</th>
        <th>تاريخ</th>
        <th>عرض</th>
      </tr>
    </thead>
    <tbody>
      <% if (!openOrders.length){ %>
        <tr><td colspan="10" class="muted">لا توجد طلبات قيد المعالجة/التوصيل.</td></tr>
      <% } %>
      <% openOrders.forEach(o => { %>
      <tr>
        <td><b>#<%= o.id %></b></td>
        <td><%= o.customer_name || '—' %></td>
        <td><%= o.customer_phone || '—' %></td>
        <td><%= o.customer_city || '—' %></td>
        <td><%= Number(o.items_count||0) %></td>
        <td>₪<%= Number(o.revenue||0).toFixed(2) %></td>
        <td>₪<%= Number(o.profit||0).toFixed(2) %></td>
        <td><span class="status-chip"><i class="fa <%= o.status==='shipping'?'fa-truck':'fa-hourglass-half' %>"></i> <%= o.status==='shipping'?'قيد التوصيل':'قيد المعالجة' %></span></td>
        <td><%= dayjs(o.created_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A') %></td>
        <td><a class="btn secondary" href="/orders/<%= o.id %>"><i class="fa fa-eye"></i> عرض</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- ===== 3) المبيعات (فقط تمّ التسليم) ===== -->
<div class="card" style="margin-top:16px">
  <div class="row" style="justify-content:space-between;align-items:center">
    <h3 style="margin:0"><i class="fa fa-receipt"></i> المبيعات (تمّ التسليم)</h3>
    <div class="row" style="gap:8px">
      <a class="btn save" href="/reports"><i class="fa fa-clipboard-list"></i> التقارير</a>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الزبون</th>
        <th>كمية</th>
        <th>(₪) أصلي</th>
        <th>(₪) بيع</th>
        <th>(₪) شحن</th>
        <th>(₪) الربح</th>
        <th>توصيل</th>
        <th>تعديل</th>
      </tr>
    </thead>
    <tbody>
      <% deliveredSales.forEach(s=> {
        const qty = Number(s.quantity);
        const price = Number(s.sale_price);
        const cost  = Number(s.cost_price);
        const ship  = Number(s.shipping_cost||0);
        const revenue = price*qty;
        const profit  = (price*qty) - (cost*qty); // بدون الشحن حسب طلبك
      %>
      <tr>
        <td><%= dayjs(s.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A') %></td>
        <td style="text-align:right">
          <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
            <div class="thumb">
              <% if (s.product_image){ %>
                <img src="<%= fixImg(s.product_image) %>" style="width:100%;height:100%;object-fit:cover">
              <% } %>
            </div>
            <div style="max-width:420px"><%= s.product_name %></div>
          </div>
        </td>
        <td><%= s.customer_name || '—' %></td>
        <td><%= qty %></td>
        <td>₪<%= cost.toFixed(2) %></td>
        <td>₪<%= price.toFixed(2) %></td>
        <td>₪<%= ship.toFixed(2) %></td>
        <td>₪<%= profit.toFixed(2) %></td>
        <td><span class="status-chip"><i class="fa fa-check"></i> تمّ التسليم</span></td>
        <td><a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i> تعديل</a></td>
      </tr>
      <% }) %>
      <% if (!deliveredSales.length){ %><tr><td colspan="10" class="muted">لا توجد مبيعات مُسلّمة بعد.</td></tr><% } %>
    </tbody>
  </table>
</div>

<script>
  // بيانات المنتجات من السيرفر
  const PRODUCTS = <%- JSON.stringify(products||[]) %>;

  // بناء صف جديد داخل نموذج الطلب
  const rows = document.getElementById('rows');
  document.getElementById('addRow').addEventListener('click', addRow);

  function addRow(pref = {}){
    const tr = document.createElement('tr');

    const sel = document.createElement('select');
    sel.name = 'product_id';
    sel.required = true;
    sel.innerHTML = '<option value="">— اختر —</option>' + PRODUCTS.map(p=>(
      `<option value="${p.id}" data-cost="${p.cost_price||0}" data-sale="${p.sale_price||0}">
         ${p.name} (مخزون ${p.stock||0})
       </option>`
    )).join('');
    if (pref.product_id) sel.value = pref.product_id;

    const qty  = input('number','quantity',pref.quantity||1,{min:1,step:1});
    const sale = input('number','sale_price',pref.sale_price||'',{step:'0.01'});
    const cost = input('number','cost_price',pref.cost_price||'',{step:'0.01'});
    const ship = input('number','shipping_cost',pref.shipping_cost||0,{step:'0.01'});
    const note = input('text','item_note',pref.item_note||'',{});

    sel.addEventListener('change',()=>{
      const opt = sel.options[sel.selectedIndex];
      if (opt && !sale.value) sale.value = opt.dataset.sale || '';
      if (opt && !cost.value) cost.value = opt.dataset.cost || '';
    });

    tr.appendChild(tcell(sel, true));
    tr.appendChild(tcell(qty));
    tr.appendChild(tcell(sale));
    tr.appendChild(tcell(cost));
    tr.appendChild(tcell(ship));
    tr.appendChild(tcell(note));

    const delBtn = document.createElement('button');
    delBtn.type='button'; delBtn.className='btn danger'; delBtn.innerHTML='<i class="fa fa-trash"></i>';
    delBtn.addEventListener('click', ()=> tr.remove());
    tr.appendChild(tcell(delBtn));

    rows.appendChild(tr);
  }
  function input(type,name,val,attrs){const i=document.createElement('input');i.type=type;i.name=name;i.value=val??'';Object.entries(attrs||{}).forEach(([k,v])=>i.setAttribute(k,v));return i;}
  function tcell(child,right){const td=document.createElement('td');if(right) td.style.textAlign='right';td.appendChild(child);return td;}

  // صف مبدئي
  addRow();

  // مودال اختيار منتج (للنسخ السريعة مستقبلاً إن حبيت)
  (function(){
    const modal=document.getElementById('pickerModal');
    const bg=modal.querySelector('.modal-bg');
    const closeBtn=document.getElementById('pickerClose');
    const search=document.getElementById('searchBox');
    const cards=[...modal.querySelectorAll('.pcard')];

    function show(){ modal.style.display='block'; search.focus(); }
    function hide(){ modal.style.display='none'; search.value=''; filter(''); }
    bg.addEventListener('click',hide);
    closeBtn.addEventListener('click',hide);
    document.addEventListener('keydown',e=>{ if(modal.style.display==='block' && e.key==='Escape') hide(); });

    function filter(q){ const s=(q||'').trim().toLowerCase(); cards.forEach(c=>c.style.display=c.dataset.name.toLowerCase().includes(s)?'flex':'none'); }
    search.addEventListener('input',e=>filter(e.target.value));
    // ممكن نضيف زر فتح المودال لاحقًا لو بدك اختيار شبكي بدل القائمة.
  })();
</script>
