<!-- views/sales.ejs — كامل وجاهز للاستبدال (رقم الطلب إجباري + فحص تكرار) -->
<link rel="stylesheet" href="<%= faLink %>">

<style>
  .table-scroll{overflow:auto;border:1px solid var(--border);border-radius:12px}
  table{width:100%;border-collapse:collapse;background:#fff}
  thead th{background:#feeef5}
  th,td{padding:10px;border-top:1px solid #f1f5f9;text-align:center;vertical-align:middle}
  .muted-sm{color:#6b7280;font-size:.9rem}
  .thumb{width:56px;height:56px;border-radius:10px;object-fit:cover;border:1px solid var(--border)}
  .btn{display:inline-flex;align-items:center;gap:8px;border:0;border-radius:12px;padding:10px 14px;color:#fff;cursor:pointer}
  .btn.add{background:#2563eb}.btn.save{background:#16a34a}.btn.danger{background:#ef4444}
  .btn.edit{background:#f9a825;color:#111}
  .row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .right{margin-inline-start:auto}
  .card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:16px;box-shadow:var(--shadow)}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  @media(max-width:800px){.form-grid{grid-template-columns:1fr}}
  input,select,textarea{width:100%;background:#fff;border:1px solid var(--border);border-radius:12px;padding:10px 12px}
  .status-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-weight:700;font-size:.88rem;border:1px solid var(--border)}
  .status-pending{background:#fff7e6}.status-shipping{background:#fff3cd}
  .status-delivered{background:#e6ffed}.status-failed{background:#ffe6e6}

  /* تنبيه خطأ لرقم الطلب */
  .field-error{color:#b91c1c;margin-top:6px;display:none}
  .is-invalid{border-color:#ef4444!important;box-shadow:0 0 0 2px rgba(239,68,68,.12)}

  /* ===== Modal (picker) ===== */
  .modal{display:none;position:fixed;inset:0;z-index:60}
  .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.5)}
  .modal-card{position:relative;margin:auto;top:5vh;width:min(1100px,95vw);max-height:90vh;overflow:auto;background:#fff;border-radius:18px;padding:14px}
  .mhead{display:flex;align-items:center;gap:10px;padding:4px 2px 10px 2px;border-bottom:1px solid #f1f5f9;margin-bottom:10px; padding-inline-start:56px;}
  .mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
  .pcard{position:relative;background:#fff;border:1px solid var(--border);border-radius:14px;padding:10px;display:flex;flex-direction:column;gap:8px;box-shadow:var(--shadow)}
  .pcard.soldout{opacity:.55;filter:grayscale(1)}
  .pcard .ribbon{position:absolute;inset:8px auto auto 8px;background:#ef4444;color:#fff;padding:2px 8px;border-radius:999px;font-weight:800;font-size:.8rem}
  .pcard img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:10px;border:1px solid var(--border)}
  .pcard .name{font-weight:800}
  .tag{display:inline-block;font-size:.82rem;padding:4px 8px;border-radius:999px;background:#f8fafc;border:1px solid var(--border)}
  .mclose{position:absolute; top:10px; left:10px; width:40px; height:40px; border:0; border-radius:999px; background:#ef4444; color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 2px 8px rgba(0,0,0,.15); z-index:5}
  .mclose:hover{ filter:brightness(.95) }
  .choose-btn{white-space:nowrap}
</style>

<div class="container page">
  <% if (flash) { %>
    <div class="card" style="border-color:<%= flash.type==='success'?'#bbf7d0':'#fecaca' %>">
      <div class="row" style="justify-content:space-between;align-items:center">
        <div>
          <b><%= flash.type==='success'?'✅ نجاح':'⚠️ تنبيه' %>:</b>
          <%= flash.msg %>
          <% if (flash.skipped && flash.skipped.length) { %>
            <div class="muted-sm" style="margin-top:6px">
              تم تجاوز البنود التالية: <%= flash.skipped.join('، ') %>
            </div>
          <% } %>
        </div>
        <% if (flash.orderId) { %>
          <a class="btn edit" href="/orders/<%= flash.orderId %>"><i class="fa fa-folder-open"></i> فتح الطلب</a>
        <% } %>
      </div>
    </div>
  <% } %>

  <h2 style="margin:0 0 10px"><i class="fa fa-cart-shopping"></i> إضافة طلب جديد (عدّة منتجات)</h2>

  <!-- نموذج الطلب متعدد البنود -->
  <form id="multiSaleForm" action="/sales/multi" method="post" class="card" novalidate>
    <div class="form-grid">
      <input name="customer_name"  placeholder="اسم الزبون">
      <input name="customer_phone" placeholder="الهاتف">
      <input name="customer_city"  placeholder="المدينة">
      <input name="order_note"     placeholder="ملاحظة عامة للطلب" style="grid-column:1 / -1">
    </div>

    <!-- رقم طلب إجباري + حساب/رابط إنستغرام -->
    <div class="form-grid" style="margin-top:10px">
      <div>
        <input id="orderId" name="order_id" type="number" min="1" required
               placeholder="رقم الطلب (إجباري وفريد)">
        <div id="orderIdHelp" class="muted-sm">هذا الحقل إجباري ورقم الطلب يجب أن يكون فريدًا.</div>
        <div id="orderIdErr" class="field-error">رقم الطلب موجود مسبقًا. اختر رقمًا آخر.</div>
      </div>
      <div>
        <input name="customer_instagram" placeholder="حساب إنستغرام / رابط (اختياري)">
      </div>
    </div>

    <div class="row" style="margin:14px 0 10px">
      <button class="btn add" type="button" id="btnAddEmpty"><i class="fa fa-plus"></i> إضافة سطر</button>
      <button class="btn danger" type="button" id="btnClear"><i class="fa fa-trash"></i> إفراغ كل البنود</button>
      <div class="right muted-sm">لكل سطر زر “اختيار من الشبكة” لتعبئة المنتج نفسه</div>
    </div>

    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th style="width:46px">حذف</th>
            <th class="right">المنتج</th>
            <th>كمية</th>
            <th>(₪) سعر بيع</th>
            <th>(₪) سعر أصلي</th>
            <th>(₪) شحن</th>
            <th>ملاحظة</th>
          </tr>
        </thead>
        <tbody id="cartBody"></tbody>
      </table>
    </div>

    <div class="row" style="gap:18px;margin-top:12px">
      <div class="muted-sm">الإيراد الكلي: ₪ <span id="sumRevenue">0.00</span></div>
      <div class="muted-sm">الربح الكلي: ₪ <span id="sumProfit">0.00</span></div>
    </div>

    <div class="row" style="margin-top:14px">
      <button class="btn save" id="btnSubmit"><i class="fa fa-floppy-disk"></i> حفظ البنود</button>
    </div>
  </form>

  <!-- الطلبات المفتوحة -->
  <hr>
  <h2><i class="fa fa-list"></i> الطلبات المفتوحة</h2>
  <div class="cards">
    <% (openOrders||[]).forEach(o => { %>
      <div class="card">
        <div class="row" style="justify-content:space-between">
          <div>
            <b>#<%= o.id %></b> — <%= o.customer_name || 'بدون اسم' %>
            <div class="muted-sm"><i class="fa fa-clock"></i>
              <%= dayjs(o.created_at).tz('Asia/Hebron').format('hh:mm a YYYY-MM-DD') %>
            </div>
          </div>
          <a class="btn edit" href="/orders/<%= o.id %>"><i class="fa fa-pen"></i> إدارة</a>
        </div>

        <% if ((o.items||[]).length) { %>
          <div class="table-scroll" style="margin-top:10px">
            <table>
              <thead>
                <tr><th>المنتج</th><th>كمية</th><th>سعر</th><th>شحن</th><th>الحالة</th></tr>
              </thead>
              <tbody>
                <% o.items.forEach(it=>{ %>
                  <tr>
                    <td style="text-align:right">
                      <div class="row">
                        <img class="thumb" src="<%= it.product_image||'' %>">
                        <div><%= it.product_name %></div>
                      </div>
                    </td>
                    <td><%= it.quantity %></td>
                    <td>₪<%= Number(it.sale_price).toFixed(2) %></td>
                    <td>₪<%= Number(it.shipping_cost||0).toFixed(2) %></td>
                    <td>
                      <span class="status-chip status-<%= it.delivery_status %>">
                        <% if(it.delivery_status==='pending'){ %><i class="fa fa-hourglass-half"></i> قيد المعالجة
                        <% } else if(it.delivery_status==='shipping'){ %><i class="fa fa-truck"></i> قيد التوصيل
                        <% } else if(it.delivery_status==='delivered'){ %><i class="fa fa-check"></i> تم التسليم
                        <% } else { %><i class="fa fa-xmark"></i> لم يتم / فشل <% } %>
                      </span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    <% }) %>
    <% if (!(openOrders||[]).length) { %>
      <div class="card"><div class="muted">لا توجد طلبات مفتوحة مؤخرًا.</div></div>
    <% } %>
  </div>
</div>

<!-- مودال اختيار من الشبكة -->
<div class="modal" id="picker" aria-hidden="true">
  <div class="modal-bg"></div>
  <div class="modal-card">
    <button class="mclose" type="button" id="pickerClose"><i class="fa fa-xmark"></i></button>
    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <strong>اختيار منتج</strong>
      <div class="right" style="display:flex;gap:8px;align-items:center">
        <input id="pickSearch" placeholder="بحث بالاسم/الماركة/التصنيف..." style="max-width:320px">
        <label class="row muted-sm" style="gap:6px"><input type="checkbox" id="hideOut"> إخفاء النافد</label>
      </div>
    </div>

    <div class="mgrid" id="pickGrid">
      <% (products||[]).forEach(p => { 
           const stock = Number(p.stock||0);
           const isOut = stock <= 0;
      %>
        <div class="pcard <%= isOut ? 'soldout' : '' %>"
             data-id="<%= p.id %>"
             data-name="<%- p.name %>"
             data-brand="<%- p.brand||'' %>"
             data-cat="<%- p.category||'' %>"
             data-sp="<%= Number(p.sale_price||0) %>"
             data-cp="<%= Number(p.cost_price||0) %>"
             data-stock="<%= stock %>">
          <% if(isOut){ %><div class="ribbon">نفد</div><% } %>
          <img src="<%= p.image_path || 'https://via.placeholder.com/600?text=No+Image' %>" alt="<%- p.name %>">
          <div class="name"><%- p.name %></div>
          <div style="display:flex;justify-content:space-between">
            <span class="tag">سعر: ₪<%= Number(p.sale_price||0).toFixed(2) %></span>
            <span class="tag">مخزون: <%= stock %></span>
          </div>
          <div class="muted-sm" style="text-align:center;margin-top:6px">
            <%= (p.brand||'—') %> • <%= (p.category||'—') %>
          </div>
          <button class="btn add pickBtn" type="button" <%= isOut ? 'disabled title="نفد المخزون"' : '' %>>
            <i class="fa fa-check"></i> اختيار
          </button>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  const PRODUCTS = <%- JSON.stringify(products||[]) %>;
  const cartBody = document.getElementById('cartBody');
  const sumRevenue = document.getElementById('sumRevenue');
  const sumProfit  = document.getElementById('sumProfit');
  const btnAddRow  = document.getElementById('btnAddEmpty');
  const btnClear   = document.getElementById('btnClear');
  const orderIdInp = document.getElementById('orderId');
  const orderErr   = document.getElementById('orderIdErr');
  const submitBtn  = document.getElementById('btnSubmit');

  const picker   = document.getElementById('picker');
  const pickGrid = document.getElementById('pickGrid');
  const pickSearch = document.getElementById('pickSearch');
  const hideOut  = document.getElementById('hideOut');
  const pickerCloseBtn = document.getElementById('pickerClose');

  let activeRow = null;
  const num = v => Number(v||0) || 0;
  const fmt = n => (Number(n)||0).toFixed(2);

  /* ====== رقم الطلب: فحص فريد ====== */
  async function checkOrderId(){
    const v = (orderIdInp.value||'').trim();
    if(!v){ orderErr.style.display='none'; orderIdInp.classList.remove('is-invalid'); submitBtn.removeAttribute('disabled'); return false; }
    try{
      const r = await fetch(`/orders/check-id?id=${encodeURIComponent(v)}`);
      const j = await r.json();
      const taken = !!j.exists;
      orderErr.style.display = taken ? 'block' : 'none';
      orderIdInp.classList.toggle('is-invalid', taken);
      submitBtn.toggleAttribute('disabled', taken);
      return taken;
    }catch(_e){
      // في حال فشل الشبكة لا نمنع الإرسال
      orderErr.style.display='none';
      orderIdInp.classList.remove('is-invalid');
      submitBtn.removeAttribute('disabled');
      return false;
    }
  }
  orderIdInp.addEventListener('input', checkOrderId);
  orderIdInp.addEventListener('blur', checkOrderId);

  /* منع الإرسال إن كان الرقم مكرر */
  document.getElementById('multiSaleForm').addEventListener('submit', async (e)=>{
    if(!orderIdInp.reportValidity()) return; // required من المتصفح
    e.preventDefault();
    const taken = await checkOrderId();
    if(!taken) e.target.submit();
  });

  function rowTemplate({pid=0, name='', qty=1, sp=0, cp=0, ship=0, note='', img=''} = {}) {
    const has = Boolean(pid && name);
    return `
      <tr class="sale-row" data-pid="${pid}">
        <td><button class="btn danger" type="button" data-act="del" title="حذف" style="padding:8px 10px"><i class="fa fa-xmark"></i></button></td>
        <td class="right">
          <input type="hidden" name="product_id[]" value="${pid}">
          <div class="row" style="justify-content:flex-end;gap:8px">
            ${has && img ? `<img src="${img}" class="thumb">` : ''}
            <span class="${has ? '' : 'muted-sm'}">${has ? name : '[اختر من الشبكة]'}</span>
            <button class="btn add choose-btn" type="button" data-act="choose"><i class="fa fa-grid-2"></i> اختيار من الشبكة</button>
          </div>
        </td>
        <td><input name="quantity[]" type="number" min="1" step="1" value="${qty}"></td>
        <td><input name="sale_price[]" type="number" step="0.01" value="${sp}"></td>
        <td><input name="cost_price[]" type="number" step="0.01" value="${cp}"></td>
        <td><input name="shipping_cost[]" type="number" step="0.01" value="${ship}"></td>
        <td><input name="item_note[]" placeholder="ملاحظة" value="${note}"></td>
      </tr>`;
  }

  function addRow(data={}){ cartBody.insertAdjacentHTML('beforeend', rowTemplate(data)); recalc(); }
  function recalc(){
    let rev=0, prof=0;
    cartBody.querySelectorAll('tr.sale-row').forEach(tr=>{
      const q=num(tr.querySelector('input[name="quantity[]"]').value);
      const sp=num(tr.querySelector('input[name="sale_price[]"]').value);
      const cp=num(tr.querySelector('input[name="cost_price[]"]').value);
      const sh=num(tr.querySelector('input[name="shipping_cost[]"]').value);
      rev+=q*sp; prof+=(sp-cp)*q - sh;
    });
    sumRevenue.textContent=fmt(rev); sumProfit.textContent=fmt(prof);
  }

  cartBody.addEventListener('input', e=>{ if (e.target.matches('input')) recalc(); });
  cartBody.addEventListener('click', e=>{
    const del=e.target.closest('[data-act="del"]'); if(del){ del.closest('tr').remove(); recalc(); return; }
    const choose=e.target.closest('[data-act="choose"]'); if(choose){ activeRow=choose.closest('tr'); showPicker(); }
  });

  btnAddRow.addEventListener('click', ()=>addRow({}));
  btnClear.addEventListener('click', ()=>{ cartBody.innerHTML=''; recalc(); });

  function showPicker(){ picker.style.display='block'; pickSearch.focus(); }
  function hidePicker(){ picker.style.display='none'; pickSearch.value=''; filterGrid(''); activeRow=null; }

  document.querySelector('#picker .modal-bg').addEventListener('click', hidePicker);
  pickerCloseBtn.addEventListener('click', hidePicker);
  document.addEventListener('keydown', e=>{ if(picker.style.display==='block' && e.key==='Escape') hidePicker(); });

  function filterGrid(q){
    const s=(q||'').trim().toLowerCase();
    [...pickGrid.querySelectorAll('.pcard')].forEach(card=>{
      const hay=(card.dataset.name+' '+(card.dataset.brand||'')+' '+(card.dataset.cat||'')).toLowerCase();
      const out=Number(card.dataset.stock||0)<=0;
      const passText=hay.includes(s);
      const passOut =!hideOut.checked || !out;
      card.style.display=(passText && passOut)?'flex':'none';
    });
  }
  pickSearch.addEventListener('input', e=>filterGrid(e.target.value));
  hideOut.addEventListener('change', ()=>filterGrid(pickSearch.value));

  pickGrid.addEventListener('click', e=>{
    const btn=e.target.closest('.pickBtn'); if(!btn||!activeRow) return;
    const card=btn.closest('.pcard');
    const stock=Number(card.dataset.stock||0);
    if(stock<=0){ alert('لا يمكن إضافة منتج نفد من المخزون'); return; }

    const pid=Number(card.dataset.id||0);
    const name=card.dataset.name||'';
    const sp=Number(card.dataset.sp||0);
    const cp=Number(card.dataset.cp||0);
    const img=card.querySelector('img')?.getAttribute('src')||'';

    activeRow.dataset.pid=String(pid);
    activeRow.querySelector('input[name="product_id[]"]').value=pid;
    activeRow.querySelector('input[name="sale_price[]"]').value=sp;
    activeRow.querySelector('input[name="cost_price[]"]').value=cp;

    const cell=activeRow.querySelector('td:nth-child(2) .row');
    if(cell){
      const existing=cell.querySelector('img.thumb');
      if(img){ if(existing) existing.src=img; else cell.insertAdjacentHTML('afterbegin', `<img src="${img}" class="thumb">`); }
      const nameSpan=cell.querySelector('span'); if(nameSpan){ nameSpan.textContent=name; nameSpan.classList.remove('muted-sm'); }
    }
    recalc(); hidePicker();
  });

  // صف ابتدائي
  addRow({});
</script>
