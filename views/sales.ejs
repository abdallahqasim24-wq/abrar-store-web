<div class="card" style="margin-top:12px">
  <h3><i class="fa fa-receipt"></i> سجل المبيعات</h3>
  <form method="post" action="/sales/bulk-delete" id="bulkDelForm">
    <table>
      <thead>
        <tr>
          <th>الصورة</th> <!-- 👈 عمود جديد -->
          <th>التاريخ</th>
          <th>المنتج</th>
          <th>كمية</th>
          <th>سعر بيع</th>
          <th>السعر الأصلي</th>
          <th>شحن</th>
          <th>الربح</th>
          <th>حذف</th>
          <th style="width:44px">
            <input type="checkbox" id="selectAllSales"/>
          </th>
        </tr>
      </thead>
      <tbody>
        <% sales.forEach(s => {
             const profit = (Number(s.sale_price)*Number(s.quantity))
                           - (Number(s.cost_price)*Number(s.quantity))
                           - Number(s.shipping_cost||0);
        %>
          <tr>
            <td>
              <% if (s.product_image) { %>
                <img src="<%= s.product_image %>" class="thumb" alt="صورة <%= s.product_name %>">
              <% } else { %> — <% } %>
            </td>
            <td><%= dayjs(s.sold_at).format('YYYY-MM-DD HH:mm') %></td>
            <td><%= s.product_name %></td>
            <td><%= s.quantity %></td>
            <td>₪<%= Number(s.sale_price).toFixed(2) %></td>
            <td>₪<%= Number(s.cost_price).toFixed(2) %></td>
            <td>₪<%= Number(s.shipping_cost||0).toFixed(2) %></td>
            <td>₪<%= profit.toFixed(2) %></td>
            <td>
              <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف العملية؟')">
                <button class="btn danger"><i class="fa fa-trash"></i> حذف</button>
              </form>
            </td>
            <td style="text-align:center">
              <input type="checkbox" name="ids" value="<%= s.id %>" class="rowChkSales">
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="row" style="margin-top:10px">
      <button class="btn danger" type="submit" onclick="return confirm('حذف العناصر المحددة؟ سيُعاد المخزون!')">
        <i class="fa fa-trash"></i> حذف المحدد
      </button>
      <div class="right"></div>
    </div>
  </form>
</div>

<script>
  // Select All للمبيعات
  const selectAllSales = document.getElementById('selectAllSales');
  if (selectAllSales) {
    selectAllSales.addEventListener('change', e => {
      document.querySelectorAll('.rowChkSales').forEach(ch => ch.checked = e.target.checked);
    });
  }
</script>
