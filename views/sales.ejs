<%- /* sales.ejs — واجهة مبيعات محدثة */ -%>
<link rel="stylesheet" href="<%= faLink || 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css' %>">
<style>
  .wrap{max-width:1200px;margin:0 auto;padding:14px}
  .card{background:#fff;border:1px solid #eef2f7;border-radius:14px;padding:16px;margin:14px 0}
  .row{display:flex;gap:8px;align-items:center}
  .grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  .grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
  input,select{width:100%;padding:10px;border:1px solid #e5e7eb;border-radius:10px}
  .btn{display:inline-flex;gap:6px;align-items:center;border:0;border-radius:10px;padding:9px 12px;cursor:pointer}
  .btn.primary{background:#2563eb;color:#fff}
  .btn.gray{background:#f1f5f9}
  .btn.danger{background:#ef4444;color:#fff}
  .table{width:100%;border:1px solid #eef2f7;border-radius:12px;overflow:hidden}
  .table th{background:#feeef5;text-align:center;padding:10px}
  .table td{border-top:1px solid #f1f5f9;text-align:center;vertical-align:middle;padding:8px}
  .thumb{width:44px;height:44px;border:1px solid #ebedf0;border-radius:10px;object-fit:cover;background:#fff}
  .muted{color:#7a8da1}
  .pill{display:inline-flex;gap:6px;align-items:center;padding:6px 10px;border-radius:999px;border:1px solid #ebedf0}
  .pill.delivered{background:#efffed}
</style>

<div class="wrap">
  <!-- شريط علوي: المبيعات (تم التسليم) -->
  <div class="card">
    <div class="row" style="justify-content:space-between">
      <h3 style="margin:0"><i class="fa fa-check-double"></i> المبيعات — تمّ التسليم</h3>
      <form method="post" action="/sales/bulk-deliver" id="deliverForm" class="row" style="gap:8px">
        <input type="hidden" name="ids" id="deliverIds">
        <button class="btn primary" type="submit"><i class="fa fa-check"></i> تعليم المحدد “تمّ التسليم”</button>
      </form>
    </div>
    <table class="table" id="deliveredTbl">
      <thead>
        <tr>
          <th><input type="checkbox" id="delvToggle"></th>
          <th>الصورة</th>
          <th>المنتج</th>
          <th>كمية</th>
          <th>سعر البيع (₪)</th>
          <th>السعر الأصلي (₪)</th>
          <th>الربح (₪)</th>
          <th>التاريخ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!delivered || !delivered.length){ %>
          <tr><td colspan="8" class="muted">لا توجد عناصر مسلّمة بعد.</td></tr>
        <% } %>
        <% (delivered||[]).forEach(r=>{ %>
          <tr data-id="<%= r.id %>">
            <td><input type="checkbox" class="chk-delv"></td>
            <td><img class="thumb" src="<%= r.product_image||'' %>"></td>
            <td style="text-align:right"><%= r.product_name %></td>
            <td><%= r.quantity %></td>
            <td>₪<%= Number(r.sale_price).toFixed(2) %></td>
            <td>₪<%= Number(r.cost_price).toFixed(2) %></td>
            <td><span class="pill delivered">₪<%= Number(r._profit||0).toFixed(2) %></span></td>
            <td><%= (new Date(r.delivered_at||r.sold_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- نموذج إضافة عملية بيع (عدة منتجات) -->
  <div class="card">
    <h3 style="margin:0 0 10px 0"><i class="fa fa-cart-plus"></i> إضافة عملية بيع (عدة منتجات)</h3>
    <form method="post" action="/sales/multi" id="multiForm">
      <div class="grid4">
        <input name="customer_name"  placeholder="اسم الزبون">
        <input name="customer_phone" placeholder="الهاتف">
        <input name="customer_city"  placeholder="المدينة">
        <input name="order_note"     placeholder="ملاحظة عامة للطلب">
      </div>

      <table class="table" id="itemsTable" style="margin-top:12px">
        <thead>
          <tr>
            <th>المنتج</th>
            <th>كمية</th>
            <th>سعر بيع (₪)</th>
            <th>سعر أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>حذف</th>
          </tr>
        </thead>
        <tbody id="itemsBody"></tbody>
      </table>

      <div class="row" style="justify-content:space-between;margin-top:10px">
        <button class="btn gray" type="button" id="addRow"><i class="fa fa-plus"></i> إضافة بند</button>
        <div class="row" style="gap:8px">
          <button class="btn danger"  type="button" id="clearRows"><i class="fa fa-trash"></i> إفراغ السلة</button>
          <button class="btn primary" type="submit"><i class="fa fa-save"></i> حفظ البنود</button>
        </div>
      </div>
    </form>
  </div>

  <!-- الطلبات الحديثة -->
  <div class="card">
    <div class="row" style="justify-content:space-between">
      <h3 style="margin:0"><i class="fa fa-list"></i> الطلبات</h3>
      <div class="row" style="gap:8px">
        <form method="post" action="/sales/bulk-return" id="retForm" class="row"><input type="hidden" name="ids" id="retIds"><button class="btn gray" type="submit"><i class="fa fa-rotate-left"></i> نقل المحدد إلى الراجعات</button></form>
        <form method="post" action="/sales/bulk-delete" id="delForm" class="row"><input type="hidden" name="ids" id="delIds"><button class="btn danger" type="submit"><i class="fa fa-trash"></i> حذف المحدد نهائيًا</button></form>
        <a class="btn gray" href="/orders"><i class="fa fa-basket-shopping"></i> كل الطلبات</a>
      </div>
    </div>

    <table class="table" id="ordersTbl">
      <thead>
        <tr>
          <th><input type="checkbox" id="ordToggle"></th>
          <th>#</th>
          <th>الزبون</th>
          <th>الهاتف</th>
          <th>الحالة</th>
          <th>الأصناف</th>
          <th>الإيراد (₪)</th>
          <th>الربح (₪)</th>
          <th>التاريخ</th>
          <th>عرض</th>
        </tr>
      </thead>
      <tbody>
        <% if (!orders || !orders.length){ %>
          <tr><td colspan="10" class="muted">لا توجد طلبات بعد.</td></tr>
        <% } %>
        <% (orders||[]).forEach(o=>{ %>
          <tr data-id="<%= o.id %>">
            <td><input type="checkbox" class="chk-ord"></td>
            <td>#<%= o.id %></td>
            <td style="text-align:right"><%= o.customer_name || '—' %></td>
            <td><%= o.customer_phone || '—' %></td>
            <td><%= o.status==='pending'?'قيد المعالجة':o.status==='shipping'?'قيد التوصيل':o.status==='delivered'?'تم التسليم':'—' %></td>
            <td><%= o.items_count || 0 %></td>
            <td>₪<%= Number(o.revenue||0).toFixed(2) %></td>
            <td>₪<%= Number(o.profit||0).toFixed(2) %></td>
            <td><%= (new Date(o.created_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %></td>
            <td><a class="btn gray" href="/orders/<%= o.id %>"><i class="fa fa-eye"></i> عرض</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // بيانات المنتجات من السيرفر (لصناعة الصفوف بسرعة)
  const PRODUCTS = <%- JSON.stringify(products||[]) %>;

  // === بناء صف جديد
  function makeRow(){
    const opts = PRODUCTS.map(p => `<option value="${p.id}" data-sp="${p.sale_price||0}" data-cp="${p.cost_price||0}">${p.name}</option>`).join('');
    return `
      <tr>
        <td style="text-align:right">
          <select name="product_id">${opts}</select>
        </td>
        <td><input name="quantity" type="number" value="1" min="1" step="1" required></td>
        <td><input name="sale_price" type="number" step="0.01" required></td>
        <td><input name="cost_price" type="number" step="0.01" required></td>
        <td><input name="shipping_cost" type="number" step="0.01" value="0"></td>
        <td><input name="item_note" type="text"></td>
        <td><button class="btn danger btn-del" type="button"><i class="fa fa-xmark"></i></button></td>
      </tr>`;
  }

  const body = document.getElementById('itemsBody');
  const add  = document.getElementById('addRow');
  const clr  = document.getElementById('clearRows');

  function autoFillPrices(tr){
    const sel = tr.querySelector('select[name="product_id"]');
    const spI = tr.querySelector('input[name="sale_price"]');
    const cpI = tr.querySelector('input[name="cost_price"]');
    const opt = sel.options[sel.selectedIndex];
    if (opt){
      const sp = Number(opt.getAttribute('data-sp')||0);
      const cp = Number(opt.getAttribute('data-cp')||0);
      if (!spI.value) spI.value = sp;
      if (!cpI.value) cpI.value = cp;
    }
  }

  function addRow(){
    body.insertAdjacentHTML('beforeend', makeRow());
    const tr = body.lastElementChild;
    tr.querySelector('.btn-del').onclick = ()=> tr.remove();
    tr.querySelector('select[name="product_id"]').onchange = ()=> autoFillPrices(tr);
    autoFillPrices(tr);
  }

  add.onclick = addRow;
  clr.onclick = ()=> (body.innerHTML = '');
  if (!body.children.length) addRow();

  // تجميع معرفات المحدد (المبيعات المسلّمة)
  const delvToggle = document.getElementById('delvToggle');
  delvToggle?.addEventListener('change', e=>{
    document.querySelectorAll('.chk-delv').forEach(c=> c.checked = e.target.checked);
  });
  document.getElementById('deliverForm')?.addEventListener('submit', e=>{
    const ids = Array.from(document.querySelectorAll('#deliveredTbl tbody tr'))
      .filter(tr => tr.querySelector('.chk-delv')?.checked)
      .map(tr => tr.getAttribute('data-id'))
      .filter(Boolean);
    document.getElementById('deliverIds').value = ids.join(',');
  });

  // تحديد وحذف/إرجاع للطلبات (حسب بنود الطلب)
  const ordToggle = document.getElementById('ordToggle');
  ordToggle?.addEventListener('change', e=>{
    document.querySelectorAll('.chk-ord').forEach(c=> c.checked = e.target.checked);
  });
  function fillIds(hiddenId){
    const ids = Array.from(document.querySelectorAll('#ordersTbl tbody tr'))
      .filter(tr => tr.querySelector('.chk-ord')?.checked)
      // ملاحظة: سننفذ العمليات على بنود المبيعات داخل السيرفر اعتمادًا على IDs البنود لاحقًا إن رغبت.
      .map(tr => tr.getAttribute('data-id'));
    document.getElementById(hiddenId).value = ids.join(',');
  }
  document.getElementById('retForm')?.addEventListener('submit', ()=> fillIds('retIds'));
  document.getElementById('delForm')?.addEventListener('submit', ()=> fillIds('delIds'));
</script>
