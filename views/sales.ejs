<link rel="stylesheet" href="<%= faLink %>">

<div class="card">
  <h3><i class="fa fa-receipt"></i> سجل المبيعات</h3>

  <!-- شريط أدوات التحديد الجماعي -->
  <div class="row" style="margin:8px 0;gap:10px;align-items:center">
    <label class="row select-all" style="gap:6px">
      <input type="checkbox" id="checkAll"> تحديد الكل
    </label>

    <!-- نقل المحدد إلى الراجعات -->
    <form method="post" action="/sales/bulk-return" id="bulkReturnForm" class="right"
          onsubmit="return confirm('نقل العمليات المحددة إلى قائمة الراجعات؟')">
      <input type="hidden" name="ids" id="bulkReturnIds">
      <button class="btn secondary" type="submit">
        <i class="fa fa-arrow-rotate-left"></i> نقل المحدد إلى الراجعات
      </button>
    </form>

    <!-- حذف المحدد نهائيًا -->
    <form method="post" action="/sales/bulk-delete" id="bulkDeleteForm"
          onsubmit="return confirm('حذف نهائي للعمليات المحددة؟ لا يمكن التراجع.')">
      <input type="hidden" name="ids" id="bulkDeleteIds">
      <button class="btn danger" type="submit">
        <i class="fa fa-trash"></i> حذف المحدد نهائيًا
      </button>
    </form>
  </div>

  <table>
    <thead>
      <tr>
        <th></th>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الزبون</th>
        <th>هاتف</th>
        <th>المدينة</th>

        <!-- ترتيب وسط الجدول -->
        <th>كمية</th>
        <th>السعر الأصلي (₪)</th>
        <th>سعر بيع (₪)</th>
        <th>شحن (₪)</th>
        <!-- ✅ الربح ثم المطلوب (المطلوب يسار الربح بصريًا) -->
        <th>الربح (₪)</th>
        <th>المطلوب (₪)</th>

        <th>التوصيل</th>
        <th>تعديل</th>
        <th>إجراء</th>
      </tr>
    </thead>
    <tbody>
      <% sales.forEach(s=> {
           const qty       = Number(s.quantity);
           const price     = Number(s.sale_price);
           const costUnit  = Number(s.cost_price);
           const ship      = Number(s.shipping_cost||0);
           const revenue   = price * qty;
           const requested = revenue + ship;
           const profit    = revenue - (costUnit*qty) - ship;
           const status    = (s.delivery_status || 'pending');
      %>
        <tr>
          <td><input type="checkbox" class="rowChk" value="<%= s.id %>"></td>
          <td><%= dayjs(s.sold_at).format('YYYY-MM-DD hh:mm A') %></td>

          <td style="text-align:right">
            <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
              <div style="width:64px;height:64px;display:flex;align-items:center;justify-content:center;border:1px solid var(--border);border-radius:10px;overflow:hidden">
                <% if (s.product_image) { %>
                  <img src="<%= s.product_image %>" class="js-img" style="width:100%;height:100%;object-fit:cover" alt="">
                <% } %>
              </div>
              <div style="max-width:380px"><%= s.product_name %></div>
            </div>
          </td>

          <td><%= s.customer_name || '—' %></td>
          <td><%= s.customer_phone || '—' %></td>
          <td><%= s.customer_city || '—' %></td>

          <td><%= qty %></td>
          <td>₪<%= costUnit.toFixed(2) %></td>
          <td>₪<%= price.toFixed(2) %></td>
          <td>₪<%= ship.toFixed(2) %></td>

          <!-- ✅ أولًا الربح ثم المطلوب -->
          <td>₪<%= profit.toFixed(2) %></td>
          <td><strong>₪<%= requested.toFixed(2) %></strong></td>

          <td>
            <div class="status-wrap">
              <div class="status-chip status-<%= status %>" onclick="toggleMenu(this)">
                <% if (status==='delivered'){ %><i class="fa fa-check"></i><span>تم التسليم</span>
                <% } else if (status==='failed'){ %><i class="fa fa-xmark"></i><span>فشل/لم يتم</span>
                <% } else if (status==='shipping'){ %><i class="fa fa-truck"></i><span>قيد التوصيل</span>
                <% } else { %><i class="fa fa-hourglass-half"></i><span>قيد المعالجة</span><% } %>
              </div>
              <div class="status-menu">
                <% ['pending','shipping','delivered','failed'].forEach(st=>{ %>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="<%= st %>">
                  <button type="submit">
                    <i class="fa <%= st==='pending'?'fa-hourglass-half':st==='shipping'?'fa-truck':st==='delivered'?'fa-check':'fa-xmark' %>"></i>
                    <%= st==='pending'?'قيد المعالجة':st==='shipping'?'قيد التوصيل':st==='delivered'?'تم التسليم':'فشل/لم يتم' %>
                  </button>
                </form>
                <% }) %>
              </div>
            </div>
          </td>

          <td>
            <a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i> تعديل</a>
          </td>

          <td class="row" style="gap:6px;justify-content:center">
            <!-- زر مستقل: نقل للراجعات -->
            <form method="post" action="/sales/<%= s.id %>/return" onsubmit="return confirm('نقل العملية إلى قائمة الراجعات؟')">
              <button class="btn secondary"><i class="fa fa-arrow-rotate-left"></i> نقل للراجعات</button>
            </form>

            <!-- حذف نهائي -->
            <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف نهائي؟ لا يمكن التراجع.')">
              <button class="btn danger"><i class="fa fa-trash"></i> حذف نهائي</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!sales.length){ %><tr><td colspan="15" class="muted">لا توجد عمليات بعد.</td></tr><% } %>
    </tbody>
  </table>
</div>

<script>
  // تجميع IDs المحددة في فورمَي النقل والحذف
  (function(){
    const all = document.getElementById('checkAll');
    const checks = () => [...document.querySelectorAll('.rowChk')];
    if (all) all.addEventListener('change',()=>checks().forEach(c=>c.checked=all.checked));

    function fillHidden(){
      const ids = checks().filter(c=>c.checked).map(c=>c.value);
      document.getElementById('bulkReturnIds').value = ids.join(',');
      document.getElementById('bulkDeleteIds').value = ids.join(',');
    }
    document.getElementById('bulkReturnForm').addEventListener('submit', fillHidden);
    document.getElementById('bulkDeleteForm').addEventListener('submit', fillHidden);
  })();

  // قائمة حالة التوصيل
  function toggleMenu(el){
    const menu = el.parentElement.querySelector('.status-menu');
    menu.style.display = (menu.style.display==='block' ? 'none' : 'block');
    document.addEventListener('click', function once(e){
      if (!el.parentElement.contains(e.target)){ menu.style.display='none'; document.removeEventListener('click', once); }
    });
  }
</script>
