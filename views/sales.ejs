<!-- views/sales.ejs -->

<div class="container my-4">

  <!-- بيانات الزبون -->
  <form id="multiSaleForm" action="/sales/multi" method="post" class="card p-3 shadow-sm rounded-3">
    <h4 class="mb-3">🛒 إضافة عملية بيع (عدّة منتجات)</h4>

    <div class="row g-2 mb-3">
      <div class="col-md-3">
        <input name="customer_name" class="form-control" placeholder="اسم الزبون">
      </div>
      <div class="col-md-3">
        <input name="customer_phone" class="form-control" placeholder="الهاتف">
      </div>
      <div class="col-md-3">
        <input name="customer_city" class="form-control" placeholder="المدينة">
      </div>
      <div class="col-md-3">
        <input name="order_note" class="form-control" placeholder="ملاحظة عامة للطلب">
      </div>
    </div>

    <!-- جدول البنود -->
    <div class="table-responsive border rounded-3">
      <table class="table align-middle m-0">
        <thead class="table-light">
          <tr class="text-center">
            <th style="width:34%">المنتج</th>
            <th style="width:10%">كمية</th>
            <th style="width:12%">سعر بيع (₪)</th>
            <th style="width:12%">سعر أصلي (₪)</th>
            <th style="width:10%">شحن (₪)</th>
            <th style="width:14%">ملاحظة</th>
            <th style="width:8%">حذف</th>
          </tr>
        </thead>
        <tbody id="cartBody"></tbody>
      </table>
    </div>

    <div class="d-flex gap-2 mt-3">
      <button type="button" id="btnAddRow" class="btn btn-primary">
        <i class="fa fa-plus"></i> إضافة بند
      </button>
      <button type="button" id="btnClear" class="btn btn-danger">
        <i class="fa fa-trash"></i> إفراغ السلة
      </button>
      <button type="submit" class="btn btn-success ms-auto">
        <i class="fa fa-save"></i> حفظ البنود
      </button>
    </div>

    <!-- ملخص -->
    <div class="row mt-3">
      <div class="col-md-4 ms-auto">
        <div class="card p-3">
          <div class="d-flex justify-content-between">
            <span>الإيراد الكلي:</span>
            <strong id="sumRevenue">0.00 ₪</strong>
          </div>
          <div class="d-flex justify-content-between">
            <span>الربح الكلي:</span>
            <strong id="sumProfit">0.00 ₪</strong>
          </div>
          <small class="text-muted mt-2 d-block">
            الربح = (الكمية × سعر البيع) − (الكمية × السعر الأصلي) − الشحن
          </small>
        </div>
      </div>
    </div>
  </form>

  <hr class="my-4">

  <!-- الطلبات المفتوحة (من السيرفر: openOrders) -->
  <h5 class="mb-3">الطلبات المفتوحة</h5>
  <div class="list-group">
    <% (openOrders||[]).forEach(o => { %>
      <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="/orders/<%= o.id %>">
        <div>
          #<%= o.id %> — <%= o.customer_name || 'بدون اسم' %>
          — <small class="text-muted"><%= dayjs(o.created_at).format('YYYY-MM-DD HH:mm') %></small>
        </div>
        <span class="badge bg-secondary"><%= o.status %></span>
      </a>
    <% }) %>
    <% if(!(openOrders||[]).length){ %>
      <div class="text-muted">لا توجد طلبات مفتوحة مؤخّرًا.</div>
    <% } %>
  </div>

</div>

<script>
  // بيانات المنتجات من السيرفر
  const PRODUCTS = <%- JSON.stringify(products || []) %>;

  const cartBody   = document.getElementById('cartBody');
  const sumRevenue = document.getElementById('sumRevenue');
  const sumProfit  = document.getElementById('sumProfit');
  const btnAddRow  = document.getElementById('btnAddRow');
  const btnClear   = document.getElementById('btnClear');

  function fmt(n){ return (Number(n)||0).toFixed(2) + ' ₪'; }

  function buildProductSelect(){
    const sel = document.createElement('select');
    sel.className = 'form-select';
    sel.name = 'product_id[]';
    sel.required = true;

    const opt0 = new Option('— اختر —', '');
    sel.appendChild(opt0);

    PRODUCTS.forEach(p => {
      const t = `${p.name} ${p.stock>0?`(مخزون: ${p.stock})`:''}`;
      const o = new Option(t, p.id);
      o.dataset.price = p.sale_price;
      o.dataset.cost  = p.cost_price;
      sel.appendChild(o);
    });

    sel.addEventListener('change', () => {
      const o = sel.selectedOptions[0];
      const tr = sel.closest('tr');
      tr.querySelector('[name="sale_price[]"]').value = o?.dataset?.price || 0;
      tr.querySelector('[name="cost_price[]"]').value = o?.dataset?.cost  || 0;
      recalc();
    });
    return sel;
  }

  function addRow(pref = {}){
    const tr = document.createElement('tr');
    tr.className = 'align-middle';

    tr.innerHTML = `
      <td></td>
      <td class="text-center"><input name="quantity[]" type="number" min="1" value="${pref.quantity||1}" class="form-control text-center"></td>
      <td><input name="sale_price[]" type="number" step="0.01" class="form-control text-center" value="${pref.sale_price||''}"></td>
      <td><input name="cost_price[]" type="number" step="0.01" class="form-control text-center" value="${pref.cost_price||''}"></td>
      <td><input name="shipping_cost[]" type="number" step="0.01" class="form-control text-center" value="${pref.shipping_cost||0}"></td>
      <td><input name="item_note[]" class="form-control" value="${pref.item_note||''}"></td>
      <td class="text-center">
        <button type="button" class="btn btn-outline-danger btn-sm btnDel"><i class="fa fa-times"></i></button>
      </td>
    `;

    tr.children[0].appendChild(buildProductSelect());
    tr.querySelectorAll('input').forEach(inp => inp.addEventListener('input', recalc));
    tr.querySelector('.btnDel').addEventListener('click', () => { tr.remove(); recalc(); });

    cartBody.appendChild(tr);
    recalc();
  }

  function recalc(){
    let revenue = 0, profit = 0;
    cartBody.querySelectorAll('tr').forEach(tr => {
      const qty   = Number(tr.querySelector('[name="quantity[]"]').value || 0);
      const sp    = Number(tr.querySelector('[name="sale_price[]"]').value || 0);
      const cp    = Number(tr.querySelector('[name="cost_price[]"]').value || 0);
      const ship  = Number(tr.querySelector('[name="shipping_cost[]"]').value || 0);
      revenue += qty * sp;
      profit  += (qty*sp) - (qty*cp) - ship;
    });
    sumRevenue.textContent = fmt(revenue);
    sumProfit.textContent  = fmt(profit);
  }

  btnAddRow.addEventListener('click', () => addRow());
  btnClear.addEventListener('click', () => { cartBody.innerHTML = ''; recalc(); });

  // صف ابتدائي
  addRow();
</script>
