<link rel="stylesheet" href="<%= faLink %>">

<style>
  .items-grid{width:100%;border:1px solid var(--border);border-radius:12px;overflow:hidden}
  .items-grid thead th{background:#feeef5;text-align:center;padding:10px}
  .items-grid td{padding:8px;border-top:1px solid #f1f5f9;text-align:center;vertical-align:middle}
  .pick-btn{white-space:nowrap}
  .thumb{width:48px;height:48px;border-radius:10px;border:1px solid var(--border);object-fit:cover;background:#fff}
  .row-actions{display:flex;gap:6px;justify-content:center}
  .xbtn{background:#ef4444;color:#fff;border:0;border-radius:10px;padding:8px 10px;cursor:pointer}
  .plusbtn{background:#2563eb;color:#fff;border:0;border-radius:10px;padding:8px 10px;cursor:pointer}
  .mini-tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:999px;background:#fff7fb;font-size:.8rem}
  .status-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-weight:700;border:1px solid var(--border);cursor:pointer}
  .status-wrap{position:relative;display:inline-block}
  .status-menu{position:absolute;inset:auto auto auto 0;transform:translateY(6px);background:#fff;border:1px solid var(--border);border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.08);min-width:180px;padding:6px;z-index:30;display:none}
  .status-menu button{width:100%;text-align:right;background:#fff;color:#111;border:0;padding:8px 10px;border-radius:8px;cursor:pointer}
  .status-menu button:hover{background:#f8fafc}

  .modal{position:fixed;inset:0;display:none;z-index:90}
  .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.4)}
  .modal-card{position:absolute;inset:4% 3%;background:#fff;border-radius:16px;border:1px solid var(--border);display:flex;flex-direction:column}
  .mclose{position:absolute;inset-block-start:10px;inset-inline-start:10px;width:38px;height:38px;border:0;border-radius:999px;background:#ef4444;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.15);z-index:5}
  .mhead{display:flex;gap:10px;align-items:center;padding:12px;position:relative;padding-inline-start:56px}
  .mgrid{padding:14px;overflow:auto;display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
  @media(max-width:1200px){.mgrid{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:900px){.mgrid{grid-template-columns:repeat(2,1fr)}}
  .pcard{border:1px solid var(--border);border-radius:14px;padding:10px;display:flex;flex-direction:column;gap:8px}
  .pcard img{width:100%;aspect-ratio:1/1;object-fit:cover;border:1px solid var(--border);border-radius:12px}
  .tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:999px;font-size:.8rem;background:#fff7fb;margin-inline:2px}
  .name{font-weight:800;text-align:center;min-height:48px}
</style>

<div class="card">
  <h3><i class="fa fa-cart-plus"></i> إضافة عملية بيع (عدّة منتجات)</h3>

  <form id="multiForm" method="post" action="/sales/multi" class="form-grid" style="grid-template-columns: 1fr 1fr; gap:14px">
    <!-- بيانات الزبون -->
    <div><label>اسم الزبون</label><input type="text" name="customer_name" placeholder=""></div>
    <div><label>الهاتف</label><input type="text" name="customer_phone" placeholder=""></div>
    <div><label>المدينة</label><input type="text" name="customer_city" placeholder=""></div>
    <div class="right">
      <!-- أزرار تنقّل واضحة -->
      <a class="btn add" href="/orders"><i class="fa fa-basket-shopping"></i> الطلبات</a>
      <a class="btn save" href="/sales"><i class="fa fa-tags"></i> المبيعات</a>
    </div>

    <!-- جدول البنود -->
    <div style="grid-column: span 2;">
      <table class="items-grid" id="itemsTable">
        <thead>
          <tr>
            <th>المنتج</th>
            <th>كمية</th>
            <th>سعر بيع (₪)</th>
            <th>سعر أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>إجراء</th>
          </tr>
        </thead>
        <tbody id="itemsBody"></tbody>
      </table>
      <div class="row right" style="margin-top:8px">
        <button class="plusbtn" type="button" id="addRow"><i class="fa fa-plus"></i> إضافة سطر</button>
      </div>
    </div>

    <div class="right" style="grid-column: span 2;">
      <button class="btn save" type="submit"><i class="fa fa-plus"></i> إضافة البنود</button>
    </div>
  </form>
</div>

<!-- ===== قسم جديد: إضافة المنتجات إلى طلب ===== -->
<div class="card">
  <h3 style="margin:0 0 8px"><i class="fa fa-basket-shopping"></i> إضافة المنتجات إلى طلب</h3>

  <form id="orderForm" method="post" class="form-grid" style="grid-template-columns:1fr 1fr; gap:14px">
    <!-- اختيار طلب مفتوح -->
    <div style="grid-column: span 2;">
      <label>اختر طلب مفتوح (اختياري)</label>
      <select id="orderSelect">
        <option value="">— بدون اختيار (إنشاء طلب جديد) —</option>
        <% (openOrders||[]).forEach(o=>{ %>
          <option value="<%= o.id %>">#<%= o.id %> — <%= o.customer_name||'—' %> — <%= o.status %></option>
        <% }) %>
      </select>
      <div class="muted-sm">لو تركته فاضي، رح ننشئ طلب جديد بهذه البنود.</div>
    </div>

    <!-- إنشاء سريع لطلب جديد (لو ما اخترت طلب) -->
    <div><label>اسم الزبون (جديد)</label><input name="customer_name" placeholder=""></div>
    <div><label>الهاتف</label><input name="customer_phone" placeholder=""></div>
    <div><label>المدينة</label><input name="customer_city" placeholder=""></div>
    <div style="grid-column: span 2;"><label>ملاحظة</label><input name="note" placeholder=""></div>

    <!-- جدول البنود للطلب -->
    <div style="grid-column: span 2;">
      <table class="items-grid">
        <thead>
          <tr>
            <th>المنتج</th>
            <th>كمية</th>
            <th>سعر بيع (₪)</th>
            <th>سعر أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>إجراء</th>
          </tr>
        </thead>
        <tbody id="orderItemsBody"></tbody>
      </table>
      <div class="row right" style="margin-top:8px">
        <button class="plusbtn" type="button" id="addOrderRow"><i class="fa fa-plus"></i> إضافة سطر</button>
      </div>
    </div>

    <div class="right" style="grid-column: span 2;">
      <button class="btn save" type="submit"><i class="fa fa-floppy-disk"></i> حفظ البنود للطلب</button>
    </div>
  </form>
</div>

<!-- ===== سجل المعاملات ===== -->
<div class="card">
  <div class="row" style="justify-content:space-between;align-items:center">
    <h3 style="margin:0"><i class="fa fa-arrows-rotate"></i> سجل المعاملات</h3>

    <!-- تنقّل: تمت إزالة زر "الكل" حسب طلبك -->
    <div class="row" style="gap:8px">
      <a class="btn add" href="/orders"><i class="fa fa-basket-shopping"></i> الطلبات</a>
      <a class="btn save" href="/sales"><i class="fa fa-tags"></i> المبيعات</a>
    </div>
  </div>

  <div class="row" style="margin:8px 0;gap:10px;align-items:center">
    <label class="row select-all" style="gap:6px">
      <input type="checkbox" id="checkAll"> تحديد الكل
    </label>

    <form method="post" action="/sales/bulk-return" id="bulkReturnForm"
          onsubmit="return confirm('نقل العمليات المحددة إلى قائمة الراجعات؟')">
      <input type="hidden" name="ids" id="bulkReturnIds">
      <button class="btn secondary" type="submit"><i class="fa fa-arrow-rotate-left"></i> نقل المحدد إلى الراجعات</button>
    </form>

    <form method="post" action="/sales/bulk-delete" id="bulkDeleteForm"
          onsubmit="return confirm('حذف نهائي للعمليات المحددة؟ لا يمكن التراجع.')">
      <input type="hidden" name="ids" id="bulkDeleteIds">
      <button class="btn danger" type="submit"><i class="fa fa-trash"></i> حذف المحدد نهائيًا</button>
    </form>
  </div>

  <table>
    <thead>
      <tr>
        <th></th>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الزبون</th>
        <th>هاتف</th>
        <th>المدينة</th>
        <th>كمية</th>
        <th>السعر الأصلي (₪)</th>
        <th>سعر بيع (₪)</th>
        <th>شحن (₪)</th>
        <th>الربح (₪)</th>
        <th>المطلوب (₪)</th>
        <th>التوصيل</th>
        <th>تعديل</th>
        <th>إجراء</th>
      </tr>
    </thead>
    <tbody id="txBody">
      <% sales.forEach(s=> {
           const qty       = Number(s.quantity);
           const price     = Number(s.sale_price);
           const costUnit  = Number(s.cost_price);
           const ship      = Number(s.shipping_cost||0);
           const revenue   = price * qty;
           const requested = revenue + ship;
           const profit    = revenue - (costUnit*qty); // <-- الربح بدون الشحن
      %>
        <tr data-status="<%= (s.delivery_status || 'pending') %>">
          <td><input type="checkbox" class="rowChk" value="<%= s.id %>"></td>
          <td>
            <%= (dayjs && dayjs.tz)
                  ? dayjs(s.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A')
                  : (new Date(s.sold_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'})
            %>
          </td>
          <td style="text-align:right">
            <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
              <div class="thumb" style="display:flex;align-items:center;justify-content:center;overflow:hidden">
                <% if (s.product_image) { %>
                  <img src="<%= s.product_image %>" class="js-img" style="width:100%;height:100%;object-fit:cover" alt="">
                <% } %>
              </div>
              <div style="max-width:420px"><%= s.product_name %></div>
            </div>
          </td>
          <td><%= s.customer_name || '—' %></td>
          <td><%= s.customer_phone || '—' %></td>
          <td><%= s.customer_city || '—' %></td>
          <td><%= qty %></td>
          <td>₪<%= costUnit.toFixed(2) %></td>
          <td>₪<%= price.toFixed(2) %></td>
          <td>₪<%= ship.toFixed(2) %></td>
          <td>₪<%= profit.toFixed(2) %></td>
          <td><b>₪<%= requested.toFixed(2) %></b></td>
          <td>
            <div class="status-wrap">
              <div class="status-chip status-<%= s.delivery_status %>" onclick="toggleMenu(this)">
                <% if (s.delivery_status==='delivered'){ %><i class="fa fa-check"></i><span>تم التسليم</span>
                <% } else if (s.delivery_status==='failed'){ %><i class="fa fa-xmark"></i><span>فشل/لم يتم</span>
                <% } else if (s.delivery_status==='shipping'){ %><i class="fa fa-truck"></i><span>قيد التوصيل</span>
                <% } else { %><i class="fa fa-hourglass-half"></i><span>قيد المعالجة</span><% } %>
              </div>
              <div class="status-menu">
                <% ['pending','shipping','delivered','failed'].forEach(st=>{ %>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="<%= st %>">
                  <button type="submit">
                    <i class="fa <%= st==='pending'?'fa-hourglass-half':st==='shipping'?'fa-truck':st==='delivered'?'fa-check':'fa-xmark' %>"></i>
                    <%= st==='pending'?'قيد المعالجة':st==='shipping'?'قيد التوصيل':st==='delivered'?'تم التسليم':'فشل/لم يتم' %>
                  </button>
                </form>
                <% }) %>
              </div>
            </div>
          </td>
          <td><a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i> تعديل</a></td>
          <td class="row-actions">
            <form method="post" action="/sales/<%= s.id %>/return" onsubmit="return confirm('نقل العملية إلى قائمة الراجعات؟')">
              <button class="btn secondary" type="submit"><i class="fa fa-arrow-rotate-left"></i> للراجعات</button>
            </form>
            <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف نهائي؟ لا يمكن التراجع.')">
              <button class="btn danger" type="submit"><i class="fa fa-trash"></i> حذف</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!sales.length){ %><tr><td colspan="15" class="muted">لا توجد عمليات بعد.</td></tr><% } %>
    </tbody>
  </table>
</div>

<!-- ===== مودال اختيار المنتج (مستخدم للقسمين) ===== -->
<div class="modal" id="pickerModal" aria-hidden="true">
  <div class="modal-bg"></div>
  <div class="modal-card">
    <button type="button" id="pickerClose" class="mclose" aria-label="إغلاق">
      <i class="fa fa-xmark"></i>
    </button>

    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <div style="font-weight:800">اختيار منتج من الشبكة</div>
      <input id="searchBox" placeholder="ابحث بالاسم..." class="right" style="max-width:320px">
    </div>

    <div class="mgrid" id="gridWrap">
      <% products.forEach(p=>{ %>
        <div class="pcard" data-id="<%= p.id %>"
             data-name="<%- p.name %>"
             data-img="<%= p.image_path||'' %>"
             data-sale="<%= Number(p.sale_price||0) %>"
             data-cost="<%= Number(p.cost_price||0) %>"
             data-stock="<%= Number(p.stock||0) %>">
          <img src="<%= p.image_path||'' %>" alt="">
          <div class="name"><%= p.name %></div>
          <div style="text-align:center">
            <span class="tag">بيع: ₪<%= Number(p.sale_price||0).toFixed(2) %></span>
            <span class="tag">أصلي: ₪<%= Number(p.cost_price||0).toFixed(2) %></span>
            <span class="tag">مخزون: <%= Number(p.stock||0) %></span>
          </div>
          <button class="btn add pickBtn" type="button"><i class="fa fa-check"></i> اختيار</button>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
(function(){
  // ===== Util لإنشاء خلايا / مدخلات =====
  function tcell(el, first){ const td=document.createElement('td'); if(first){td.style.textAlign='right'} td.appendChild(el); return td; }
  function input(type,name,val,attrs){
    const i=document.createElement('input'); i.type=type; i.name=name; i.value = (val??'');
    Object.entries(attrs||{}).forEach(([k,v])=>i.setAttribute(k,v)); return i;
  }
  function selectProduct(name){
    const sel=document.createElement('button'); sel.type='button'; sel.className='btn add pick-btn'; sel.textContent='اختيار';
    const display=document.createElement('div'); display.style.minWidth='180px'; display.style.textAlign='right';
    display.textContent='— لم يتم الاختيار —';
    const wrap=document.createElement('div'); wrap.className='row'; wrap.style.justifyContent='flex-start'; wrap.appendChild(display); wrap.appendChild(sel);
    const hidden=document.createElement('input'); hidden.type='hidden'; hidden.name=name;

    // فتح المودال وملء البيانات
    sel.addEventListener('click',()=>{ openPicker((p)=>{ hidden.value=p.id; display.textContent=p.name; sale.value=p.sale; cost.value=p.cost; }); });

    // placeholders (sale/cost يحتاجان الوصول)
    const sale = input('number','sale_price', '', {step:'0.01'});
    const cost = input('number','cost_price','', {step:'0.01'});

    return {cell:tcell(wrap,true), hidden, sale, cost, display};
  }

  // ====== القسم الأول (بيع مباشر) ======
  const itemsBody = document.getElementById('itemsBody');
  document.getElementById('addRow').addEventListener('click', ()=> addRow(itemsBody, 'product_id'));
  function addRow(tbody, productField){
    const tr=document.createElement('tr');

    // منتج (زر اختيار)
    const p = selectProduct(productField);
    tr.appendChild(p.cell);

    // كمية/أسعار/شحن/ملاحظة
    const qty = input('number','quantity','1',{min:'1',step:'1'});
    const sale= p.sale; sale.name='sale_price';
    const cost= p.cost; cost.name='cost_price';
    const ship= input('number','shipping_cost','0',{step:'0.01'});
    const note= input('text','item_note','',{});

    tr.appendChild(tcell(qty));
    tr.appendChild(tcell(sale));
    tr.appendChild(tcell(cost));
    tr.appendChild(tcell(ship));
    tr.appendChild(tcell(note));

    // حذف
    const del=document.createElement('button'); del.type='button'; del.className='xbtn'; del.innerHTML='حذف';
    del.addEventListener('click',()=>tr.remove());
    tr.appendChild(tcell(del));

    // hidden for product id
    tr.appendChild(p.hidden);
    tbody.appendChild(tr);
  }
  // أول صف افتراضي
  addRow(itemsBody,'product_id');

  // ====== القسم الثاني (إضافة إلى طلب) ======
  const orderItemsBody = document.getElementById('orderItemsBody');
  document.getElementById('addOrderRow').addEventListener('click', ()=> addRow(orderItemsBody,'product_id[]'));
  // صف افتراضي
  addRow(orderItemsBody,'product_id[]');

  // تبديل الإرسال حسب اختيار الطلب
  const orderForm = document.getElementById('orderForm');
  orderForm.addEventListener('submit', function(e){
    const orderId = document.getElementById('orderSelect').value.trim();
    if(orderId){
      // إرسال إلى bulk-update للطلب المحدد
      orderForm.action = `/orders/${orderId}/items/bulk-update`;
    }else{
      // إنشاء طلب جديد بهذه البنود
      orderForm.action = `/orders`;
    }
  });

  // ===== مودال اختيار المنتج =====
  const modal=document.getElementById('pickerModal');
  const bg=modal.querySelector('.modal-bg');
  const closeBtn=document.getElementById('pickerClose');
  const search=document.getElementById('searchBox');
  const cards=[...modal.querySelectorAll('.pcard')];

  function openPicker(cb){
    modal.style.display='block'; search.value=''; filter('');
    const onPick = (e)=>{
      const card=e.currentTarget.closest('.pcard');
      const p={ id:card.dataset.id, name:card.dataset.name, sale:card.dataset.sale, cost:card.dataset.cost };
      cb(p);
      hide();
    };
    cards.forEach(c=>{
      let btn=c.querySelector('.pickBtn');
      if(!btn){ btn=document.createElement('button'); btn.type='button'; btn.className='btn add pickBtn'; btn.textContent='اختيار'; c.appendChild(btn); }
      btn.onclick=onPick;
    });
    search.oninput = ()=> filter(search.value);
  }
  function hide(){ modal.style.display='none'; }
  function filter(q){
    const k=(q||'').toLowerCase();
    cards.forEach(c=>{
      const n=(c.dataset.name||'').toLowerCase();
      c.style.display = n.includes(k) ? '' : 'none';
    });
  }
  bg.addEventListener('click', hide);
  closeBtn.addEventListener('click', hide);

  // ===== تحديد الكل للجدول السفلي =====
  const checkAll = document.getElementById('checkAll');
  const body = document.getElementById('txBody');
  if(checkAll){
    checkAll.addEventListener('change', ()=>{
      body.querySelectorAll('.rowChk').forEach(ch=> ch.checked = checkAll.checked);
      collectBulk();
    });
  }
  body.addEventListener('change', (e)=>{
    if(e.target.classList.contains('rowChk')) collectBulk();
  });
  function collectBulk(){
    const ids=[...body.querySelectorAll('.rowChk:checked')].map(i=>i.value);
    document.getElementById('bulkReturnIds').value = ids.join(',');
    document.getElementById('bulkDeleteIds').value = ids.join(',');
  }

  // قائمة حالة التوصيل
  window.toggleMenu = function(el){
    const menu = el.parentElement.querySelector('.status-menu');
    menu.style.display = (menu.style.display==='block') ? 'none' : 'block';
    document.addEventListener('click', (ev)=>{
      if(!menu.contains(ev.target) && !el.contains(ev.target)) menu.style.display='none';
    }, {once:true});
  }
})();
</script>
