<link rel="stylesheet" href="<%= faLink %>">

<!-- (اختياري) تحسينات بسيطة محلية لو ما كانت موجودة بالـ layout -->
<style>
  .thumb{width:64px;height:64px;border-radius:10px;border:1px solid var(--border);object-fit:cover;background:#fff}
  .status-chip{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;font-weight:700;border:1px solid var(--border);cursor:pointer}
  .status-pending{background:#fff7e6}.status-shipping{background:#fff3cd}
  .status-delivered{background:#e6ffed}.status-failed{background:#ffe6e6}
  .status-wrap{position:relative;display:inline-block}
  .status-menu{position:absolute;inset:auto auto auto 0;transform:translateY(6px);background:#fff;border:1px solid var(--border);border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,.08);min-width:180px;padding:6px;z-index:30;display:none}
  .status-menu button{width:100%;text-align:right;background:#fff;color:#111;border:0;padding:8px 10px;border-radius:8px;cursor:pointer}
  .status-menu button:hover{background:#f8fafc}

  .modal{position:fixed;inset:0;display:none;z-index:90}
  .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.4)}
  .modal-card{position:absolute;inset:4% 3%;background:#fff;border-radius:16px;border:1px solid var(--border);display:flex;flex-direction:column}
  .mclose{position:absolute;inset-block-start:10px;inset-inline-start:10px;width:38px;height:38px;border:0;border-radius:999px;background:#ef4444;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.15);z-index:5}
  .mhead{display:flex;gap:10px;align-items:center;padding:12px 12px 12px 56px;border-bottom:1px solid #f1f5f9}
  .mgrid{padding:14px;overflow:auto;display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
  @media(max-width:1200px){.mgrid{grid-template-columns:repeat(4,1fr)}}
  @media(max-width:900px){.mgrid{grid-template-columns:repeat(2,1fr)}}
  .pcard{border:1px solid var(--border);border-radius:14px;padding:10px;display:flex;flex-direction:column;gap:8px}
  .pcard img{width:100%;aspect-ratio:1/1;object-fit:cover;border:1px solid var(--border);border-radius:12px}
  .tag{display:inline-block;padding:2px 8px;border:1px solid var(--border);border-radius:999px;font-size:.8rem;background:#fff7fb;margin-inline:2px}
  .name{font-weight:800;text-align:center;min-height:48px}
</style>

<div class="card">
  <h3><i class="fa fa-cart-plus"></i> إضافة عملية بيع</h3>

  <!-- نموذج الإضافة -->
  <form method="post" action="/sales" class="form-grid" style="grid-template-columns: 1fr 1fr; gap:14px">
    <!-- اختيار المنتج عبر مودال -->
    <div style="grid-column: span 2;">
      <label>المنتج</label>
      <div class="row" style="gap:8px">
        <input id="productNameDisplay" placeholder="اختر منتج..." readonly style="flex:1">
        <input type="hidden" id="productIdField" name="product_id" required>
        <button id="openPicker" class="btn add" type="button"><i class="fa fa-grid-2"></i> اختيار المنتج</button>
      </div>

      <!-- معاينة مصغّرة للمنتج المختار -->
      <div id="miniPreview" class="row" style="display:none; margin-top:10px; gap:10px; align-items:center">
        <div class="thumb" style="width:56px;height:56px;display:flex;align-items:center;justify-content:center;overflow:hidden">
          <img id="miniImg" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none">
        </div>
        <div style="font-weight:700" id="miniName"></div>
        <span class="tag">مخزون: <b id="miniStock"></b></span>
        <span class="tag">بيع: ₪<b id="miniSale"></b></span>
        <span class="tag">أصلي: ₪<b id="miniCost"></b></span>
      </div>
    </div>

    <div>
      <label>الكمية</label>
      <input id="qtyInput" type="number" name="quantity" value="1" min="1" step="1" required>
    </div>
    <div>
      <label>سعر البيع (₪)</label>
      <input id="salePriceInput" type="number" name="sale_price" step="0.01" required>
    </div>
    <div>
      <label>السعر الأصلي (₪)</label>
      <input id="costPriceInput" type="number" name="cost_price" step="0.01" required>
    </div>
    <div>
      <label>الشحن (₪)</label>
      <input type="number" name="shipping_cost" step="0.01" value="0">
    </div>

    <div>
      <label>اسم الزبون</label>
      <input type="text" name="customer_name" placeholder="">
    </div>
    <div>
      <label>هاتف</label>
      <input type="text" name="customer_phone" placeholder="">
    </div>
    <div>
      <label>المدينة</label>
      <input type="text" name="customer_city" placeholder="">
    </div>

    <div style="grid-column: span 2;">
      <label>ملاحظة (اختياري)</label>
      <textarea name="note" rows="2" placeholder=""></textarea>
    </div>

    <!-- تجميع كبنود ضمن طلب -->
    <div style="grid-column: span 2; border-top:1px dashed #f1f5f9; padding-top:10px">
      <label class="row" style="gap:8px;align-items:center">
        <input type="checkbox" name="as_order" id="asOrderChk">
        <span>ضمّ هذه العملية ضمن <b>طلب</b> (ينشأ تلقائيًا حسب رقم الهاتف إن لم تُحدّد)</span>
      </label>

      <% if (typeof openOrders !== 'undefined' && openOrders.length) { %>
        <div class="row" style="gap:8px; margin-top:8px">
          <select name="order_id" id="orderSel" disabled style="min-width:280px">
            <option value="">— اختيار طلب مفتوح (اختياري) —</option>
            <% openOrders.forEach(o=>{ %>
              <option value="<%= o.id %>">#<%= o.id %> — <%= o.customer_name||'بدون اسم' %> — <%= o.customer_phone||'—' %> — <%= o.status==='shipping'?'قيد التوصيل':'قيد المعالجة' %></option>
            <% }) %>
          </select>
          <span class="muted">لو تركته فارغًا ومعك رقم هاتف: رح نلحقها تلقائيًا بأقرب طلب مفتوح لنفس الرقم خلال 48 ساعة، أو ننشئ واحد جديد.</span>
        </div>
      <% } else { %>
        <div class="muted" style="margin-top:6px">ما في طلبات مفتوحة حالياً. إذا فعلت الخيار، رح ننشئ طلب جديد تلقائيًا.</div>
      <% } %>
    </div>

    <div class="right" style="grid-column: span 2;">
      <button class="btn save" type="submit"><i class="fa fa-plus"></i> إضافة بيع</button>
    </div>
  </form>
</div>

<div class="card">
  <div class="row" style="justify-content:space-between;align-items:center">
    <h3 style="margin:0"><i class="fa fa-arrows-rotate"></i> سجل المعاملات</h3>

    <!-- فلاتر العرض: الواجهة فقط -->
    <div class="row" style="gap:8px">
      <button id="filterAll" class="btn secondary" type="button">الكل</button>
      <button id="filterOrders" class="btn add" type="button">الطلبات</button>
      <button id="filterSales" class="btn save" type="button">المبيعات</button>
    </div>
  </div>

  <!-- أدوات جماعية أعلى الجدول -->
  <div class="row" style="margin:8px 0;gap:10px;align-items:center">
    <label class="row select-all" style="gap:6px">
      <input type="checkbox" id="checkAll"> تحديد الكل
    </label>

    <form method="post" action="/sales/bulk-return" id="bulkReturnForm"
          onsubmit="return confirm('نقل العمليات المحددة إلى قائمة الراجعات؟')">
      <input type="hidden" name="ids" id="bulkReturnIds">
      <button class="btn secondary" type="submit"><i class="fa fa-arrow-rotate-left"></i> نقل المحدد إلى الراجعات</button>
    </form>

    <form method="post" action="/sales/bulk-delete" id="bulkDeleteForm"
          onsubmit="return confirm('حذف نهائي للعمليات المحددة؟ لا يمكن التراجع.')">
      <input type="hidden" name="ids" id="bulkDeleteIds">
      <button class="btn danger" type="submit"><i class="fa fa-trash"></i> حذف المحدد نهائيًا</button>
    </form>
  </div>

  <table>
    <thead>
      <tr>
        <th></th>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الزبون</th>
        <th>هاتف</th>
        <th>المدينة</th>
        <th>كمية</th>
        <th>السعر الأصلي (₪)</th>
        <th>سعر بيع (₪)</th>
        <th>شحن (₪)</th>
        <th>الربح (₪)</th>
        <th>المطلوب (₪)</th>
        <th>التوصيل</th>
        <th>تعديل</th>
        <th>إجراء</th>
      </tr>
    </thead>
    <tbody id="txBody">
      <% sales.forEach(s=> {
           const qty       = Number(s.quantity);
           const price     = Number(s.sale_price);
           const costUnit  = Number(s.cost_price);
           const ship      = Number(s.shipping_cost||0);
           const revenue   = price * qty;
           const requested = revenue + ship;
           const profit    = revenue - (costUnit*qty) - ship;
           const status    = (s.delivery_status || 'pending');
      %>
        <tr data-status="<%= status %>">
          <td><input type="checkbox" class="rowChk" value="<%= s.id %>"></td>
          <td>
            <%= (dayjs && dayjs.tz)
                  ? dayjs(s.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A')
                  : (new Date(s.sold_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'})
            %>
          </td>

          <td style="text-align:right">
            <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
              <div class="thumb" style="display:flex;align-items:center;justify-content:center;overflow:hidden">
                <% if (s.product_image) { %>
                  <img src="<%= s.product_image %>" class="js-img" style="width:100%;height:100%;object-fit:cover" alt="">
                <% } %>
              </div>
              <div style="max-width:420px"><%= s.product_name %></div>
            </div>
          </td>

          <td><%= s.customer_name || '—' %></td>
          <td><%= s.customer_phone || '—' %></td>
          <td><%= s.customer_city || '—' %></td>

          <td><%= qty %></td>
          <td>₪<%= costUnit.toFixed(2) %></td>
          <td>₪<%= price.toFixed(2) %></td>
          <td>₪<%= ship.toFixed(2) %></td>
          <td>₪<%= profit.toFixed(2) %></td>
          <td><b>₪<%= requested.toFixed(2) %></b></td>

          <td>
            <div class="status-wrap">
              <div class="status-chip status-<%= status %>" onclick="toggleMenu(this)">
                <% if (status==='delivered'){ %><i class="fa fa-check"></i><span>تم التسليم</span>
                <% } else if (status==='failed'){ %><i class="fa fa-xmark"></i><span>فشل/لم يتم</span>
                <% } else if (status==='shipping'){ %><i class="fa fa-truck"></i><span>قيد التوصيل</span>
                <% } else { %><i class="fa fa-hourglass-half"></i><span>قيد المعالجة</span><% } %>
              </div>
              <div class="status-menu">
                <% ['pending','shipping','delivered','failed'].forEach(st=>{ %>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="<%= st %>">
                  <button type="submit">
                    <i class="fa <%= st==='pending'?'fa-hourglass-half':st==='shipping'?'fa-truck':st==='delivered'?'fa-check':'fa-xmark' %>"></i>
                    <%= st==='pending'?'قيد المعالجة':st==='shipping'?'قيد التوصيل':st==='delivered'?'تم التسليم':'فشل/لم يتم' %>
                  </button>
                </form>
                <% }) %>
              </div>
            </div>
          </td>

          <td>
            <a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i><span>تعديل</span></a>
          </td>

          <td class="row" style="gap:6px;justify-content:center">
            <form method="post" action="/sales/<%= s.id %>/return" onsubmit="return confirm('نقل العملية إلى قائمة الراجعات؟')">
              <button class="btn secondary" type="submit"><i class="fa fa-arrow-rotate-left"></i><span>نقل للراجعات</span></button>
            </form>
            <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف نهائي؟ لا يمكن التراجع.')">
              <button class="btn danger" type="submit"><i class="fa fa-trash"></i><span>حذف نهائي</span></button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (!sales.length){ %><tr><td colspan="15" class="muted">لا توجد عمليات بعد.</td></tr><% } %>
    </tbody>
  </table>
</div>

<!-- مودال شبكة اختيار المنتج -->
<div class="modal" id="pickerModal" aria-hidden="true">
  <div class="modal-bg"></div>
  <div class="modal-card">
    <button type="button" id="pickerClose" class="mclose" aria-label="إغلاق">
      <i class="fa fa-xmark"></i>
    </button>

    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <div style="font-weight:800">اختيار منتج من الشبكة</div>
      <input id="searchBox" placeholder="ابحث بالاسم..." class="right" style="max-width:320px">
    </div>

    <div class="mgrid" id="gridWrap">
      <% products.forEach(p=>{ %>
        <div class="pcard" data-id="<%= p.id %>"
             data-name="<%- p.name %>"
             data-img="<%= p.image_path||'' %>"
             data-sale="<%= Number(p.sale_price||0) %>"
             data-cost="<%= Number(p.cost_price||0) %>"
             data-stock="<%= Number(p.stock||0) %>">
          <img src="<%= p.image_path||'' %>" alt="">
          <div class="name"><%= p.name %></div>
          <div style="text-align:center">
            <span class="tag">بيع: ₪<%= Number(p.sale_price||0).toFixed(2) %></span>
            <span class="tag">أصلي: ₪<%= Number(p.cost_price||0).toFixed(2) %></span>
            <span class="tag">مخزون: <%= Number(p.stock||0) %></span>
          </div>
          <button class="btn add pickBtn" type="button"><i class="fa fa-check"></i> اختيار</button>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  // تفعيل/تعطيل اختيار الطلب المفتوح بناءً على خيار "ضمّ إلى طلب"
  (function(){
    const chk = document.getElementById('asOrderChk');
    const sel = document.getElementById('orderSel');
    if (!chk || !sel) return;
    const sync = ()=> sel.disabled = !chk.checked;
    chk.addEventListener('change', sync);
    sync();
  })();

  // تحديد/إلغاء تحديد الكل + تعبئة فورمَي النقل/الحذف
  (function(){
    const all = document.getElementById('checkAll');
    const checks = () => [...document.querySelectorAll('.rowChk')];
    if (all) all.addEventListener('change',()=>checks().forEach(c=>c.checked=all.checked));
    function fillHidden(){
      const ids = checks().filter(c=>c.checked).map(c=>c.value);
      document.getElementById('bulkReturnIds').value = ids.join(',');
      document.getElementById('bulkDeleteIds').value = ids.join(',');
    }
    document.getElementById('bulkReturnForm').addEventListener('submit', fillHidden);
    document.getElementById('bulkDeleteForm').addEventListener('submit', fillHidden);
  })();

  // فلاتر المعاملات (واجهة فقط)
  (function(){
    const body  = document.getElementById('txBody');
    const rows  = Array.from(body.querySelectorAll('tr'));
    const btnAll = document.getElementById('filterAll');
    const btnOrd = document.getElementById('filterOrders');
    const btnSal = document.getElementById('filterSales');

    const isOrder = st => /^(pending|shipping)$/i.test(st||'');
    const isSale  = st => /^(delivered|failed)$/i.test(st||'');

    function show(which){
      rows.forEach(tr=>{
        const st = (tr.getAttribute('data-status')||'').toLowerCase();
        let ok = true;
        if (which==='orders') ok = isOrder(st);
        if (which==='sales')  ok = isSale(st);
        tr.style.display = ok ? '' : 'none';
      });
    }
    btnAll && (btnAll.onclick = ()=>show('all'));
    btnOrd && (btnOrd.onclick = ()=>show('orders'));
    btnSal && (btnSal.onclick = ()=>show('sales'));
  })();

  // مودال الشبكة + زر ✕ + تعبئة الحقول
  (function(){
    const modal=document.getElementById('pickerModal');
    const open=document.getElementById('openPicker');
    const bg=modal.querySelector('.modal-bg');
    const closeBtn=document.getElementById('pickerClose');
    const search=document.getElementById('searchBox');
    const cards=[...modal.querySelectorAll('.pcard')];

    function show(){ modal.style.display='block'; search.focus(); }
    function hide(){ modal.style.display='none'; search.value=''; filter(''); }

    if (open) open.addEventListener('click',show);
    bg.addEventListener('click',hide);
    closeBtn.addEventListener('click',hide);
    document.addEventListener('keydown',e=>{
      if(modal.style.display==='block' && e.key==='Escape') hide();
    });

    function filter(q){
      const s=(q||'').trim().toLowerCase();
      cards.forEach(c=>{ c.style.display=c.dataset.name.toLowerCase().includes(s)?'flex':'none'; });
    }
    search.addEventListener('input',e=>filter(e.target.value));

    // تعبئة الحقول بعد الاختيار
    const idF=document.getElementById('productIdField');
    const nameF=document.getElementById('productNameDisplay');
    const qtyI=document.getElementById('qtyInput');
    const saleI=document.getElementById('salePriceInput');
    const costI=document.getElementById('costPriceInput');

    const mini=document.getElementById('miniPreview');
    const miniImg=document.getElementById('miniImg');
    const miniName=document.getElementById('miniName');
    const miniStock=document.getElementById('miniStock');
    const miniSale=document.getElementById('miniSale');
    const miniCost=document.getElementById('miniCost');

    modal.addEventListener('click',e=>{
      const btn=e.target.closest('.pickBtn');
      if(!btn) return;
      const card=btn.closest('.pcard');
      const id=card.dataset.id, nm=card.dataset.name;
      const img=card.dataset.img||'';
      const sale=Number(card.dataset.sale||0);
      const cost=Number(card.dataset.cost||0);
      const stock=Number(card.dataset.stock||0);

      idF.value=id;
      nameF.value=nm;
      if(!saleI.value) saleI.value=sale;
      if(!costI.value) costI.value=cost;

      mini.style.display='flex';
      if(img){ miniImg.src=img; miniImg.style.display='block'; } else { miniImg.style.display='none'; }
      miniName.textContent=nm;
      miniStock.textContent=stock;
      miniSale.textContent=sale.toFixed(2);
      miniCost.textContent=cost.toFixed(2);

      hide();
      qtyI.focus();
    });
  })();

  // قائمة حالة التوصيل
  function toggleMenu(el){
    const menu = el.parentElement.querySelector('.status-menu');
    menu.style.display = (menu.style.display==='block' ? 'none' : 'block');
    document.addEventListener('click', function once(e){
      if (!el.parentElement.contains(e.target)){ menu.style.display='none'; document.removeEventListener('click', once); }
    });
  }
</script>
