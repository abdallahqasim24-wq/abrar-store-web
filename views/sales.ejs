<link rel="stylesheet" href="<%= faLink %>">

<style>
  .thumb{border-radius:10px;object-fit:cover}
  .status-chip{
    display:inline-flex; align-items:center; gap:6px;
    padding:6px 10px; border-radius:999px; font-weight:700; font-size:.85rem;
    border:1px solid var(--border); cursor:pointer; user-select:none;
  }
  .status-pending  { background:#fff7e6 }
  .status-shipping { background:#fff3cd }
  .status-delivered{ background:#e6ffed }
  .status-failed   { background:#ffe6e6 }
  .status-menu{
    position:absolute; inset:auto auto auto 0; transform:translateY(6px);
    background:#fff; border:1px solid var(--border); border-radius:10px;
    box-shadow: var(--shadow); min-width:180px; padding:6px; z-index:30; display:none;
  }
  .status-wrap{ position:relative; display:inline-block }
  .status-menu form{ margin:0 }
  .status-menu button{
    width:100%; text-align:right; background:#fff; color:#111; border:0;
    padding:8px 10px; border-radius:8px; cursor:pointer;
  }
  .status-menu button:hover{ background:#f8fafc }
  .muted-sm{ color:#6b7280; font-size:.8rem }
</style>

<div class="card">
  <h3><i class="fa fa-cart-plus"></i> تسجيل عملية بيع</h3>
  <form method="post" action="/sales" class="form-grid">
    <div>
      <label>المنتج</label>
      <select name="product_id" required>
        <option value="">اختر المنتج</option>
        <% products.forEach(p=> { %>
          <option value="<%= p.id %>"><%= p.name %> (مخزون: <%= p.stock %>)</option>
        <% }) %>
      </select>
    </div>
    <div><label>كمية</label><input type="number" name="quantity" value="1" step="1" required/></div>
    <div><label>سعر البيع</label><input type="number" name="sale_price" step="0.01"/></div>
    <div><label>السعر الأصلي</label><input type="number" name="cost_price" step="0.01"/></div>
    <div><label>تكلفة الشحن +₪</label><input type="number" name="shipping_cost" step="0.01"/></div>
    <div><label>ملاحظة</label><input type="text" name="note"/></div>

    <!-- معلومات الزبون -->
    <div><label>اسم الزبون</label><input type="text" name="customer_name" /></div>
    <div><label>رقم الهاتف</label><input type="tel" name="customer_phone" /></div>
    <div><label>المدينة/المنطقة</label><input type="text" name="customer_city" /></div>

    <div class="right"></div>
    <div class="row right">
      <button class="btn save"><i class="fa fa-check"></i> تسجيل</button>
    </div>
  </form>
</div>

<div class="card" style="margin-top:12px">
  <h3><i class="fa fa-receipt"></i> سجل المبيعات</h3>
  <table>
    <thead>
      <tr>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الزبون</th>
        <th>هاتف</th>
        <th>المدينة</th>
        <th>كمية</th>
        <th>سعر بيع (₪)</th>
        <th>المطلوب (₪)</th> <!-- = سعر*كمية + الشحن -->
        <th>السعر الأصلي (₪)</th>
        <th>شحن (₪)</th>
        <th>الربح (₪)</th>
        <th>التوصيل</th>
        <th>تعديل</th>
        <th>حذف</th>
      </tr>
    </thead>
    <tbody>
      <% sales.forEach(s=> {
           const qty       = Number(s.quantity);
           const price     = Number(s.sale_price);
           const costUnit  = Number(s.cost_price);
           const ship      = Number(s.shipping_cost||0);
           const revenue   = price * qty;
           const requested = revenue + ship;             // المطلوب من الزبون
           const profit    = revenue - (costUnit*qty) - ship;
           const status    = (s.delivery_status || 'pending');
      %>
        <tr>
          <td><%= dayjs(s.sold_at).format('YYYY-MM-DD hh:mm A') %></td>
          <td class="right">
            <% if (s.product_image) { %>
              <img src="<%= s.product_image %>" class="thumb" style="width:44px;height:44px;vertical-align:middle;margin-inline-start:6px" alt="product"/>
            <% } %>
            <%= s.product_name %>
          </td>
          <td><%= s.customer_name || '—' %></td>
          <td><%= s.customer_phone || '—' %></td>
          <td><%= s.customer_city || '—' %></td>
          <td><%= qty %></td>
          <td>₪<%= price.toFixed(2) %></td>
          <td><strong>₪<%= requested.toFixed(2) %></strong></td> <!-- المطلوب يشمل الشحن -->
          <td>₪<%= costUnit.toFixed(2) %></td>
          <td>₪<%= ship.toFixed(2) %></td>
          <td>₪<%= profit.toFixed(2) %></td>

          <td>
            <div class="status-wrap">
              <div class="status-chip status-<%= status %>" onclick="toggleMenu(this)">
                <i class="fa fa-truck-fast"></i>
                <span>
                  <%= status === 'pending'   ? 'قيد المعالجة'
                     : status === 'shipping' ? 'قيد التوصيل'
                     : status === 'delivered'? 'تم التسليم'
                     : 'فشل التوصيل' %>
                </span>
              </div>
              <div class="status-menu">
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="pending">
                  <button type="submit"><i class="fa fa-hourglass-half"></i> قيد المعالجة</button>
                </form>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="shipping">
                  <button type="submit"><i class="fa fa-truck"></i> قيد التوصيل</button>
                </form>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="delivered">
                  <button type="submit"><i class="fa fa-check"></i> تم التسليم</button>
                </form>
                <form method="post" action="/sales/<%= s.id %>/delivery">
                  <input type="hidden" name="status" value="failed">
                  <button type="submit"><i class="fa fa-xmark"></i> فشل/لم يتم</button>
                </form>
                <div class="muted-sm" style="padding:6px 8px">
                  <% if (s.delivered_at) { %>
                    آخر تسليم: <%= dayjs(s.delivered_at).format('YYYY-MM-DD hh:mm A') %>
                  <% } else { %>
                    لا يوجد وقت تسليم مسجل
                  <% } %>
                </div>
              </div>
            </div>
          </td>

          <td>
            <a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i> تعديل</a>
          </td>

          <td>
            <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف العملية؟ سيُنقل الطلب إلى قائمة الراجعات.')">
              <button class="btn danger"><i class="fa fa-trash"></i> حذف</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
  function toggleMenu(el){
    const menu = el.parentElement.querySelector('.status-menu');
    const open = menu.style.display === 'block';
    document.querySelectorAll('.status-menu').forEach(m => m.style.display='none');
    menu.style.display = open ? 'none' : 'block';
  }
  document.addEventListener('click', (e)=>{
    const wrap = e.target.closest('.status-wrap');
    if(!wrap) document.querySelectorAll('.status-menu').forEach(m => m.style.display='none');
  });
</script>
