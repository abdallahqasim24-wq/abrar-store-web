<!-- views/sales.ejs -->
<link rel="stylesheet" href="<%= faLink %>">

<div class="container page">
  <h2><i class="fa fa-cart-shopping"></i> إضافة عملية بيع (عدّة منتجات)</h2>

  <!-- نموذج البيع المتعدد -->
  <form id="multiSaleForm" action="/sales/multi" method="post" class="card">
    <div class="form-grid">
      <input name="customer_name"  placeholder="اسم الزبون">
      <input name="customer_phone" placeholder="الهاتف">
      <input name="customer_city"  placeholder="المدينة">
      <input name="order_note"     placeholder="ملاحظة عامة للطلب">
    </div>

    <div class="table-scroll" style="margin-top:10px">
      <table>
        <thead>
          <tr>
            <th>المنتج</th>
            <th>كمية</th>
            <th>سعر بيع (₪)</th>
            <th>سعر أصلي (₪)</th>
            <th>شحن (₪)</th>
            <th>ملاحظة</th>
            <th>حذف</th>
          </tr>
        </thead>
        <tbody id="cartBody"></tbody>
      </table>
    </div>

    <div class="row" style="margin-top:10px">
      <button type="button" id="btnAddRow" class="btn add"><i class="fa fa-plus"></i> إضافة بند</button>
      <button type="button" id="btnClear"  class="btn danger"><i class="fa fa-trash"></i> إفراغ السلة</button>
      <button type="submit" id="btnSubmit" class="btn save right"><i class="fa fa-save"></i> حفظ البنود</button>
    </div>

    <div class="row" style="margin-top:8px">
      <div class="card" style="margin:0">
        <div class="row">
          <b>الإيراد الكلي:</b> <span id="sumRevenue">0.00 ₪</span>
          <b style="margin-inline-start:16px">الربح الكلي:</b> <span id="sumProfit">0.00 ₪</span>
        </div>
      </div>
    </div>
  </form>

  <% if (flash) { %>
    <div class="card" style="border-color:<%= flash.type==='success'?'#bbf7d0':'#fecaca' %>">
      <b><%= flash.msg %></b>
      <% if ((flash.skipped||[]).length) { %>
        <div class="muted-sm" style="margin-top:6px">تجاوز: <%= flash.skipped.join('، ') %></div>
      <% } %>
      <% if (flash.orderId) { %>
        <div style="margin-top:8px">
          <a class="btn secondary" href="/orders/<%= flash.orderId %>"><i class="fa fa-eye"></i> فتح الطلب #<%= flash.orderId %></a>
        </div>
      <% } %>
    </div>
  <% } %>

  <hr>

  <!-- الطلبات المفتوحة (بطاقات مع أزرار الحالة بالعربي) -->
  <h2><i class="fa fa-list"></i> الطلبات المفتوحة</h2>
  <div class="cards">
    <% (openOrders||[]).forEach(o => { %>
      <div class="card">
        <div class="row" style="justify-content:space-between">
          <div>
            <b>#<%= o.id %></b> — <%= o.customer_name || 'بدون اسم' %>
            <div class="muted-sm"><i class="fa fa-clock"></i>
              <%= dayjs(o.created_at).tz('Asia/Hebron').format('YYYY-MM-DD HH:mm') %>
            </div>
          </div>
          <a class="btn secondary" href="/orders/<%= o.id %>"><i class="fa fa-pen"></i> إدارة</a>
        </div>

        <!-- شارة الحالة بالنص العربي -->
        <div style="margin:10px 0">
          <span class="status-chip status-<%= o.status %>">
            <% if(o.status==='pending'){ %><i class="fa fa-hourglass-half"></i> قيد المعالجة
            <% } else if(o.status==='processing'){ %><i class="fa fa-spinner"></i> معالجة
            <% } else if(o.status==='shipping'){ %><i class="fa fa-truck"></i> قيد التوصيل
            <% } else if(o.status==='delivered'){ %><i class="fa fa-check"></i> تم التسليم
            <% } else { %><i class="fa fa-xmark"></i> لم يتم / فشل <% } %>
          </span>
        </div>

        <!-- أزرار سريعة لتغيير الحالة -->
        <form class="row" method="post" action="/orders/<%= o.id %>/status">
          <input type="hidden" name="apply_to_items" value="on">
          <input type="hidden" name="status" value="">
          <div class="row">
            <button type="button" class="btn edit status-action" data-val="pending"   title="قيد المعالجة">⏳</button>
            <button type="button" class="btn add  status-action" data-val="shipping"  title="قيد التوصيل">🚚</button>
            <button type="button" class="btn save status-action" data-val="delivered" title="تم التسليم">✔</button>
            <button type="button" class="btn danger status-action" data-val="failed"    title="لم يتم / فشل">✖</button>
            <a href="/orders/<%= o.id %>" class="btn secondary">فتح الطلب</a>
          </div>
        </form>

        <% if ((o.items||[]).length) { %>
          <div class="table-scroll" style="margin-top:10px">
            <table>
              <thead>
                <tr><th>المنتج</th><th>كمية</th><th>سعر</th><th>شحن</th><th>الحالة</th></tr>
              </thead>
              <tbody>
                <% o.items.forEach(it=>{ %>
                  <tr>
                    <td style="text-align:right">
                      <div class="row">
                        <img class="thumb" style="width:56px;height:56px" src="<%= it.product_image||'' %>">
                        <div><%= it.product_name %></div>
                      </div>
                    </td>
                    <td><%= it.quantity %></td>
                    <td>₪<%= Number(it.sale_price).toFixed(2) %></td>
                    <td>₪<%= Number(it.shipping_cost||0).toFixed(2) %></td>
                    <td>
                      <span class="status-chip status-<%= it.delivery_status %>">
                        <% if(it.delivery_status==='pending'){ %><i class="fa fa-hourglass-half"></i> قيد المعالجة
                        <% } else if(it.delivery_status==='shipping'){ %><i class="fa fa-truck"></i> قيد التوصيل
                        <% } else if(it.delivery_status==='delivered'){ %><i class="fa fa-check"></i> تم التسليم
                        <% } else { %><i class="fa fa-xmark"></i> لم يتم / فشل <% } %>
                      </span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    <% }) %>
    <% if (!(openOrders||[]).length) { %>
      <div class="muted">لا توجد طلبات مفتوحة مؤخرًا.</div>
    <% } %>
  </div>

  <hr>

  <!-- آخر البنود المُسلّمة -->
  <h2><i class="fa fa-check-circle"></i> آخر البنود المُسلّمة</h2>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>المنتج</th><th>زبون</th><th>كمية</th><th>سعر</th><th>شحن</th><th>ربح</th><th>التاريخ</th>
        </tr>
      </thead>
      <tbody>
        <% (delivered||[]).forEach(r => { %>
          <tr>
            <td style="text-align:right">
              <div class="row">
                <img class="thumb" style="width:56px;height:56px" src="<%= r.product_image||'' %>">
                <div><%= r.product_name %></div>
              </div>
            </td>
            <td><%= r.customer_name||'-' %></td>
            <td><%= r.quantity %></td>
            <td>₪<%= Number(r.sale_price).toFixed(2) %></td>
            <td>₪<%= Number(r.shipping_cost||0).toFixed(2) %></td>
            <td>₪<%= Number(r._profit||0).toFixed(2) %></td>
            <td><%= dayjs(r.delivered_at||r.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD HH:mm') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // ===== بيانات المنتجات من السيرفر =====
  const PRODUCTS = <%- JSON.stringify(products||[]) %>;

  const cartBody   = document.getElementById('cartBody');
  const sumRevenue = document.getElementById('sumRevenue');
  const sumProfit  = document.getElementById('sumProfit');
  const btnAddRow  = document.getElementById('btnAddRow');
  const btnClear   = document.getElementById('btnClear');
  const btnSubmit  = document.getElementById('btnSubmit');

  const fmt = n => (Number(n)||0).toFixed(2) + ' ₪';

  function buildPicker(){
    const sel = document.createElement('select');
    sel.name = 'product_id[]';
    sel.className = 'form-select';
    sel.required = true;
    sel.appendChild(new Option('— اختر —',''));
    PRODUCTS.forEach(p=>{
      const t = `${p.name} ${p.stock>0?`(مخزون: ${p.stock})`:''}`;
      const o = new Option(t, p.id);
      o.dataset.price = p.sale_price;
      o.dataset.cost  = p.cost_price;
      sel.appendChild(o);
    });
    sel.addEventListener('change', ()=>{
      const o = sel.selectedOptions[0];
      const tr = sel.closest('tr');
      tr.querySelector('[name="sale_price[]"]').value = o?.dataset?.price || 0;
      tr.querySelector('[name="cost_price[]"]').value = o?.dataset?.cost  || 0;
      recalc();
    });
    return sel;
  }

  function addRow(pref={}){
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td></td>
      <td><input name="quantity[]" type="number" min="1" value="${pref.quantity||1}"></td>
      <td><input name="sale_price[]" type="number" step="0.01" value="${pref.sale_price||''}"></td>
      <td><input name="cost_price[]" type="number" step="0.01" value="${pref.cost_price||''}"></td>
      <td><input name="shipping_cost[]" type="number" step="0.01" value="${pref.shipping_cost||0}"></td>
      <td><input name="item_note[]" value="${pref.item_note||''}"></td>
      <td><button type="button" class="btn danger btn-sm btnDel"><i class="fa fa-times"></i></button></td>
    `;
    tr.children[0].appendChild(buildPicker());
    tr.querySelectorAll('input').forEach(i=>i.addEventListener('input', recalc));
    tr.querySelector('.btnDel').addEventListener('click', ()=>{ tr.remove(); recalc(); });
    cartBody.appendChild(tr);
    recalc();
  }

  function recalc(){
    let revenue=0, profit=0;
    const hasRows = !!cartBody.querySelector('tr');
    cartBody.querySelectorAll('tr').forEach(tr=>{
      const q = +tr.querySelector('[name="quantity[]"]').value||0;
      const sp= +tr.querySelector('[name="sale_price[]"]').value||0;
      const cp= +tr.querySelector('[name="cost_price[]"]').value||0;
      const sh= +tr.querySelector('[name="shipping_cost[]"]').value||0;
      revenue += q*sp;
      profit  += (q*sp)-(q*cp)-sh;
    });
    sumRevenue.textContent = fmt(revenue);
    sumProfit.textContent  = fmt(profit);
    btnSubmit.disabled = !hasRows;
  }

  btnAddRow.addEventListener('click', ()=>addRow());
  btnClear.addEventListener('click', ()=>{ cartBody.innerHTML=''; recalc(); });
  addRow();

  // أزرار تغيير حالة الطلب من البطاقة
  document.querySelectorAll('.status-action').forEach(b=>{
    b.addEventListener('click', ()=>{
      const form = b.closest('form');
      form.querySelector('[name="status"]').value = b.dataset.val;
      form.submit();
    });
  });
</script>
