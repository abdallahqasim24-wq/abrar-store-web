<link rel="stylesheet" href="<%= faLink %>">

<style>
  /* بطاقة معاينة المنتج المختار */
  .pick-preview{
    display:flex; align-items:center; gap:12px;
    border:1px dashed var(--border); background:#fff;
    border-radius:14px; padding:10px 12px; min-height:84px;
  }
  .pick-preview .thumb{ width:84px; height:84px; border-radius:12px; object-fit:cover; border:1px solid var(--border) }
  .pick-preview .meta{ line-height:1.35 }
  .pick-preview .meta .name{ font-weight:800 }
  .pick-preview .tag{ display:inline-block; padding:2px 8px; border-radius:999px; font-size:.8rem; border:1px solid var(--border); background:#fff7fb; margin-inline-end:6px }
  .muted-sm{ color:#6b7280; font-size:.85rem }

  /* ===== Product Picker (Modal) ===== */
  .pp-backdrop{position:fixed; inset:0; background:rgba(0,0,0,.45); display:none; z-index:80}
  .pp-modal{position:fixed; inset:30px; background:#fff; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,.25); display:none; z-index:90; padding:14px; overflow:hidden}
  .pp-head{display:flex; gap:10px; align-items:center; margin-bottom:8px}
  .pp-search{flex:1; display:flex; gap:8px}
  .pp-search input{width:100%; padding:10px 12px; border:1px solid var(--border); border-radius:12px}
  .pp-close{background:#fff; border:1px solid var(--border); border-radius:10px; padding:8px 10px; cursor:pointer}
  .pp-grid{height:calc(100% - 56px); overflow:auto; padding:6px}
  .pp-cards{display:grid; grid-template-columns:repeat(5,minmax(220px,1fr)); gap:14px}
  @media (max-width:1200px){.pp-cards{grid-template-columns:repeat(4,minmax(220px,1fr))}}
  @media (max-width:900px){.pp-cards{grid-template-columns:repeat(2,minmax(220px,1fr))}}
  @media (max-width:600px){.pp-cards{grid-template-columns:1fr}}
  .pp-card{border:1px solid var(--border); border-radius:16px; padding:10px; background:#fff}
  .pp-card img{width:100%; height:160px; object-fit:cover; border-radius:12px; border:1px solid var(--border)}
  .pp-title{font-weight:800; margin:8px 0; text-align:center}
  .pp-tags{display:flex; gap:8px; flex-wrap:wrap; justify-content:center}
  .pp-tag{border:1px solid var(--border); padding:4px 8px; border-radius:999px; font-size:.85rem; background:#fff7fb}
  .pp-foot{display:flex; justify-content:space-between; align-items:center; margin-top:8px}
  .pp-pick{background:var(--primary); color:#fff; border:0; padding:8px 12px; border-radius:10px; cursor:pointer}
  .pp-id{color:#6b7280; font-size:.85rem}
</style>

<div class="card">
  <h3><i class="fa fa-cart-plus"></i> تسجيل عملية بيع</h3>

  <!-- فورم التسجيل -->
  <form method="post" action="/sales" class="form-grid" id="saleForm">
    <div>
      <label>المنتج</label>
      <div class="row" style="gap:8px">
        <select name="product_id" id="prodSelect" required style="min-width:260px">
          <option value="">اختر المنتج</option>
          <% products.forEach(p=> { %>
            <option
              value="<%= p.id %>"
              data-name="<%- p.name %>"
              data-img="<%= p.image_path || '' %>"
              data-sale="<%= Number(p.sale_price) %>"
              data-cost="<%= Number(p.cost_price) %>"
              data-stock="<%= Number(p.stock) %>"
            >
              <%= p.name %> (مخزون: <%= p.stock %>)
            </option>
          <% }) %>
        </select>
        <button type="button" class="btn edit" id="btnOpenPicker"><i class="fa fa-grid-2"></i> اختيار من الشبكة</button>
      </div>
    </div>

    <div>
      <label>كمية</label>
      <input type="number" id="qtyInput" name="quantity" value="1" step="1" required/>
    </div>

    <div>
      <label>سعر البيع</label>
      <input type="number" id="salePriceInput" name="sale_price" step="0.01" />
    </div>

    <div>
      <label>السعر الأصلي</label>
      <input type="number" id="costPriceInput" name="cost_price" step="0.01" />
    </div>

    <div>
      <label>تكلفة الشحن +₪</label>
      <input type="number" name="shipping_cost" step="0.01"/>
    </div>

    <div>
      <label>ملاحظة</label>
      <input type="text" name="note"/>
    </div>

    <!-- معلومات الزبون -->
    <div><label>اسم الزبون</label><input type="text" name="customer_name" /></div>
    <div><label>رقم الهاتف</label><input type="tel" name="customer_phone" /></div>
    <div><label>المدينة/المنطقة</label><input type="text" name="customer_city" /></div>

    <!-- معاينة المنتج المختار -->
    <div style="grid-column:1 / -1">
      <div id="pickPreview" class="pick-preview" style="display:none">
        <img id="pickImg" class="thumb js-img" src="" alt="">
        <div class="meta">
          <div class="name" id="pickName"></div>
          <div class="muted-sm">
            <span class="tag">المخزون: <span id="pickStock">0</span></span>
            <span class="tag">بيع: ₪<span id="pickSale">0.00</span></span>
            <span class="tag">أصلي: ₪<span id="pickCost">0.00</span></span>
          </div>
        </div>
      </div>
    </div>

    <div class="right"></div>
    <div class="row right">
      <button class="btn save"><i class="fa fa-check"></i> تسجيل</button>
    </div>
  </form>
</div>

<!-- سجل المبيعات -->
<div class="card" style="margin-top:12px">
  <h3><i class="fa fa-receipt"></i> سجل المبيعات</h3>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>التاريخ</th>
          <th>المنتج</th>
          <th>الزبون</th>
          <th>هاتف</th>
          <th>المدينة</th>
          <th>كمية</th>
          <th>سعر بيع (₪)</th>
          <th>المطلوب (₪)</th>
          <th>السعر الأصلي (₪)</th>
          <th>شحن (₪)</th>
          <th>الربح (₪)</th>
          <th>التوصيل</th>
          <th>تعديل</th>
          <th>حذف</th>
        </tr>
      </thead>
      <tbody>
        <% sales.forEach(s=> {
             const qty       = Number(s.quantity);
             const price     = Number(s.sale_price);
             const costUnit  = Number(s.cost_price);
             const ship      = Number(s.shipping_cost||0);
             const revenue   = price * qty;
             const requested = revenue + ship;
             const profit    = revenue - (costUnit*qty) - ship;
             const status    = (s.delivery_status || 'pending');
        %>
          <tr>
            <td><%= dayjs(s.sold_at).format('YYYY-MM-DD hh:mm A') %></td>
            <td class="right">
              <% if (s.product_image) { %>
                <img src="<%= s.product_image %>" class="thumb js-img" style="width:56px;height:56px;vertical-align:middle;margin-inline-start:6px" alt="product"/>
              <% } %>
              <%= s.product_name %>
            </td>
            <td><%= s.customer_name || '—' %></td>
            <td><%= s.customer_phone || '—' %></td>
            <td><%= s.customer_city || '—' %></td>
            <td><%= qty %></td>
            <td>₪<%= price.toFixed(2) %></td>
            <td><strong>₪<%= requested.toFixed(2) %></strong></td>
            <td>₪<%= costUnit.toFixed(2) %></td>
            <td>₪<%= ship.toFixed(2) %></td>
            <td>₪<%= profit.toFixed(2) %></td>

            <td>
              <div class="status-wrap">
                <div class="status-chip status-<%= status %>" onclick="toggleMenu(this)">
                  <% if (status==='delivered'){ %>
                    <i class="fa fa-check"></i><span>تم التسليم</span>
                  <% } else if (status==='failed'){ %>
                    <i class="fa fa-xmark"></i><span>فشل/لم يتم</span>
                  <% } else if (status==='shipping'){ %>
                    <i class="fa fa-truck"></i><span>قيد التوصيل</span>
                  <% } else { %>
                    <i class="fa fa-hourglass-half"></i><span>قيد المعالجة</span>
                  <% } %>
                </div>
                <div class="status-menu">
                  <form method="post" action="/sales/<%= s.id %>/delivery">
                    <input type="hidden" name="status" value="pending">
                    <button type="submit"><i class="fa fa-hourglass-half"></i> قيد المعالجة</button>
                  </form>
                  <form method="post" action="/sales/<%= s.id %>/delivery">
                    <input type="hidden" name="status" value="shipping">
                    <button type="submit"><i class="fa fa-truck"></i> قيد التوصيل</button>
                  </form>
                  <form method="post" action="/sales/<%= s.id %>/delivery">
                    <input type="hidden" name="status" value="delivered">
                    <button type="submit"><i class="fa fa-check"></i> تم التسليم</button>
                  </form>
                  <form method="post" action="/sales/<%= s.id %>/delivery">
                    <input type="hidden" name="status" value="failed">
                    <button type="submit"><i class="fa fa-xmark"></i> فشل/لم يتم</button>
                  </form>
                  <div class="muted-sm" style="padding:6px 8px">
                    <% if (s.delivered_at) { %>
                      آخر تسليم: <%= dayjs(s.delivered_at).format('YYYY-MM-DD hh:mm A') %>
                    <% } else { %>
                      لا يوجد وقت تسليم مسجل
                    <% } %>
                  </div>
                </div>
              </div>
            </td>

            <td>
              <a class="btn edit" href="/sales/<%= s.id %>/edit"><i class="fa fa-pen-to-square"></i> تعديل</a>
            </td>

            <td>
              <form method="post" action="/sales/<%= s.id %>/delete" onsubmit="return confirm('حذف العملية؟ سيُنقل الطلب إلى قائمة الراجعات.')">
                <button class="btn danger"><i class="fa fa-trash"></i> حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- ===== Product Picker Modal (مش بيفتح تلقائي) ===== -->
<div class="pp-backdrop" id="ppBg"></div>
<div class="pp-modal" id="ppModal" role="dialog" aria-modal="true" aria-label="منتقي المنتجات">
  <div class="pp-head">
    <div class="pp-search">
      <i class="fa fa-magnifying-glass" style="align-self:center"></i>
      <input type="search" id="ppSearch" placeholder="ابحث باسم المنتج…">
    </div>
    <button class="pp-close" id="ppClose"><i class="fa fa-xmark"></i> إغلاق</button>
  </div>
  <div class="pp-grid">
    <div class="pp-cards" id="ppCards"></div>
  </div>
</div>

<script>
  // تمرير بيانات المنتجات للمنتقي
  window.PRODUCTS = <%- JSON.stringify(products || []) %>;

  // قائمة التوصيل (كما هي)
  function toggleMenu(el){
    const menu = el.parentElement.querySelector('.status-menu');
    const open = menu.style.display === 'block';
    document.querySelectorAll('.status-menu').forEach(m => m.style.display='none');
    menu.style.display = open ? 'none' : 'block';
  }
  document.addEventListener('click', (e)=>{
    const wrap = e.target.closest('.status-wrap');
    if(!wrap) document.querySelectorAll('.status-menu').forEach(m => m.style.display='none');
  });

  // معاينة + تعبئة الحقول من select
  (function(){
    const sel   = document.getElementById('prodSelect');
    const qty   = document.getElementById('qtyInput');
    const saleI = document.getElementById('salePriceInput');
    const costI = document.getElementById('costPriceInput');

    const box   = document.getElementById('pickPreview');
    const img   = document.getElementById('pickImg');
    const name  = document.getElementById('pickName');
    const stock = document.getElementById('pickStock');
    const saleV = document.getElementById('pickSale');
    const costV = document.getElementById('pickCost');

    function fillFromOption(opt){
      const pImg   = opt.getAttribute('data-img') || '';
      const pName  = opt.getAttribute('data-name') || '';
      const pSale  = Number(opt.getAttribute('data-sale') || 0);
      const pCost  = Number(opt.getAttribute('data-cost') || 0);
      const pStock = Number(opt.getAttribute('data-stock')|| 0);

      box.style.display = 'flex';
      if (pImg) img.src = pImg; else img.removeAttribute('src');
      name.textContent  = pName;
      stock.textContent = pStock.toLocaleString('en-US');
      saleV.textContent = pSale.toFixed(2);
      costV.textContent = pCost.toFixed(2);

      saleI.value = pSale.toFixed(2);
      costI.value = pCost.toFixed(2);
      if (!qty.value || Number(qty.value) <= 0) qty.value = 1;
    }

    sel.addEventListener('change', ()=> {
      const opt = sel.options[sel.selectedIndex];
      if (!opt || !opt.value) { box.style.display='none'; return; }
      fillFromOption(opt);
    });

    if (sel.value) fillFromOption(sel.options[sel.selectedIndex]); // لو في قيمة محفوظة
  })();

  // ===== منتقي المنتجات الشبكي (لا يفتح تلقائيًا) =====
  (function(){
    const bg   = document.getElementById('ppBg');
    const mod  = document.getElementById('ppModal');
    const cards= document.getElementById('ppCards');
    const search = document.getElementById('ppSearch');
    const btnOpen = document.getElementById('btnOpenPicker');
    const btnClose= document.getElementById('ppClose');
    const sel = document.getElementById('prodSelect');

    function open(){ bg.style.display='block'; mod.style.display='block'; search.focus(); render(); }
    function close(){ bg.style.display='none'; mod.style.display='none'; }

    btnOpen.addEventListener('click', open);
    btnClose.addEventListener('click', close);
    bg.addEventListener('click', close);
    window.addEventListener('keydown', e=>{ if(e.key==='Escape') close(); });

    function render(){
      const q = (search.value||'').trim().toLowerCase();
      const data = (window.PRODUCTS||[]).filter(p => !q || String(p.name).toLowerCase().includes(q));
      cards.innerHTML = '';
      data.forEach(p=>{
        const div = document.createElement('div');
        div.className='pp-card';
        div.innerHTML = `
          <img src="${p.image_path||''}" alt="">
          <div class="pp-title">${p.name}</div>
          <div class="pp-tags">
            <span class="pp-tag">بيع: ₪${Number(p.sale_price).toFixed(2)}</span>
            <span class="pp-tag">أصلي: ₪${Number(p.cost_price).toFixed(2)}</span>
            <span class="pp-tag">مخزون: ${Number(p.stock||0)}</span>
          </div>
          <div class="pp-foot">
            <span class="pp-id">ID: ${p.id}</span>
            <button class="pp-pick" data-id="${p.id}"><i class="fa fa-check"></i> اختيار</button>
          </div>
        `;
        cards.appendChild(div);
      });
    }

    search.addEventListener('input', render);

    cards.addEventListener('click', (e)=>{
      const btn = e.target.closest('.pp-pick');
      if(!btn) return;
      const id = Number(btn.getAttribute('data-id'));
      // حدّد في الـ select
      const opt = Array.from(sel.options).find(o => Number(o.value)===id);
      if (opt){ sel.value = String(id); sel.dispatchEvent(new Event('change')); }
      close();
    });
  })();
</script>
