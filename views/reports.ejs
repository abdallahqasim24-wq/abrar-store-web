<link rel="stylesheet" href="<%= faLink %>">

<style>
  .filters{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;align-items:end}
  @media(max-width:900px){.filters{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:600px){.filters{grid-template-columns:1fr}}
  .btn-toggle{padding:10px 14px;border-radius:12px;border:1px solid var(--border);cursor:pointer;font-weight:700}
  .btn-on {background:#16a34a;color:#fff;border-color:#128a3e}
  .btn-off{background:#f59e0b;color:#111;border-color:#d97706}
  .btn-ghost{background:#fff}
  .cards{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;margin-top:16px}
  @media(max-width:900px){.cards{grid-template-columns:1fr}}
  .kpi{padding:20px;border:1px solid var(--border);border-radius:16px;background:#fff}
  .muted{color:#6b7280}
  .table{width:100%}
  .table th,.table td{padding:12px;border-top:1px solid var(--border)}
  .thead th{background:#feeef5}
  .thumb{width:56px;height:56px;border:1px solid var(--border);border-radius:12px;overflow:hidden;background:#fff;display:flex;align-items:center;justify-content:center}
</style>

<%
  const dj   = (typeof dayjs !== 'undefined' && dayjs) ? dayjs : null;
  const NOW  = dj && dj.tz ? dj().tz('Asia/Hebron') : null;
  const sel  = (typeof selected === 'object' && selected) ? selected : {};
  const RANGE= (typeof range==='string'&&range) ? range : 'daily';
  const YEARS= Array.isArray(years)&&years.length ? years : [2024,2025,2026,2027,2028,2029,2030];

  const curY = Number(NOW ? NOW.format('YYYY') : new Date().getFullYear());
  const curM = Number(NOW ? NOW.format('MM')   : (new Date().getMonth()+1));
  const curD = Number(NOW ? NOW.format('DD')   : new Date().getDate());

  const selY = Number(sel.year  ?? curY);
  const selM = Number(sel.month ?? curM);
  const selD = Number(sel.day   ?? curD);

  const _rows = Array.isArray(rows) ? rows : [];
  const sumRevenue = _rows.reduce((a,s)=> a + Number(s.sale_price||0)*Number(s.quantity||0), 0);
  const sumCost    = _rows.reduce((a,s)=> a + Number(s.cost_price||0)*Number(s.quantity||0), 0);
  const sumShip    = _rows.reduce((a,s)=> a + Number(s.shipping_cost||0), 0);
  const sumProfit  = sumRevenue - sumCost; // بدون الشحن
%>

<div class="card">
  <form id="reportForm" method="get" action="/reports" class="filters">
    <input type="hidden" name="range" id="rangeInput" value="<%= RANGE %>">

    <button type="button" id="btnDaily"   class="btn-toggle <%= RANGE==='daily'?'btn-on':'btn-ghost' %>"><i class="fa fa-calendar-day"></i> تقرير يومي</button>
    <button type="button" id="btnMonthly" class="btn-toggle <%= RANGE==='monthly'?'btn-off':'btn-ghost' %>"><i class="fa fa-calendar"></i> تقرير شهري</button>

    <div>
      <label class="muted">السنة</label>
      <select name="year" id="ySel"><% YEARS.forEach(y => { %>
        <option value="<%= y %>" <%= y===selY?'selected':'' %>><%= y %></option><% }) %>
      </select>
    </div>
    <div>
      <label class="muted">الشهر</label>
      <select name="month" id="mSel"><% for (let m=1;m<=12;m++){ %>
        <option value="<%= m %>" <%= m===selM?'selected':'' %>><%= m %></option><% } %>
      </select>
    </div>
    <div id="dayWrap">
      <label class="muted">اليوم</label>
      <select name="day" id="dSel"><% for (let d=1; d<=31; d++){ %>
        <option value="<%= d %>" <%= d===selD?'selected':'' %>><%= d %></option><% } %>
      </select>
    </div>

    <button class="btn save" type="submit"><i class="fa fa-magnifying-glass"></i> عرض</button>
    <a class="btn add right" id="pdfBtn" href="#"><i class="fa fa-file-pdf"></i> تصدير PDF</a>
  </form>

  <div class="cards">
    <div class="kpi"><div class="muted">الإيراد</div><div style="font-size:28px;font-weight:800">₪<%= sumRevenue.toFixed(2) %></div></div>
    <div class="kpi"><div class="muted">التكاليف (أصلي + شحن)</div><div style="font-size:28px;font-weight:800">₪<%= (sumCost + sumShip).toFixed(2) %></div></div>
    <div class="kpi"><div class="muted">الربح</div><div style="font-size:28px;font-weight:800">₪<%= sumProfit.toFixed(2) %></div></div>
  </div>
</div>

<div class="card" style="margin-top:16px">
  <h3><i class="fa fa-clipboard-list"></i> تفاصيل العمليات — <%= title %></h3>

  <table class="table">
    <thead class="thead">
      <tr>
        <th>التاريخ</th><th>المنتج</th><th>الكمية</th><th>سعر بيع (₪)</th><th>السعر الأصلي (₪)</th><th>الشحن (₪)</th><th>الربح (₪)</th><th>ملاحظة</th>
      </tr>
    </thead>
    <tbody>
    <% if (!_rows.length){ %>
      <tr><td colspan="8" class="muted">لا توجد بيانات ضمن الفترة المختارة.</td></tr>
    <% } else { _rows.forEach(s => {
        const qty=Number(s.quantity||0), sale=Number(s.sale_price||0), cost=Number(s.cost_price||0), ship=Number(s.shipping_cost||0);
        const revenue = sale*qty, profit = revenue - (cost*qty);
        const _img=(s.product_image||''); const _src=_img?(_img.startsWith('/')?_img:'/'+_img):'';
    %>
      <tr>
        <td>
          <%= (dayjs && dayjs.tz) ? dayjs(s.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A')
                                  : (new Date(s.sold_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %>
        </td>
        <td style="text-align:right">
          <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
            <div class="thumb"><% if (_src) { %><img src="<%= _src %>" alt="" style="width:100%;height:100%;object-fit:cover"><% } else { %><span class="muted">لا صورة</span><% } %></div>
            <div style="max-width:420px"><%= s.product_name %></div>
          </div>
        </td>
        <td><%= qty %></td><td>₪<%= sale.toFixed(2) %></td><td>₪<%= cost.toFixed(2) %></td><td>₪<%= ship.toFixed(2) %></td><td>₪<%= profit.toFixed(2) %></td>
        <td style="text-align:right"><%= s.note||'' %></td>
      </tr>
    <% }) } %>
    </tbody>
    <% if (_rows.length) { %>
      <tfoot><tr><th class="right" colspan="3">الإجمالي</th><th>₪<%= sumRevenue.toFixed(2) %></th><th>₪<%= sumCost.toFixed(2) %></th><th>₪<%= sumShip.toFixed(2) %></th><th>₪<%= sumProfit.toFixed(2) %></th><th></th></tr></tfoot>
    <% } %>
  </table>
</div>

<script>
(function(){
  const rangeInput=document.getElementById('rangeInput'), dayWrap=document.getElementById('dayWrap');
  const btnDaily=document.getElementById('btnDaily'), btnMonthly=document.getElementById('btnMonthly');
  function syncDay(){ const monthly = rangeInput.value==='monthly'; dayWrap.style.display = monthly ? 'none' : ''; }
  btnDaily?.addEventListener('click', ()=>{ rangeInput.value='daily'; syncDay(); });
  btnMonthly?.addEventListener('click', ()=>{ rangeInput.value='monthly'; syncDay(); });
  syncDay();
  document.getElementById('pdfBtn')?.addEventListener('click',(e)=>{ e.preventDefault(); const form=document.getElementById('reportForm'); const params=new URLSearchParams(new FormData(form)); window.location.href='/reports/pdf?'+params.toString(); });
})();
</script>
