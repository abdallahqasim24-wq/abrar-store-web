<link rel="stylesheet" href="<%= res.locals.faLink %>">

<div class="card" style="margin-bottom:12px">
  <h3><i class="fa fa-filter"></i> فلاتر التقرير</h3>
  <form method="get" action="/reports" class="row" style="gap:12px; align-items:flex-end">
    <!-- وضع التقرير -->
    <div>
      <label>وضع التقرير</label>
      <select name="mode" onchange="this.form.submit()">
        <option value="daily"   <%= mode==='daily'?'selected':'' %> >يومي</option>
        <option value="monthly" <%= mode==='monthly'?'selected':'' %>>شهري</option>
      </select>
    </div>

    <div>
      <label>السنة</label>
      <select name="year">
        <% years.forEach(y => { %>
          <option value="<%= y %>" <%= (y===year)?'selected':'' %>><%= y %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <label>الشهر</label>
      <select name="month" onchange="syncDays()">
        <% months.forEach(m => { %>
          <option value="<%= m.n %>" <%= (m.n===month)?'selected':'' %>><%= m.name %></option>
        <% }) %>
      </select>
    </div>

    <% if (mode==='daily') { %>
    <div>
      <label>اليوم</label>
      <select name="day" id="daySelect">
        <% daysArr.forEach(dv => { %>
          <option value="<%= dv %>" <%= (dv===day)?'selected':'' %>><%= dv %></option>
        <% }) %>
      </select>
    </div>
    <% } %>

    <div class="right"></div>
    <div>
      <button class="btn save"><i class="fa fa-search"></i> عرض</button>
    </div>
  </form>
</div>

<div class="cards" style="margin-bottom:14px">
  <div class="card"><h3>الإيراد</h3><div class="kpi">₪<%= Number(totalRevenue).toLocaleString('en-US',{minimumFractionDigits:2}) %></div></div>
  <div class="card"><h3>الربح</h3><div class="kpi">₪<%= Number(totalProfit).toLocaleString('en-US',{minimumFractionDigits:2}) %></div></div>
</div>

<div class="card">
  <h3><i class="fa fa-list"></i> <%= title %></h3>
  <% if(!rows.length){ %>
    <p style="color:#666">لا توجد بيانات لهذا النطاق.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الكمية</th>
        <th>سعر البيع</th>
        <th>السعر الأصلي</th>
        <th>الشحن</th>
        <th>التصنيف</th>
        <th>الربح</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(s => {
           const sale = Number(s.sale_price);
           const cost = Number(s.cost_price);
           const ship = Number(s.shipping_cost||0);
           const qty  = Number(s.quantity||0);
           const profit = (sale*qty) - (cost*qty) - ship;
      %>
      <tr>
        <td><%= fmtTS(s.sold_at) %></td>
        <td class="right"><%= s.product_name %></td>
        <td><%= qty.toLocaleString('en-US') %></td>
        <td>₪<%= sale.toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
        <td>₪<%= cost.toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
        <td>₪<%= ship.toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
        <td><%= s.category || 'غير مصنّف' %></td>
        <td>₪<%= profit.toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<% if (mode==='monthly') { %>
  <div class="grid-2" style="margin-top:14px">
    <div class="card">
      <h3><i class="fa fa-calendar-day"></i> ملخص الشهر بحسب اليوم</h3>
      <table>
        <thead><tr><th>اليوم</th><th>الإيراد</th><th>الربح</th></tr></thead>
        <tbody>
          <% byDay.forEach(r => { %>
            <tr>
              <td><%= r.day %></td>
              <td>₪<%= Number(r.revenue).toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
              <td>₪<%= Number(r.profit).toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h3><i class="fa fa-tags"></i> توزيع الإيراد حسب التصنيف</h3>
      <% if(!byCat.length){ %><p style="color:#666">لا يوجد بيانات.</p><% } else { %>
      <table>
        <thead><tr><th>التصنيف</th><th>الإيراد</th></tr></thead>
        <tbody>
          <% byCat.forEach(c => { %>
            <tr>
              <td class="right"><%= c.label %></td>
              <td>₪<%= Number(c.value).toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
<% } %>

<script>
  // تحديث قائمة الأيام عند تغيير الشهر (للواجهة فقط؛ الحسبة الفعلية على السيرفر)
  function syncDays(){
    const form = event.target.form;
    if (form) form.submit();
  }
</script>
