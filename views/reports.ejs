<link rel="stylesheet" href="<%= faLink %>">

<!-- فلاتر التقرير -->
<div class="card" style="margin-bottom:12px">
  <h3><i class="fa fa-filter"></i> فلاتر التقرير</h3>

  <form id="reportFilter" method="get" action="/reports" class="row" style="gap:10px;flex-wrap:wrap">
    <!-- المدى -->
    <input id="rangeInput" type="hidden" name="range" value="<%= (range || 'daily') %>"/>

    <!-- السنة -->
    <div>
      <label>السنة</label>
      <select name="year" id="yearSelect">
        <% const thisYear = Number(dayjs().format('YYYY'));
           const selYear  = selected.year ?? thisYear;
           for (let y = thisYear; y >= thisYear-5; y--) { %>
          <option value="<%= y %>" <%= selYear===y ? 'selected' : '' %>><%= y %></option>
        <% } %>
      </select>
    </div>

    <!-- الشهر -->
    <div>
      <label>الشهر</label>
      <select name="month" id="monthSelect">
        <% const thisMonth = Number(dayjs().format('MM'));
           const selMonth  = selected.month ?? thisMonth;
           for (let m = 1; m <= 12; m++) { %>
          <option value="<%= m %>" <%= selMonth===m ? 'selected' : '' %>><%= m %></option>
        <% } %>
      </select>
    </div>

    <!-- اليوم (يُخفى/يُعطّل عند الشهري) -->
    <div id="dayWrap">
      <label>اليوم</label>
      <select name="day" id="daySelect">
        <% const thisDay = Number(dayjs().format('DD'));
           const selDay  = selected.day ?? thisDay;
           for (let d = 1; d <= 31; d++) { %>
          <option value="<%= d %>" <%= selDay===d ? 'selected' : '' %>><%= d %></option>
        <% } %>
      </select>
    </div>

    <!-- الأزرار -->
    <div class="row" style="gap:8px">
      <button type="button" id="dailyBtn"  class="btn save"><i class="fa fa-calendar-day"></i> تقرير يومي</button>
      <button type="button" id="monthlyBtn" class="btn edit" style="background:#f59e0b"><i class="fa fa-calendar"></i> تقرير شهري</button>

      <!-- رابط PDF يتحدث تلقائيًا حسب المدى -->
      <a id="pdfLink" class="btn" style="background:#6b7280" target="_blank">
        <i class="fa fa-file-pdf"></i> طباعة PDF
      </a>

      <!-- إرسال -->
      <button class="btn" style="background:#334155"><i class="fa fa-search"></i> عرض</button>
    </div>
  </form>
</div>

<script>
  (function () {
    const form       = document.getElementById('reportFilter');
    const rangeInput = document.getElementById('rangeInput');
    const dayWrap    = document.getElementById('dayWrap');
    const daySelect  = document.getElementById('daySelect');
    const yearSel    = document.getElementById('yearSelect');
    const monthSel   = document.getElementById('monthSelect');
    const pdfLink    = document.getElementById('pdfLink');

    function updateUI() {
      const isMonthly = rangeInput.value === 'monthly';
      // إخفاء/تعطيل اختيار اليوم في الشهري
      dayWrap.style.display = isMonthly ? 'none' : '';
      daySelect.disabled = isMonthly;

      // تحديث رابط PDF
      const y = yearSel.value || '';
      const m = monthSel.value || '';
      const d = !isMonthly ? (daySelect.value || '') : '';
      const url = new URL('/reports/pdf', window.location.origin);
      url.searchParams.set('range', rangeInput.value);
      if (y) url.searchParams.set('year', y);
      if (m) url.searchParams.set('month', m);
      if (!isMonthly && d) url.searchParams.set('day', d);
      pdfLink.href = url.pathname + url.search;
    }

    // تبديل المدى
    document.getElementById('dailyBtn').addEventListener('click', () => {
      rangeInput.value = 'daily';
      updateUI();
    });
    document.getElementById('monthlyBtn').addEventListener('click', () => {
      rangeInput.value = 'monthly';
      updateUI();
    });

    // حدث تغيير القوائم لتحديث PDF فورًا
    [yearSel, monthSel, daySelect].forEach(el => el.addEventListener('change', updateUI));

    // تهيئة أولية
    updateUI();
  })();
</script>
