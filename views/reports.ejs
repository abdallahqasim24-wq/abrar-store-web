<link rel="stylesheet" href="<%= faLink %>">

<div class="card">
  <h3><i class="fa fa-clipboard-list"></i> تفاصيل العمليات — <%= title %></h3>

  <form id="reportForm" method="get" action="/reports" class="row" style="gap:10px;margin:8px 0 14px">
    <input type="hidden" name="range" id="rangeInput" value="<%= range||'daily' %>">
    <button type="button" id="btnDaily"   class="btn <%= range==='daily'?'save':'secondary' %>"><i class="fa fa-calendar-day"></i> يومي</button>
    <button type="button" id="btnMonthly" class="btn <%= range==='monthly'?'save':'secondary' %>"><i class="fa fa-calendar"></i> شهري</button>

    <select name="year" id="ySel">
      <% const curY = Number(dayjs().format('YYYY')); const selY = Number(selected?.year || curY);
         for (let y = curY+1; y >= curY-5; y--) { %>
        <option value="<%= y %>" <%= y===selY?'selected':'' %>><%= y %></option>
      <% } %>
    </select>

    <select name="month" id="mSel">
      <% const selM = Number(selected?.month || Number(dayjs().format('MM')));
         for (let m=1;m<=12;m++){ %>
        <option value="<%= m %>" <%= m===selM?'selected':'' %>><%= m %></option>
      <% } %>
    </select>

    <select name="day" id="dSel">
      <% const selD = Number(selected?.day || Number(dayjs().format('DD')));
         for (let d=1; d<=31; d++){ %>
        <option value="<%= d %>" <%= d===selD?'selected':'' %>><%= d %></option>
      <% } %>
    </select>

    <button class="btn add"><i class="fa fa-magnifying-glass"></i> عرض</button>
    <a class="btn secondary right" href="/reports/pdf?<%= new URLSearchParams({range:range,year:selected?.year,month:selected?.month,day:selected?.day}).toString() %>" target="_blank"><i class="fa fa-file-pdf"></i> PDF</a>
  </form>

  <!-- مؤشرات -->
  <div class="row" style="gap:12px;flex-wrap:wrap;margin-bottom:8px">
    <div class="card" style="min-width:220px"><div class="muted">الإيراد</div><div style="font-weight:800;font-size:26px">₪<%= Number(totalRevenue||0).toFixed(2) %></div></div>
    <div class="card" style="min-width:220px"><div class="muted">التكاليف</div><div style="font-weight:800;font-size:26px">₪<%= Number(totalCost||0).toFixed(2) %></div></div>
    <div class="card" style="min-width:220px"><div class="muted">الربح</div><div style="font-weight:800;font-size:26px">₪<%= Number(totalRevenue-totalCost||0).toFixed(2) %></div></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>الكمية</th>
        <th>سعر بيع (₪)</th>
        <th>السعر الأصلي (₪)</th>
        <th>الشحن (₪)</th>
        <th>الربح (₪)</th>
      </tr>
    </thead>
    <tbody>
      <% if (!rows || !rows.length){ %>
        <tr><td colspan="7" class="muted">لا توجد بيانات ضمن الفترة المختارة.</td></tr>
      <% } else { rows.forEach(s => {
        const revenue = Number(s.sale_price) * Number(s.quantity);
        const profit  = revenue - (Number(s.cost_price)*Number(s.quantity)) - Number(s.shipping_cost||0);
      %>
        <tr>
          <td><%= dayjs(s.sold_at).format('YYYY-MM-DD hh:mm A') %></td>
          <td style="text-align:right">
            <div class="row" style="gap:8px;align-items:center;justify-content:flex-start">
              <div style="width:56px;height:56px;border:1px solid var(--border);border-radius:10px;overflow:hidden;display:flex;align-items:center;justify-content:center">
                <% if (s.product_image) { %>
                  <img src="<%= s.product_image %>" class="js-img" style="width:100%;height:100%;object-fit:cover" alt="">
                <% } %>
              </div>
              <div style="max-width:520px"><%= s.product_name %></div>
            </div>
          </td>
          <td><%= s.quantity %></td>
          <td>₪<%= Number(s.sale_price).toFixed(2) %></td>
          <td>₪<%= Number(s.cost_price).toFixed(2) %></td>
          <td>₪<%= Number(s.shipping_cost||0).toFixed(2) %></td>
          <td>₪<%= profit.toFixed(2) %></td>
        </tr>
      <% }) } %>
    </tbody>
  </table>
</div>

<script>
  (function(){
    const form   = document.getElementById('reportForm');
    const rangeI = document.getElementById('rangeInput');
    const btnDaily   = document.getElementById('btnDaily');
    const btnMonthly = document.getElementById('btnMonthly');
    const dSel  = document.getElementById('dSel');

    function applyUI(){
      const isMonthly = rangeI.value==='monthly';
      dSel.disabled = isMonthly;
      if(isMonthly) dSel.style.opacity=.5; else dSel.style.opacity=1;
    }
    btnDaily.addEventListener('click',()=>{ rangeI.value='daily'; applyUI(); form.submit(); });
    btnMonthly.addEventListener('click',()=>{ rangeI.value='monthly'; applyUI(); form.submit(); });
    applyUI();

    form.addEventListener('submit',()=>{
      if(rangeI.value==='monthly') dSel.removeAttribute('name');
      else dSel.setAttribute('name','day');
    });
  })();
</script>
