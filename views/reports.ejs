<div class="card">
  <h3><%= title %></h3>

  <% if (!rows.length) { %>
    <p>لا توجد بيانات لهذا النطاق الزمني.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>التاريخ</th>
          <th>المنتج</th>
          <th>كمية</th>
          <th>سعر البيع</th>
          <th>الشحن</th>
          <th>الربح</th>
          <th>ملاحظة</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(s => {
             const sale   = Number(s.sale_price);
             const ship   = Number(s.shipping_cost || 0);
             const qty    = Number(s.quantity || 0);
             const profit = (sale * qty) - ship; // ← المعادلة الجديدة
        %>
          <tr>
            <td><%= dayjs(s.sold_at).format('YYYY-MM-DD HH:mm') %></td>
            <td><%= s.product_name %></td>
            <td><%= qty.toLocaleString('en-US') %></td>
            <td>₪<%= sale.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
            <td>₪<%= ship.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
            <td>₪<%= profit.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
            <td><%= (s.note || '') %></td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="3" style="text-align:right">الإجمالي:</th>
          <th>₪<%= Number(totalRevenue).toLocaleString('en-US', {minimumFractionDigits:2}) %></th>
          <th></th>
          <th>₪<%= Number(totalProfit).toLocaleString('en-US', {minimumFractionDigits:2}) %></th>
          <th></th>
        </tr>
      </tfoot>
    </table>
  <% } %>
</div>
