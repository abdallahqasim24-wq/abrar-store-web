<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <title><%= title %></title>
  <style>
    body{font-family:'Tajawal','Cairo',Arial; font-size:12px; color:#111}
    h1{font-size:18px; margin:0 0 10px}
    table{width:100%; border-collapse:collapse}
    th,td{border:1px solid #eee; padding:6px; vertical-align:middle; text-align:center}
    th{background:#feeef5}
    .right{text-align:right}
    .thumb{width:48px;height:48px;border-radius:10px;border:1px solid #f1f5f9;overflow:hidden}
  </style>
</head>
<body>
  <h1><%= title %></h1>

  <table>
    <thead>
      <tr>
        <th>التاريخ</th><th class="right">المنتج</th><th>الصورة</th><th>الكمية</th><th>سعر بيع (₪)</th><th>السعر الأصلي (₪)</th><th>الشحن (₪)</th><th>الربح (₪)</th>
      </tr>
    </thead>
    <tbody>
      <% (rows||[]).forEach(s=>{
           const qty=Number(s.quantity||0), sale=Number(s.sale_price||0), cost=Number(s.cost_price||0), ship=Number(s.shipping_cost||0);
           const profit = (sale*qty) - (cost*qty);
           const _img=(s.product_image||''); const _src=_img?(_img.startsWith('/')?_img:'/'+_img):'';
      %>
        <tr>
          <td><%= (dayjs&&dayjs.tz)? dayjs(s.sold_at).tz('Asia/Hebron').format('YYYY-MM-DD hh:mm A') : (new Date(s.sold_at)).toLocaleString('en-CA',{hour12:true,timeZone:'Asia/Hebron'}) %></td>
          <td class="right"><%= s.product_name %></td>
          <td><div class="thumb"><% if(_src){ %><img src="<%= _src %>" alt="" style="width:100%;height:100%;object-fit:cover"><% } %></div></td>
          <td><%= qty %></td><td>₪<%= sale.toFixed(2) %></td><td>₪<%= cost.toFixed(2) %></td><td>₪<%= ship.toFixed(2) %></td><td>₪<%= profit.toFixed(2) %></td>
        </tr>
      <% }) %>
      <% if (!(rows||[]).length){ %><tr><td colspan="8">لا توجد بيانات</td></tr><% } %>
    </tbody>
    <% if ((rows||[]).length){ 
         const totalRevenue=(rows||[]).reduce((a,s)=> a+Number(s.sale_price||0)*Number(s.quantity||0),0);
         const totalProfit =(rows||[]).reduce((a,s)=> a+(Number(s.sale_price||0)*Number(s.quantity||0)-Number(s.cost_price||0)*Number(s.quantity||0)),0);
         const totalShip   =(rows||[]).reduce((a,s)=> a+Number(s.shipping_cost||0),0);
    %>
      <tfoot><tr><th class="right" colspan="4">الإجماليات</th><th>₪<%= totalRevenue.toFixed(2) %></th><th>—</th><th>₪<%= totalShip.toFixed(2) %></th><th>₪<%= totalProfit.toFixed(2) %></th></tr></tfoot>
    <% } %>
  </table>
</body>
</html>
