<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
<style>
  body{ font-family:'Cairo', Arial, sans-serif; direction:rtl; margin:0; color:#111 }
  h1{ font-size:20px; text-align:center; margin:16px 0 8px }
  .meta{ text-align:center; color:#555; margin-bottom:12px }
  table{ width:100%; border-collapse:collapse; font-size:12px }
  th,td{ border:1px solid #eee; padding:6px 8px; }
  th{ background:#fff3f8 }
  tfoot td{ font-weight:bold }
  .right{ text-align:right }
</style>
</head>
<body>
  <h1><%= title %></h1>
  <div class="meta">إيراد: $<%= totalRevenue.toFixed(2) %> — ربح: $<%= totalProfit.toFixed(2) %></div>
  <table>
    <thead>
      <tr>
        <th>التاريخ</th><th>المنتج</th><th>كمية</th><th>بيع</th>
        <th>شراء</th><th>شحن</th><th>كوبون</th><th>هدية</th><th>نقاط</th><th>الربح</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(r=>{ 
         const profit = (((r.shipping_cost||0) + r.cost_price) - ((r.coupon_value||0) + (r.gift_value||0) + (r.points_value||0)) - r.sale_price) * r.quantity;
      %>
        <tr>
          <td class="right"><%= dayjs(r.sold_at).format('YYYY-MM-DD HH:mm') %></td>
          <td class="right"><%= r.product_name %></td>
          <td class="right"><%= r.quantity %></td>
          <td class="right">$<%= r.sale_price.toFixed(2) %></td>
          <td class="right">$<%= r.cost_price.toFixed(2) %></td>
          <td class="right">$<%= (r.shipping_cost||0).toFixed(2) %></td>
          <td class="right">$<%= (r.coupon_value||0).toFixed(2) %></td>
          <td class="right">$<%= (r.gift_value||0).toFixed(2) %></td>
          <td class="right">$<%= (r.points_value||0).toFixed(2) %></td>
          <td class="right">$<%= profit.toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
