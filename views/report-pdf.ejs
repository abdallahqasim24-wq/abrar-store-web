<link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;600&display=swap" rel="stylesheet">
<style>
  @page { size: A4; margin: 20mm 12mm 16mm 12mm; }
  body { direction: rtl; font-family: "Noto Kufi Arabic", Arial, sans-serif; }
  h1 { margin: 0 0 14px; font-size: 20px; }
  .meta { margin-bottom: 12px; color:#555; font-size: 12px; }
  table { width:100%; border-collapse: collapse; font-size: 12px; }
  th, td { border: 1px solid #ddd; padding: 6px 8px; }
  th { background:#f5f6f8; text-align: center; }
  td { vertical-align: top; }
  tfoot th, tfoot td { background:#fafafa; font-weight: 600; }
  .right { text-align: right; }
  .center { text-align: center; }
  .kpis { display:flex; gap:10px; margin: 10px 0 16px; }
  .kpi { border:1px solid #eee; padding:10px 12px; border-radius:8px; background:#fcfcfc; }
  .muted { color:#666; }
</style>

<h1><%= title %></h1>
<div class="meta">
  تم التوليد: <%= dayjs().format('YYYY-MM-DD HH:mm') %>
</div>

<% if (!rows.length) { %>
  <p class="muted">لا توجد بيانات لهذا النطاق الزمني.</p>
<% } else { %>

  <div class="kpis">
    <div class="kpi">الإيراد: <strong>₪<%= Number(totalRevenue).toLocaleString('en-US', {minimumFractionDigits:2}) %></strong></div>
    <div class="kpi">الربح: <strong>₪<%= Number(totalProfit).toLocaleString('en-US', {minimumFractionDigits:2}) %></strong></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>التاريخ</th>
        <th>المنتج</th>
        <th>كمية</th>
        <th>سعر البيع</th>
        <th>الشحن</th>
        <th>الربح</th>
        <th>ملاحظة</th>
      </tr>
    </thead>
    <tbody>
      <% rows.forEach(s => {
     const sale = Number(s.sale_price);
     const cost = Number(s.cost_price);
     const ship = Number(s.shipping_cost || 0);
     const qty  = Number(s.quantity || 0);
     const profit = (sale * qty) - (cost * qty) - ship; // المعادلة الجديدة
%>

        <tr>
          <td class="center"><%= dayjs(s.sold_at).format('YYYY-MM-DD HH:mm') %></td>
          <td class="right"><%= s.product_name %></td>
          <td class="center"><%= qty.toLocaleString('en-US') %></td>
          <td class="center">₪<%= sale.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
          <td class="center">₪<%= ship.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
          <td class="center">₪<%= profit.toLocaleString('en-US', {minimumFractionDigits:2}) %></td>
          <td class="right"><%= (s.note || '') %></td>
        </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <th class="right" colspan="3">الإجمالي</th>
        <th class="center">₪<%= Number(totalRevenue).toLocaleString('en-US', {minimumFractionDigits:2}) %></th>
        <th></th>
        <th class="center">₪<%= Number(totalProfit).toLocaleString('en-US', {minimumFractionDigits:2}) %></th>
        <th></th>
      </tr>
    </tfoot>
  </table>

<% } %>
