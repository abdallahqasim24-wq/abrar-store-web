<link rel="stylesheet" href="<%= faLink %>">

<div class="card" style="margin-bottom:12px">
  <div class="row">
    <form method="post" action="/products" enctype="multipart/form-data" class="form-grid" style="width:100%">
      <div><label>الاسم</label><input name="name" required placeholder=""/></div>
      <div><label>الشركة</label><input name="brand" placeholder="MAC, Fenty"/></div>
      <div><label>التصنيف</label><input name="category" placeholder="Makeup / Skincare"/></div>
      <div><label>سعر الشراء ₪</label><input name="cost_price" type="number" step="0.01" required/></div>
      <div><label>سعر البيع ₪</label><input name="sale_price" type="number" step="0.01" required/></div>
      <div><label>الكمية</label><input name="stock" type="number" step="1" value="0"/></div>
      <div><label>صورة (اختياري)</label><input name="image" type="file" accept="image/*"/></div>
      <div class="right"></div>
      <div class="row right">
        <button class="btn add"><i class="fa fa-plus"></i> إضافة منتج</button>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <h3>قائمة المنتجات</h3>

  <!-- نموذج الحذف الجماعي -->
  <form id="bulkForm" method="post" action="/products/bulk-delete"></form>

  <div class="table-scroll">
    <table id="prodTable">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAll"></th>
          <th>الصورة</th><th>الاسم</th><th>الماركة</th><th>التصنيف</th>
          <th>شراء</th><th>بيع</th><th>المخزون</th><th>إجراءات</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(p=> { %>
          <tr>
            <td><input type="checkbox" name="ids" value="<%= p.id %>" class="rowCheck" form="bulkForm"></td>
            <td>
              <% if (p.image_path) { %>
                <img src="<%= p.image_path %>" class="thumb js-img" alt="<%= p.name %>">
              <% } else { %> — <% } %>
            </td>
            <td><%= p.name %></td>
            <td><%= p.brand || '—' %></td>
            <td><%= p.category || '—' %></td>
            <td>₪<%= Number(p.cost_price).toFixed(2) %></td>
            <td>₪<%= Number(p.sale_price).toFixed(2) %></td>
            <td><%= p.stock %></td>
            <td class="row" style="gap:6px">
              <form method="post" action="/products/<%= p.id %>/stock" class="row" style="gap:6px">
                <input type="number" name="delta" value="1" step="1" style="width:80px"/>
                <button class="btn save" type="submit"><i class="fa fa-boxes-stacked"></i> +/- مخزون</button>
              </form>
              <button class="btn edit" type="button" onclick='openEdit(<%- JSON.stringify(p) %>)'><i class="fa fa-pen"></i> تعديل</button>
              <form method="post" action="/products/<%= p.id %>/delete" onsubmit="return confirm("حذف المنتج؟")" class="row">
                <button class="btn danger"><i class="fa fa-trash"></i> حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="row right" style="margin-top:10px">
    <button class="btn danger" type="submit" form="bulkForm"><i class="fa fa-trash"></i> حذف المحدد</button>
  </div>
</div>

<!-- ========== قائمة الطلبات الراجعة ========== -->
<div class="card" style="margin-top:16px">
  <h3><i class="fa fa-rotate-left"></i> الطلبات الراجعة</h3>

  <% if (!returnsList || !returnsList.length) { %>
    <p class="muted">لا يوجد طلبات راجعة حالياً.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>الصورة</th>
          <th class="right">المنتج</th>
          <th>كمية</th>
          <th>سعر بيع</th>
          <th>التكلفة</th>
          <th>الشحن</th>
          <th>تاريخ الإرجاع</th>
          <th>تاريخ البيع الأصلي</th>
          <th class="right">ملاحظة</th>
          <th>إجراءات</th>
        </tr>
      </thead>
      <tbody>
        <% returnsList.forEach(r => { %>
          <tr>
            <td>
              <% if (r.product_image) { %>
                <img src="<%= r.product_image %>" class="thumb" alt="">
              <% } else { %> — <% } %>
            </td>
            <td class="right"><%= r.product_name %></td>
            <td><%= Number(r.quantity).toLocaleString('en-US') %></td>
            <td>₪<%= Number(r.sale_price).toFixed(2) %></td>
            <td>₪<%= Number(r.cost_price).toFixed(2) %></td>
            <td>₪<%= Number(r.shipping_cost||0).toFixed(2) %></td>
            <td><%= dayjs(r.created_at).format('YYYY-MM-DD hh:mm A') %></td>
            <td><%= r.sold_at ? dayjs(r.sold_at).format('YYYY-MM-DD hh:mm A') : '—' %></td>
            <td class="right"><%= r.note || '' %></td>
            <td>
              <div class="row">
                <form method="post" action="/returns/<%= r.id %>/restock" onsubmit="return confirm('إرجاع الكمية إلى المخزون؟')">
                  <button class="btn save"><i class="fa fa-boxes-stacked"></i> إرجاع للمخزون</button>
                </form>
                <form method="post" action="/returns/<%= r.id %>/reorder" onsubmit="return confirm('إعادة تسجيل كطلب بيع جديد؟')">
                  <button class="btn edit"><i class="fa fa-cart-plus"></i> إعادة كطلب</button>
                </form>
                <form method="post" action="/returns/<%= r.id %>/delete" onsubmit="return confirm('حذف نهائي من قائمة الراجعة؟')">
                  <button class="btn danger"><i class="fa fa-trash"></i> حذف نهائي</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<!-- Modal تعديل منتج -->
<div id="editModal" class="card" style="position:fixed;inset:0;max-width:760px;margin:auto;display:none;z-index:50">
  <h3><i class="fa fa-pen"></i> تعديل منتج</h3>
  <form id="editForm" method="post" enctype="multipart/form-data" class="form-grid">
    <div><label>الاسم</label><input id="e_name" name="name" required/></div>
    <div><label>الماركة</label><input id="e_brand" name="brand"/></div>
    <div><label>التصنيف</label><input id="e_category" name="category"/></div>
    <div><label>سعر الشراء ₪</label><input id="e_cost" name="cost_price" type="number" step="0.01" required/></div>
    <div><label>سعر البيع ₪</label><input id="e_sale" name="sale_price" type="number" step="0.01" required/></div>
    <div><label>الكمية</label><input id="e_stock" name="stock" type="number" step="1"/></div>
    <div><label>استبدال الصورة (اختياري)</label><input name="image" type="file" accept="image/*"/></div>
    <div class="right"></div>
    <div class="row right">
      <button type="button" class="btn danger" onclick="closeEdit()"><i class="fa fa-xmark"></i> إلغاء</button>
      <button class="btn save"><i class="fa fa-floppy-disk"></i> حفظ</button>
    </div>
  </form>
</div>
<div id="editBg" style="position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;z-index:40" onclick="closeEdit()"></div>

<script>
  function openEdit(p){
    document.getElementById('e_name').value = p.name||'';
    document.getElementById('e_brand').value = p.brand||'';
    document.getElementById('e_category').value = p.category||'';
    document.getElementById('e_cost').value = p.cost_price;
    document.getElementById('e_sale').value = p.sale_price;
    document.getElementById('e_stock').value = p.stock;
    document.getElementById('editForm').action = '/products/'+p.id+'/update';
    document.getElementById('editModal').style.display='block';
    document.getElementById('editBg').style.display='block';
  }
  function closeEdit(){
    document.getElementById('editModal').style.display='none';
    document.getElementById('editBg').style.display='none';
  }

  // select all
  document.addEventListener("DOMContentLoaded", () => {
    const selectAll = document.getElementById("selectAll");
    const checks = document.querySelectorAll(".rowCheck");
    if(selectAll){
      selectAll.addEventListener("change", e=>{
        checks.forEach(c => c.checked = e.target.checked);
      });
    }
  });
</script>
