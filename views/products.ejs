<%/* views/products.ejs */%>
<%- include('partials/layout-start') %>

<div class="container">

  <div class="page-head">
    <h1 class="page-title">المنتجات</h1>
    <a href="/" class="btn btn-light">لوحة التحكم</a>
  </div>

  <!-- نموذج إضافة منتج -->
  <div class="card">
    <div class="card-head">إضافة منتج جديد</div>
    <form action="/products" method="POST" enctype="multipart/form-data" class="grid-2 gap-24">

      <!-- الاسم -->
      <div class="col-2">
        <label class="label">الاسم</label>
        <input
          type="text"
          name="name"
          class="input"
          placeholder="اسم المنتج"
          value="<%= (typeof form !== 'undefined' && form.name) ? form.name : '' %>">
      </div>

      <!-- الماركة -->
      <div>
        <label class="label">الماركة</label>
        <input
          type="text"
          name="brand"
          class="input"
          placeholder="مثال: MAC, Fenty"
          value="<%= (typeof form !== 'undefined' && form.brand) ? form.brand : '' %>">
      </div>

      <!-- التصنيف -->
      <div>
        <label class="label">التصنيف</label>
        <input
          type="text"
          name="category"
          class="input"
          placeholder="Makeup / Skincare"
          value="<%= (typeof form !== 'undefined' && form.category) ? form.category : '' %>">
      </div>

      <!-- سعر الشراء -->
      <div>
        <label class="label">سعر الشراء $</label>
        <input
          type="number"
          step="0.01"
          name="cost_price"
          class="input"
          placeholder="0.00"
          value="<%= (typeof form !== 'undefined' && form.cost_price) ? form.cost_price : '' %>">
      </div>

      <!-- سعر البيع الافتراضي -->
      <div>
        <label class="label">سعر البيع $</label>
        <input
          type="number"
          step="0.01"
          name="sale_price"
          class="input"
          placeholder="0.00"
          value="<%= (typeof form !== 'undefined' && form.sale_price) ? form.sale_price : '' %>">
      </div>

      <!-- الكمية -->
      <div>
        <label class="label">الكمية</label>
        <input
          type="number"
          name="stock"
          class="input"
          placeholder="0"
          value="<%= (typeof form !== 'undefined' && form.stock) ? form.stock : '' %>">
      </div>

      <!-- صورة المنتج (اختياري) -->
      <div class="col-2">
        <label class="label">(اختياري) صورة</label>
        <input type="file" name="image" accept="image/*" class="input-file">
      </div>

      <!-- زر الإضافة -->
      <div class="col-2">
        <button type="submit" class="btn btn-add">
          + إضافة منتج
        </button>
      </div>
    </form>
  </div>

  <!-- جدول المنتجات -->
  <div class="card mt-24">
    <div class="card-head">قائمة المنتجات</div>

    <% if (products && products.length) { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>الاسم</th>
              <th>الماركة</th>
              <th>التصنيف</th>
              <th>سعر الشراء</th>
              <th>سعر البيع</th>
              <th>الكمية</th>
              <th>صورة</th>
              <th>إجراءات</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach((p, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><%= p.name %></td>
                <td><%= p.brand || '-' %></td>
                <td><%= p.category || '-' %></td>
                <td>$<%= Number(p.cost_price).toFixed(2) %></td>
                <td>$<%= Number(p.sale_price).toFixed(2) %></td>
                <td><%= p.stock %></td>
                <td>
                  <% if (p.image_path) { %>
                    <img src="<%= p.image_path %>" alt="" class="thumb">
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td class="actions">
                  <!-- تعديل -->
                  <form action="/products/<%= p.id %>/update" method="POST" enctype="multipart/form-data" class="inline-edit">
                    <input type="text" name="name" placeholder="اسم" class="input sm" value="<%= p.name %>">
                    <input type="text" name="brand" placeholder="ماركة" class="input sm" value="<%= p.brand %>">
                    <input type="text" name="category" placeholder="تصنيف" class="input sm" value="<%= p.category %>">
                    <input type="number" step="0.01" name="cost_price" placeholder="شراء" class="input sm" value="<%= p.cost_price %>">
                    <input type="number" step="0.01" name="sale_price" placeholder="بيع" class="input sm" value="<%= p.sale_price %>">
                    <input type="number" name="stock" placeholder="كمية" class="input sm" value="<%= p.stock %>">
                    <input type="file" name="image" class="input-file sm" accept="image/*">
                    <button class="btn btn-light sm">حفظ</button>
                  </form>

                  <!-- تعديل كمية سريع -->
                  <form action="/products/<%= p.id %>/stock" method="POST" class="inline">
                    <input type="number" name="delta" class="input xs" placeholder="+/-" step="1">
                    <button class="btn btn-light xs">تعديل الكمية</button>
                  </form>

                  <!-- حذف -->
                  <form action="/products/<%= p.id %>/delete" method="POST" class="inline">
                    <button class="btn btn-danger xs" onclick="return confirm('حذف المنتج؟')">حذف</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty">لا توجد منتجات — ابدأ بإضافة أول منتج ✨</div>
    <% } %>
  </div>
</div>

<%- include('partials/layout-end') %>
