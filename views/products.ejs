<div class="card" style="margin-bottom:12px">
  <div class="row">
    <form method="post" action="/products" enctype="multipart/form-data" class="form-grid" style="width:100%">
      <div><label>الاسم</label><input name="name" required placeholder=""/></div>
      <div><label>الماركة</label><input name="brand" placeholder="MAC, Fenty"/></div>
      <div><label>التصنيف</label><input name="category" placeholder="Makeup / Skincare"/></div>
      <div><label>سعر الشراء ₪</label><input name="cost_price" type="number" step="0.01" required/></div>
      <div><label>سعر البيع ₪</label><input name="sale_price" type="number" step="0.01" required/></div>
      <div><label>الكمية</label><input name="stock" type="number" step="1" value="0"/></div>
      <div><label>صورة (اختياري)</label><input name="image" type="file" accept="image/*"/></div>
      <div class="right"></div>
      <div class="row right"><button class="btn">+ إضافة منتج</button></div>
    </form>
  </div>
</div>

<div class="card">
  <h3>قائمة المنتجات</h3>
  <form id="bulkDeleteForm" method="post" action="/products/bulk-delete">
    <table id="prodTable">
      <thead>
        <tr>
          <th><input type="checkbox" id="selectAll"/></th>
          <th>الصورة</th><th>الاسم</th><th>الماركة</th><th>التصنيف</th>
          <th>شراء</th><th>بيع</th><th>المخزون</th><th>إجراءات</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(p=> { %>
          <tr>
            <td><input type="checkbox" name="ids[]" value="<%= p.id %>"/></td>
            <td><% if (p.image_path) { %><img src="<%= p.image_path %>" class="thumb"/><% } else { %>—<% } %></td>
            <td><%= p.name %></td>
            <td><%= p.brand %></td>
            <td><%= p.category %></td>
            <td>₪<%= Number(p.cost_price).toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
            <td>₪<%= Number(p.sale_price).toLocaleString('en-US',{minimumFractionDigits:2}) %></td>
            <td><%= Number(p.stock).toLocaleString('en-US') %></td>
            <td class="row">
              <form method="post" action="/products/<%= p.id %>/stock" class="row">
                <input type="number" name="delta" value="1" step="1" style="width:80px"/>
                <button class="btn" type="submit">+/- مخزون</button>
              </form>
              <button class="btn" type="button" onclick='openEdit(<%- JSON.stringify(p) %>)'>تعديل</button>
              <form method="post" action="/products/<%= p.id %>/delete" onsubmit="return confirm('حذف المنتج؟')" class="row">
                <button class="danger">حذف</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="row right" style="margin-top:10px">
      <button type="submit" class="danger" onclick="return confirm('حذف المنتجات المحددة؟')">حذف المحدد</button>
    </div>
  </form>
</div>

<script>
  document.getElementById('selectAll').addEventListener('change', function(e) {
    const checked = e.target.checked;
    document.querySelectorAll('input[name="ids[]"]').forEach(cb => cb.checked = checked);
  });
</script>
