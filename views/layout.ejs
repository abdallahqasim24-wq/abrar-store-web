<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Abrar Store</title>
    <link rel="stylesheet" href="<%= faLink %>">
    <link rel="stylesheet" href="/public/style.css">
  </head>
  <body>
    <header class="topbar">
      <div class="container nav">
        <div class="brand">Abrar Store</div>
        <nav class="links">
          <a href="/" class="<%= currentPath==='/'?'active':'' %>"><i class="fa fa-gauge"></i> لوحة التحكم</a>
          <a href="/products" class="<%= currentPath.startsWith('/products')?'active':'' %>"><i class="fa fa-box"></i> المنتجات</a>
          <a href="/sales" class="<%= currentPath.startsWith('/sales')?'active':'' %>"><i class="fa fa-bag-shopping"></i> المبيعات</a>
          <a href="/reports" class="<%= currentPath.startsWith('/reports')?'active':'' %>"><i class="fa fa-chart-line"></i> التقارير</a>
        </nav>
        <div class="right">
          <% if (currentUser) { %>
            <form method="post" action="/logout"><button class="btn danger"><i class="fa fa-right-from-bracket"></i> خروج</button></form>
          <% } %>
        </div>
      </div>
    </header>

    <main class="container page">
      <%- body %>
    </main>

    <!-- Lightbox مشترك -->
    <div id="imgPreviewBg"></div>
    <img id="imgPreview" alt="">
    <button id="imgPreviewClose" title="إغلاق"><i class="fa fa-xmark"></i></button>

    <script>
      (function(){
        const bg = document.getElementById('imgPreviewBg');
        const im = document.getElementById('imgPreview');
        const x  = document.getElementById('imgPreviewClose');
        function close(){ bg.style.display=im.style.display=x.style.display='none'; }
        function open(src){ im.src=src; bg.style.display=im.style.display='block'; x.style.display='flex'; }
        document.addEventListener('click', (e)=>{
          const t = e.target;
          if (t.classList && t.classList.contains('js-img') && t.src) open(t.src);
          if (t===bg || t===x) close();
        });
        window.addEventListener('keydown', e=>{ if(e.key==='Escape') close(); });
      })();
    </script>
  </body>
</html>
