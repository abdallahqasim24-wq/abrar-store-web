<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Abrar Store - نظام إدارة المتجر</title>

  <!-- أيقونات -->
  <link rel="stylesheet" href="<%= faLink %>">
  <!-- الستايل العام (يُحمّل من /public/style.css) -->
  <link rel="stylesheet" href="/public/style.css">

  <!-- زر تعديل موحّد -->
  <style>
    .btn{display:inline-flex;align-items:center;gap:8px;line-height:1}
    .btn i{font-size:14px}
    .btn.edit{background:var(--warning);color:#111;border:none;border-radius:12px;padding:12px 18px;box-shadow:var(--shadow-sm)}
    .btn.edit::before,.btn.edit::after{content:none !important;display:none !important}
    .btn.edit:hover{filter:brightness(.95); transform: translateY(-2px)}
    .btn.edit:active{transform:translateY(0);box-shadow:var(--shadow-sm)}
  </style>

  <style>
    /* مودال اختيار المنتج */
    .modal{position:fixed;inset:0;display:none;z-index:90}
    .modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.6); backdrop-filter: blur(4px)}
    .modal-card{position:absolute;inset:4% 3%;background:#fff;border-radius:24px;border:2px solid var(--border);display:flex;flex-direction:column; box-shadow: var(--shadow-xl)}
    .mclose{
      position:absolute;inset-block-start:12px;inset-inline-start:12px;
      width:42px;height:42px;border:0;border-radius:999px;background:var(--danger);color:#fff;
      display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:var(--shadow-lg);z-index:5;
      transition: var(--transition);
    }
    .mclose:hover{filter:brightness(.95); transform: scale(1.1) rotate(90deg)}
    .mhead{display:flex;gap:12px;align-items:center;padding:16px;border-bottom:2px solid #f1f5f9;padding-inline-start:64px; background: linear-gradient(135deg, #f8f9fa 0%, #fff5f9 100%)}
    .mhead h3{margin:0; font-size: 1.3rem}
    .mgrid{padding:20px;overflow:auto;display:grid;grid-template-columns:repeat(5,1fr);gap:18px}
    @media(max-width:1200px){.mgrid{grid-template-columns:repeat(4,1fr)}}
    @media(max-width:900px){.mgrid{grid-template-columns:repeat(2,1fr)}}
    .pcard{border:2px solid var(--border);border-radius:16px;padding:12px;display:flex;flex-direction:column;gap:10px; transition: var(--transition); background: #fff}
    .pcard:hover{transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--primary)}
    .pcard img{width:100%;aspect-ratio:1/1;object-fit:cover;border:2px solid var(--border);border-radius:14px; box-shadow: var(--shadow-sm)}
    .pcard .name{font-weight:800;text-align:center;min-height:48px; color: var(--text); font-size: 0.95rem}
    
    /* Status Menu */
    .status-wrap{position:relative;display:inline-block}
    .status-menu{position:absolute;inset:auto auto auto 0;transform:translateY(8px);background:#fff;border:2px solid var(--border);border-radius:12px;box-shadow:var(--shadow-lg);min-width:200px;padding:8px;z-index:30;display:none}
    .status-menu button{width:100%;text-align:right;background:#fff;color:var(--text);border:0;padding:10px 14px;border-radius:10px;cursor:pointer; font-weight: 600; transition: var(--transition)}
    .status-menu button:hover{background:#f8fafc; transform: translateX(-4px)}
    
    .order-meta{ font-size:1rem; color:var(--text-light); font-weight: 600 }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="container nav">
      <div class="brand">✨ Abrar Store</div>
      <% if (currentUser) { %>
        <a class="btab <%= currentPath==='/'?'active':'' %>" href="/"><i class="fa fa-gauge"></i> لوحة التحكم</a>
        <a class="btab <%= currentPath.startsWith('/products')?'active':'' %>" href="/products"><i class="fa fa-box"></i> المنتجات</a>
        <a class="btab <%= currentPath.startsWith('/sales')?'active':'' %>" href="/sales"><i class="fa fa-receipt"></i> المبيعات</a>
        <a class="btab <%= currentPath.startsWith('/orders')?'active':'' %>" href="/orders">
          <i class="fa fa-list"></i> كل الطلبات
        </a>
        <a class="btab <%= currentPath.startsWith('/reports')?'active':'' %>" href="/reports"><i class="fa fa-file-lines"></i> التقارير</a>

        <form class="right" method="post" action="/logout" style="margin:0">
          <button class="logout-btn" type="submit" title="تسجيل الخروج">
            <i class="fa fa-arrow-right-from-bracket"></i><span>خروج</span>
          </button>
        </form>
      <% } else { %>
        <a class="btab right" href="/login">تسجيل الدخول</a>
      <% } %>
    </div>
  </div>

  <div class="container page"><%- body %></div>

  <!-- Lightbox -->
  <div id="imgPreviewBg"></div>
  <img id="imgPreview" alt="">
  <button id="imgPreviewClose"><i class="fa fa-xmark"></i></button>

  <script>
    // Lightbox
    (function(){
      const bg=document.getElementById('imgPreviewBg');
      const im=document.getElementById('imgPreview');
      const x=document.getElementById('imgPreviewClose');
      function close(){bg.style.display=im.style.display=x.style.display='none'}
      function open(src){im.src=src;bg.style.display=im.style.display='block';x.style.display='flex'}
      document.addEventListener('click',e=>{
        const t=e.target;
        if(t.classList&&t.classList.contains('js-img')&&t.src) open(t.src);
        else if(t===bg||t===x) close();
      });
      window.addEventListener('keydown',e=>{if(e.key==='Escape') close()});
    })();

    // قائمة حالة التوصيل
    function toggleMenu(el){
      const menu=el.parentElement.querySelector('.status-menu');
      const open=menu.style.display==='block';
      document.querySelectorAll('.status-menu').forEach(m=>m.style.display='none');
      menu.style.display=open?'none':'block';
    }
    document.addEventListener('click',(e)=>{
      const wrap=e.target.closest('.status-wrap');
      if(!wrap) document.querySelectorAll('.status-menu').forEach(m=>m.style.display='none');
    });
  </script>
</body>
</html>