<section class="cards">
  <div class="card"><h3>قيمة المخزون (بيع)</h3><div class="kpi">$<%= Number(stats.total_sale_value).toFixed(2) %></div></div>
  <div class="card"><h3>قيمة المخزون (تكلفة)</h3><div class="kpi">$<%= Number(stats.total_cost_value).toFixed(2) %></div></div>
  <div class="card"><h3>إيراد الشهر</h3><div class="kpi">$<%= Number(stats.month_revenue).toFixed(2) %></div></div>
  <div class="card"><h3>ربح الشهر</h3><div class="kpi">$<%= Number(stats.month_profit).toFixed(2) %></div></div>
</section>

<section class="grid-2" style="margin-top:14px">
  <div class="card">
    <h3>آخر المبيعات 🧾</h3>
    <% if(!lastSales.length){ %><p>لا توجد مبيعات بعد.</p><% } else { %>
    <table>
      <thead><tr><th>التاريخ</th><th>المنتج</th><th>كمية</th><th>سعر</th></tr></thead>
      <tbody>
      <% lastSales.forEach(s => { %>
        <tr>
          <td><%= dayjs(s.sold_at).format('YYYY-MM-DD HH:mm') %></td>
          <td><%= s.product_name %></td>
          <td><%= s.quantity %></td>
          <td>$<%= (Number(s.sale_price) * Number(s.quantity)).toFixed(2) %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
  <div class="card">
    <h3>تنبيهات المخزون المنخفض</h3>
    <% if(!lowStock.length){ %><p>لا توجد تنبيهات ✅</p><% } else { %>
    <table>
      <thead><tr><th>المنتج</th><th>الكمية</th></tr></thead>
      <tbody>
      <% lowStock.forEach(p => { %>
        <tr><td><%= p.name %></td><td><%= p.stock %></td></tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</section>

<section class="card" style="margin-top:14px">
  <h3>توزيع الإيراد حسب التصنيف</h3>
  <canvas id="byCat"></canvas>
</section>

<script>
  (function () {
    const labels = <%- JSON.stringify(byCat.map(x => (x.label || 'غير مصنّف'))) %>;
    const values = <%- JSON.stringify(byCat.map(x => Number(x.value))) %>;

    // لو ما في بيانات، بنحط نقطة صفرية عشان ما ينهار التشارت
    const hasData = values.some(v => v > 0);
    const chartLabels = hasData ? labels : ['لا بيانات'];
    const chartValues = hasData ? values : [0];

    const data = {
      labels: chartLabels,
      datasets: [{ label: 'الإيراد', data: chartValues }]
    };

    const ctx = document.getElementById('byCat');
    if (ctx && window.Chart) {
      new Chart(ctx, { type: 'pie', data });
    }
  })();
</script>
