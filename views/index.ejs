<!-- views/index.ejs — استبدال كامل (بدون قسم "آخر البنود المُسلّمة") -->
<link rel="stylesheet" href="<%= faLink %>">

<div class="container page">
  <h2><i class="fa fa-gauge"></i> لوحة التحكم</h2>

  <div class="cards" style="margin-top:10px">
    <div class="card">
      <div class="row" style="justify-content:space-between;align-items:center">
        <div>
          <div class="muted-sm">إجمالي الإيرادات (تم التسليم)</div>
          <div style="font-size:1.6rem;font-weight:800">₪<%= Number(totals?.revenue||0).toFixed(2) %></div>
        </div>
        <i class="fa fa-sack-dollar" style="font-size:28px;opacity:.6"></i>
      </div>
    </div>

    <div class="card">
      <div class="row" style="justify-content:space-between;align-items:center">
        <div>
          <div class="muted-sm">إجمالي الربح (تم التسليم)</div>
          <div style="font-size:1.6rem;font-weight:800">₪<%= Number(totals?.profit||0).toFixed(2) %></div>
        </div>
        <i class="fa fa-chart-line" style="font-size:28px;opacity:.6"></i>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top:14px">
    <div class="row" style="gap:10px;flex-wrap:wrap">
      <a class="btn add" href="/sales"><i class="fa fa-cart-shopping"></i> مبيعات</a>
      <a class="btn secondary" href="/orders"><i class="fa fa-list"></i> الطلبات</a>
      <a class="btn edit" href="/products"><i class="fa fa-box"></i> المنتجات</a>
      <a class="btn" href="/reports"><i class="fa fa-file-lines"></i> التقارير</a>
    </div>
  </div>
</div>
