<div class="card">
  <h3><i class="fa fa-gauge"></i> ملخص سريع</h3>
  <div class="row" style="flex-wrap:wrap;gap:12px">
    <div class="card" style="min-width:220px"><div class="muted">عدد المنتجات</div><div style="font-weight:800;font-size:26px"><%= stats.products_count %></div></div>
    <div class="card" style="min-width:220px"><div class="muted">وحدات بالمخزون</div><div style="font-weight:800;font-size:26px"><%= stats.total_units %></div></div>
    <div class="card" style="min-width:220px"><div class="muted">قيمة الشراء</div><div style="font-weight:800;font-size:26px">₪<%= Number(stats.total_cost_value||0).toFixed(2) %></div></div>
    <div class="card" style="min-width:220px"><div class="muted">قيمة البيع</div><div style="font-weight:800;font-size:26px">₪<%= Number(stats.total_sale_value||0).toFixed(2) %></div></div>
  </div>
</div>

<div class="card" style="margin-top:14px">
  <h3><i class="fa fa-clock-rotate-left"></i> آخر عمليات البيع</h3>
  <table>
    <thead><tr><th>التاريخ</th><th>المنتج</th><th>كمية</th><th>سعر بيع</th></tr></thead>
    <tbody>
      <% (lastSales||[]).forEach(r=>{ %>
        <tr>
          <td><%= dayjs(r.sold_at).format('YYYY-MM-DD hh:mm A') %></td>
          <td><%= r.product_name %></td>
          <td><%= r.quantity %></td>
          <td>₪<%= Number(r.sale_price).toFixed(2) %></td>
        </tr>
      <% }) %>
      <% if(!(lastSales||[]).length){ %><tr><td colspan="4" class="muted">لا يوجد بيانات</td></tr><% } %>
    </tbody>
  </table>
</div>
