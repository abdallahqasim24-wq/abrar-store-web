<link rel="stylesheet" href="<%= faLink %>">

<div class="card">
  <h3><i class="fa fa-pen-to-square"></i> تعديل عملية بيع</h3>

  <form method="post" action="/sales/<%= sale.id %>/update" class="form-grid" style="grid-template-columns:1fr 1fr; gap:14px">
    <div>
      <label>المنتج</label>
      <select name="product_id" required>
        <% products.forEach(p=>{ %>
          <option value="<%= p.id %>" <%= p.id===sale.product_id?'selected':'' %>><%= p.name %></option>
        <% }) %>
      </select>
      <div class="muted">المخزون الحالي: <b><%= productStock %></b></div>
    </div>
    <div><label>كمية</label><input type="number" name="quantity" step="1" min="1" value="<%= sale.quantity %>"></div>
    <div><label>سعر بيع (₪)</label><input type="number" name="sale_price" step="0.01" value="<%= sale.sale_price %>"></div>
    <div><label>سعر أصلي (₪)</label><input type="number" name="cost_price" step="0.01" value="<%= sale.cost_price %>"></div>
    <div><label>شحن (₪)</label><input type="number" name="shipping_cost" step="0.01" value="<%= sale.shipping_cost||0 %>"></div>
    <div style="grid-column:span 2"><label>ملاحظة</label><input type="text" name="note" value="<%= sale.note||'' %>"></div>

    <div><label>اسم الزبون</label><input name="customer_name" value="<%= sale.customer_name||'' %>"></div>
    <div><label>الهاتف</label><input name="customer_phone" value="<%= sale.customer_phone||'' %>"></div>
    <div><label>المدينة</label><input name="customer_city" value="<%= sale.customer_city||'' %>"></div>

    <div class="right" style="grid-column:span 2">
      <a class="btn secondary" href="/orders"><i class="fa fa-arrow-right-from-bracket"></i> الرجوع</a>
      <button class="btn save" type="submit"><i class="fa fa-floppy-disk"></i> حفظ</button>
    </div>
  </form>
</div>
