<link rel="stylesheet" href="<%= faLink %>">

<div class="card">
  <h3><i class="fa fa-pen-to-square"></i> تعديل عملية #<%= sale.id %></h3>

  <form method="post" action="/sales/<%= sale.id %>/update" class="form-grid">
    <div style="grid-column:1/-1" class="row">
      <button type="button" class="btn add" id="openPicker"><i class="fa fa-grid-2"></i> اختر منتج</button>
      <div class="muted">الحقل الحالي: <strong><%= sale.product_name %></strong></div>
    </div>

    <input type="hidden" name="product_id" id="productIdField" value="<%= sale.product_id %>">

    <div>
      <label>اسم المنتج (للعرض)</label>
      <input id="productNameDisplay" value="<%= sale.product_name %>" disabled/>
    </div>

    <div><label>كمية</label><input type="number" name="quantity" value="<%= sale.quantity %>" step="1" required></div>
    <div><label>سعر البيع</label><input type="number" name="sale_price" value="<%= Number(sale.sale_price) %>" step="0.01"></div>
    <div><label>السعر الأصلي</label><input type="number" name="cost_price" value="<%= Number(sale.cost_price) %>" step="0.01"></div>
    <div><label>تكلفة الشحن +₪</label><input type="number" name="shipping_cost" value="<%= Number(sale.shipping_cost||0) %>" step="0.01"></div>
    <div><label>ملاحظة</label><input name="note" value="<%- sale.note||'' %>"></div>

    <div><label>اسم الزبون</label><input name="customer_name" value="<%- sale.customer_name||'' %>"></div>
    <div><label>رقم الهاتف</label><input name="customer_phone" value="<%- sale.customer_phone||'' %>"></div>
    <div><label>المدينة/المنطقة</label><input name="customer_city" value="<%- sale.customer_city||'' %>"></div>

    <div>
      <label>حالة التوصيل</label>
      <select name="delivery_status">
        <option value="pending"   <%= sale.delivery_status==='pending'?'selected':'' %>>قيد المعالجة</option>
        <option value="shipping"  <%= sale.delivery_status==='shipping'?'selected':'' %>>قيد التوصيل</option>
        <option value="delivered" <%= sale.delivery_status==='delivered'?'selected':'' %>>تم التسليم</option>
        <option value="failed"    <%= sale.delivery_status==='failed'?'selected':'' %>>فشل/لم يتم</option>
      </select>
    </div>

    <div class="right"></div>
    <div class="row right"><button class="btn save"><i class="fa fa-check"></i> حفظ</button></div>
  </form>
</div>

<!-- مودال شبكة (نفس مبدأ sales) -->
<div class="modal" id="pickerModal" aria-hidden="true">
  <div class="modal-bg"></div>
  <div class="modal-card">
    <div class="mhead">
      <i class="fa fa-grid-2"></i>
      <div style="font-weight:800">اختيار منتج</div>
      <input id="searchBox" placeholder="ابحث بالاسم..." class="right" style="max-width:320px">
    </div>
    <div class="mgrid" id="gridWrap">
      <% products.forEach(p=>{ %>
        <div class="pcard" data-id="<%= p.id %>"
             data-name="<%- p.name %>"
             data-img="<%= p.image_path||'' %>"
             data-sale="<%= Number(p.sale_price||0) %>"
             data-cost="<%= Number(p.cost_price||0) %>">
          <img src="<%= p.image_path||'' %>" alt="">
          <div class="name"><%= p.name %></div>
          <div style="text-align:center">
            <span class="tag">بيع: ₪<%= Number(p.sale_price||0).toFixed(2) %></span>
            <span class="tag">أصلي: ₪<%= Number(p.cost_price||0).toFixed(2) %></span>
          </div>
          <button class="btn add pickBtn" type="button"><i class="fa fa-check"></i> اختيار</button>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  (function(){
    const modal=document.getElementById('pickerModal');
    const open=document.getElementById('openPicker');
    const bg=modal.querySelector('.modal-bg');
    const search=document.getElementById('searchBox');
    const cards=[...modal.querySelectorAll('.pcard')];

    function show(){modal.style.display='block';search.focus()}
    function hide(){modal.style.display='none';search.value='';filter('')}
    open.addEventListener('click',show); bg.addEventListener('click',hide);
    document.addEventListener('keydown',e=>{ if(modal.style.display==='block' && e.key==='Escape') hide(); });

    function filter(q){
      const s=(q||'').trim().toLowerCase();
      cards.forEach(c=>{c.style.display=c.dataset.name.toLowerCase().includes(s)?'flex':'none';});
    }
    search.addEventListener('input',e=>filter(e.target.value));

    function pick(card){
      const id=card.dataset.id, name=card.dataset.name, sale=Number(card.dataset.sale||0), cost=Number(card.dataset.cost||0);
      document.getElementById('productIdField').value=id;
      document.getElementById('productNameDisplay').value=name;
      document.querySelector('input[name="sale_price"]').value=sale.toFixed(2);
      document.querySelector('input[name="cost_price"]').value=Math.max(cost,0).toFixed(2);
      hide();
    }
    modal.addEventListener('click',e=>{
      const b=e.target.closest('.pickBtn'); if(b) pick(b.closest('.pcard'));
    });
  })();
</script>
